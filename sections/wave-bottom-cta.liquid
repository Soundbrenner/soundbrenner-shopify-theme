{% liquid
  assign cta_product_handle = section.settings.product_handle | default: 'wave-in-ear-monitors'
  assign cta_product = all_products[cta_product_handle]
  assign hide_section = false
  assign cta_currency_code = cart.currency.iso_code | default: localization.country.currency.iso_code | default: shop.currency | upcase
  assign cta_variant = blank
  assign cta_has_compare_price = false
  assign cta_discount_percent = 0
  assign cta_price_cents = 0
  assign cta_compare_price_cents = 0
  assign cta_rating = 0
  assign cta_reviews_count = 0
  assign cta_has_reviews = false
  assign cta_product_url = blank
  assign cta_image = blank
  assign cta_override_image = section.settings.image
  assign storefront_cart_discount_percent = 0
  assign storefront_global_discount_percent = 0
  assign storefront_product_discount_percent = 0
  assign storefront_effective_discount_percent = 0

  if cta_product == blank or cta_product.url == blank
    assign hide_section = true
  else
    assign cta_variant = cta_product.selected_or_first_available_variant
    assign cta_product_url = cta_product.url
    assign cta_image = cta_variant.featured_image | default: cta_product.featured_image

    if cta_override_image != blank
      assign cta_image = cta_override_image
    endif

    if cta_variant == blank
      assign hide_section = true
    endif

    if cta_product.metafields.reviews.rating.value != blank
      assign cta_rating_source = cta_product.metafields.reviews.rating.value
      assign cta_rating = cta_rating_source.rating | default: cta_rating_source | plus: 0
    endif

    assign cta_reviews_count = cta_product.metafields.reviews.rating_count.value | default: 0 | plus: 0 | round: 0
    if cta_rating > 0 and cta_reviews_count > 0
      assign cta_has_reviews = true
    endif
    assign cta_price_cents = cta_variant.price | default: 0 | plus: 0
    assign cta_compare_price_cents = cta_variant.compare_at_price | default: 0 | plus: 0

    for discount_application in cart.cart_level_discount_applications
      if discount_application.value_type == 'percentage'
        assign storefront_next_discount_percent = discount_application.value | plus: 0
        if storefront_next_discount_percent > storefront_cart_discount_percent
          assign storefront_cart_discount_percent = storefront_next_discount_percent
        endif
      endif
    endfor

    for cart_item in cart.items
      for line_discount_allocation in cart_item.line_level_discount_allocations
        assign line_discount_application = line_discount_allocation.discount_application
        if line_discount_application and line_discount_application.value_type == 'percentage'
          assign storefront_next_discount_percent = line_discount_application.value | plus: 0
          if storefront_next_discount_percent > storefront_cart_discount_percent
            assign storefront_cart_discount_percent = storefront_next_discount_percent
          endif
        endif
      endfor
    endfor

    assign storefront_global_discount_percent = settings.sitewide_seasonal_discount_depth | default: 48 | plus: 0
    if storefront_cart_discount_percent > storefront_global_discount_percent
      assign storefront_global_discount_percent = storefront_cart_discount_percent
    endif
    if storefront_global_discount_percent < 0
      assign storefront_global_discount_percent = 0
    elsif storefront_global_discount_percent > 100
      assign storefront_global_discount_percent = 100
    endif

    assign storefront_override_product_1 = all_products[settings.storefront_price_override_product_id_1]
    if storefront_override_product_1 != blank and storefront_override_product_1.id == cta_product.id
      assign storefront_product_discount_percent = settings.storefront_price_override_discount_depth_1 | default: 0 | plus: 0
    endif
    assign storefront_override_product_2 = all_products[settings.storefront_price_override_product_id_2]
    if storefront_override_product_2 != blank and storefront_override_product_2.id == cta_product.id
      assign storefront_product_discount_percent = settings.storefront_price_override_discount_depth_2 | default: 0 | plus: 0
    endif
    assign storefront_override_product_3 = all_products[settings.storefront_price_override_product_id_3]
    if storefront_override_product_3 != blank and storefront_override_product_3.id == cta_product.id
      assign storefront_product_discount_percent = settings.storefront_price_override_discount_depth_3 | default: 0 | plus: 0
    endif
    assign storefront_override_product_4 = all_products[settings.storefront_price_override_product_id_4]
    if storefront_override_product_4 != blank and storefront_override_product_4.id == cta_product.id
      assign storefront_product_discount_percent = settings.storefront_price_override_discount_depth_4 | default: 0 | plus: 0
    endif
    if storefront_product_discount_percent < 0
      assign storefront_product_discount_percent = 0
    elsif storefront_product_discount_percent > 100
      assign storefront_product_discount_percent = 100
    endif

    assign storefront_effective_discount_percent = storefront_global_discount_percent
    if storefront_product_discount_percent > storefront_effective_discount_percent
      assign storefront_effective_discount_percent = storefront_product_discount_percent
    endif
    if storefront_global_discount_percent > 0 and storefront_product_discount_percent > 0
      assign storefront_keep_after_global = 100 | minus: storefront_global_discount_percent
      assign storefront_keep_after_product = 100 | minus: storefront_product_discount_percent
      assign storefront_keep_combined_percent = storefront_keep_after_global | times: storefront_keep_after_product | divided_by: 100.0
      assign storefront_effective_discount_percent = 100 | minus: storefront_keep_combined_percent
    endif

    if storefront_effective_discount_percent > 0
      assign cta_compare_price_cents = cta_price_cents
      assign storefront_keep_percent = 100 | minus: storefront_effective_discount_percent
      assign cta_price_cents = cta_price_cents | times: storefront_keep_percent | divided_by: 100.0 | round
      assign cta_discount_percent = storefront_effective_discount_percent | round
      assign cta_has_compare_price = true
    elsif cta_compare_price_cents > cta_price_cents
      assign cta_discount_percent = cta_compare_price_cents | minus: cta_price_cents | times: 100.0 | divided_by: cta_compare_price_cents | round
      assign cta_has_compare_price = true
    endif
  endif
%}

{% if hide_section %}
  <script>
    (() => {
      const sectionWrapper = document.currentScript && document.currentScript.closest('.shopify-section');
      if (sectionWrapper) {
        sectionWrapper.style.setProperty('display', 'none', 'important');
      }
    })();
  </script>
{% else %}
  {% assign cta_rating_rounded = cta_rating | round: 1 %}
  {% assign cta_rating_rounded_text = cta_rating_rounded | append: '' %}
  {% assign cta_reviews_count_text = cta_reviews_count | append: '' %}
  {% assign cta_discount_percent_text = cta_discount_percent | append: '' %}
  {% assign cta_price_today_label = section.settings.price_today_label | default: 'Price today' %}
  {% assign cta_review_summary_text = cta_rating_rounded_text | append: ' stars from ' | append: cta_reviews_count_text | append: ' reviews' %}
  {% assign cta_save_badge_text = 'Save ' | append: cta_discount_percent_text | append: '% today' %}
  <section class="sb-wave-bottom-cta" data-sb-motion="reveal">
    <div class="sb-wave-bottom-cta__shell" data-sb-motion-item>
      <div class="sb-wave-bottom-cta__content">
        <div class="sb-wave-bottom-cta__copy">
          <p class="sb-wave-bottom-cta__eyebrow font-caption weight-semibold">{{ section.settings.eyebrow }}</p>
          <h2 class="sb-wave-bottom-cta__title font-title weight-bold">
            <span class="sb-wave-bottom-cta__title-primary">{{ section.settings.title_part_one }}</span>
            <span class="sb-wave-bottom-cta__title-accent">{{ section.settings.title_part_two }}</span>
          </h2>
          <div class="sb-wave-bottom-cta__body font-body weight-regular rte">
            {{ section.settings.body }}
          </div>
        </div>

        <div class="sb-wave-bottom-cta__decision-box">
          {% if cta_has_reviews %}
            <div class="sb-wave-bottom-cta__proof">
              {% if cta_has_reviews %}
                <div class="sb-wave-bottom-cta__proof-rating">
                  <div class="sb-wave-bottom-cta__stars" aria-hidden="true" style="--sb-wave-cta-star-url: url('{{ 'icon-review-star.svg' | asset_url }}');">
                    {% for i in (1..5) %}
                      {% assign step = i | minus: 1 %}
                      {% assign fill_ratio = cta_rating | minus: step %}
                      {% if fill_ratio >= 1 %}
                        {% assign fill_percent = 100 %}
                      {% elsif fill_ratio <= 0 %}
                        {% assign fill_percent = 0 %}
                      {% else %}
                        {% assign fill_percent = fill_ratio | times: 100 | round %}
                      {% endif %}
                      <span class="sb-wave-bottom-cta__star" style="--sb-star-fill: {{ fill_percent }}%;"></span>
                    {% endfor %}
                  </div>
                  <p class="sb-wave-bottom-cta__proof-text font-caption weight-semibold">
                    {{ cta_review_summary_text }}
                  </p>
                </div>
              {% endif %}
            </div>
          {% endif %}

          <div class="sb-wave-bottom-cta__value-panel">
            <div class="sb-wave-bottom-cta__value-top">
              <div class="sb-wave-bottom-cta__value-copy">
                <p class="sb-wave-bottom-cta__offer-label font-caption weight-semibold">{{ cta_price_today_label }}</p>
                <div class="sb-wave-bottom-cta__price-row">
                  <span class="sb-wave-bottom-cta__current-price font-body weight-bold">
                    {% render 'sb-money-no-decimals', amount: cta_price_cents, currency: cta_currency_code, context: 'storefront' %}
                  </span>
                  {% if cta_has_compare_price %}
                    <span class="sb-wave-bottom-cta__compare-price font-body weight-regular">
                      {% render 'sb-money-no-decimals', amount: cta_compare_price_cents, currency: cta_currency_code, context: 'storefront' %}
                    </span>
                  {% endif %}
                </div>
                {% if section.settings.value_anchor != blank %}
                  <p class="sb-wave-bottom-cta__value-anchor font-caption weight-regular">{{ section.settings.value_anchor }}</p>
                {% endif %}
              </div>

              {% if cta_has_compare_price %}
                <p class="sb-wave-bottom-cta__savings-badge font-caption weight-semibold">
                  {{ cta_save_badge_text }}
                </p>
              {% endif %}
            </div>

            {% if section.settings.trust_line != blank %}
              <div class="sb-wave-bottom-cta__guarantee-row">
                <span
                  class="sb-wave-bottom-cta__guarantee-icon"
                  aria-hidden="true"
                  style="--sb-wave-bottom-cta-guarantee-icon-url: url('https://cdn.shopify.com/s/files/1/1306/4847/files/check.svg?v=1774512519');"
                ></span>
                <p class="sb-wave-bottom-cta__guarantee-text font-caption weight-semibold">{{ section.settings.trust_line }}</p>
              </div>
            {% endif %}

            {% if section.settings.helper_text != blank %}
              <div class="sb-wave-bottom-cta__shipping-row">
                <span
                  class="sb-wave-bottom-cta__guarantee-icon"
                  aria-hidden="true"
                  style="--sb-wave-bottom-cta-guarantee-icon-url: url('https://cdn.shopify.com/s/files/1/1306/4847/files/check.svg?v=1774512519');"
                ></span>
                <p class="sb-wave-bottom-cta__shipping-text font-caption weight-regular">{{ section.settings.helper_text }}</p>
              </div>
            {% endif %}
          </div>

          <div class="sb-wave-bottom-cta__actions">
          {% render 'radiant-button',
            label: section.settings.button_label,
            link: cta_product_url,
            size: 'large',
            icon_position: 'trailing',
            extra_class: 'sb-wave-bottom-cta__button'
          %}
          </div>
        </div>
      </div>

      <div class="sb-wave-bottom-cta__media">
        {% if cta_image != blank %}
          {% assign cta_image_width = cta_image.width | default: 1200 | at_most: 1200 %}
          {{
            cta_image
            | image_url: width: cta_image_width
            | image_tag:
              class: 'sb-wave-bottom-cta__image',
              widths: '480, 640, 800, 1024, 1200',
              sizes: '(min-width: 990px) 32vw, 100vw',
              alt: cta_product.title,
              loading: 'lazy'
          }}
        {% else %}
          <img
            class="sb-wave-bottom-cta__image"
            src="{{ 'placeholder-large-feature.png' | asset_url }}"
            alt="{{ cta_product.title | escape }}"
            loading="lazy"
            width="1200"
            height="1108"
          >
        {% endif %}

        {% if section.settings.included_items != blank %}
          <div class="sb-wave-bottom-cta__included-items font-caption weight-regular rte">
            {{ section.settings.included_items }}
          </div>
        {% endif %}
      </div>
    </div>
  </section>
{% endif %}

{% stylesheet %}
  .sb-wave-bottom-cta {
    --sb-wave-bottom-cta-muted-text: var(--sb-light-neutral-600);

    width: 100%;
  }

  .sb-wave-bottom-cta__shell {
    align-items: stretch;
    background:
      radial-gradient(circle at top right, rgba(0, 201, 183, 0.12) 0, transparent 24%),
      linear-gradient(180deg, #151515 0%, #0d0d0d 56%, #050505 100%);
    border: 1px solid var(--sb-color-neutral-700);
    border-radius: 32px;
    display: grid;
    gap: 28px;
    grid-template-columns: minmax(0, 1.08fr) minmax(280px, 0.92fr);
    overflow: hidden;
    padding: 24px;
  }

  .sb-wave-bottom-cta__content {
    display: flex;
    flex-direction: column;
    gap: 24px;
    height: 100%;
    justify-content: space-between;
    min-width: 0;
  }

  .sb-wave-bottom-cta__copy {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .sb-wave-bottom-cta__eyebrow,
  .sb-wave-bottom-cta__title,
  .sb-wave-bottom-cta__proof-text,
  .sb-wave-bottom-cta__trust-text,
  .sb-wave-bottom-cta__offer-label,
  .sb-wave-bottom-cta__guarantee-text,
  .sb-wave-bottom-cta__shipping-text,
  .sb-wave-bottom-cta__helper {
    margin: 0;
  }

  .sb-wave-bottom-cta__eyebrow {
    color: var(--sb-color-primary-500);
    font-size: 0.95rem;
    text-transform: uppercase;
  }

  .sb-wave-bottom-cta__title {
    color: var(--sb-color-always-white);
    line-height: 0.96;
    margin: 0;
    max-width: 12ch;
    text-wrap: balance;
  }

  .sb-wave-bottom-cta__title-primary,
  .sb-wave-bottom-cta__title-accent {
    color: inherit;
    text-wrap: pretty;
  }

  .sb-wave-bottom-cta__title-accent {
    color: var(--sb-color-always-white);
  }

  .sb-wave-bottom-cta__body {
    color: var(--sb-color-always-white);
    font-size: 1rem;
    line-height: 1.7;
    opacity: 0.96;
  }

  .sb-wave-bottom-cta__body,
  .sb-wave-bottom-cta__body p,
  .sb-wave-bottom-cta__body strong,
  .sb-wave-bottom-cta__body a {
    color: var(--sb-color-always-white);
  }

  .sb-wave-bottom-cta__body > * {
    margin: 0;
  }

  .sb-wave-bottom-cta__body > * + * {
    margin-top: 20px;
  }

  .sb-wave-bottom-cta__decision-box {
    display: flex;
    flex: 1 1 auto;
    flex-direction: column;
    gap: 18px;
    justify-content: flex-end;
  }

  .sb-wave-bottom-cta__proof {
    align-self: flex-start;
    align-items: flex-start;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-width: 100%;
    padding: 14px 16px;
    width: fit-content;
  }

  .sb-wave-bottom-cta__proof-text,
  .sb-wave-bottom-cta__trust-text,
  .sb-wave-bottom-cta__offer-label,
  .sb-wave-bottom-cta__value-anchor,
  .sb-wave-bottom-cta__guarantee-text,
  .sb-wave-bottom-cta__shipping-text {
    color: var(--sb-wave-bottom-cta-muted-text);
  }

  .sb-wave-bottom-cta__proof-rating {
    align-items: center;
    display: flex;
    flex-wrap: nowrap;
    gap: 10px;
    max-width: 100%;
  }

  .sb-wave-bottom-cta__proof-text {
    color: var(--sb-color-always-white);
    font-size: 0.95rem;
    line-height: 1.4;
    min-width: 0;
    opacity: 1;
  }

  .sb-wave-bottom-cta__proof-text,
  .sb-wave-bottom-cta__proof-text * {
    color: var(--sb-color-always-white);
  }

  .sb-wave-bottom-cta__trust-text {
    color: var(--sb-wave-bottom-cta-muted-text);
  }

  .sb-wave-bottom-cta__savings-badge {
    background: rgba(0, 201, 183, 0.12);
    border: 1px solid rgba(0, 201, 183, 0.4);
    border-radius: 999px;
    color: var(--sb-color-primary-500);
    display: inline-flex;
    margin: 0;
    padding: 8px 12px;
    white-space: nowrap;
  }

  .sb-wave-bottom-cta__stars {
    display: inline-flex;
    gap: 6px;
  }

  .sb-wave-bottom-cta__star {
    background: linear-gradient(90deg, var(--sb-color-reviews) var(--sb-star-fill), var(--sb-color-neutral-700) var(--sb-star-fill));
    display: block;
    height: 18px;
    mask: center / contain no-repeat var(--sb-wave-cta-star-url);
    width: 18px;
    -webkit-mask: center / contain no-repeat var(--sb-wave-cta-star-url);
  }

  .sb-wave-bottom-cta__value-panel {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.04) 100%);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 24px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
    display: flex;
    flex-direction: column;
    gap: 18px;
    padding: 22px;
  }

  .sb-wave-bottom-cta__value-top {
    align-items: flex-start;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .sb-wave-bottom-cta__value-copy {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .sb-wave-bottom-cta__offer-label {
    color: var(--sb-wave-bottom-cta-muted-text);
    font-size: 0.78rem;
    text-transform: uppercase;
  }

  .sb-wave-bottom-cta__value-panel,
  .sb-wave-bottom-cta__value-panel p,
  .sb-wave-bottom-cta__value-panel span {
    color: var(--sb-color-always-white);
  }

  .sb-wave-bottom-cta__value-panel .sb-wave-bottom-cta__offer-label,
  .sb-wave-bottom-cta__value-panel .sb-wave-bottom-cta__compare-price,
  .sb-wave-bottom-cta__value-panel .sb-wave-bottom-cta__value-anchor,
  .sb-wave-bottom-cta__value-panel .sb-wave-bottom-cta__guarantee-text,
  .sb-wave-bottom-cta__value-panel .sb-wave-bottom-cta__shipping-text {
    color: var(--sb-wave-bottom-cta-muted-text);
  }

  .sb-wave-bottom-cta__price-row {
    align-items: baseline;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .sb-wave-bottom-cta__compare-price {
    color: var(--sb-wave-bottom-cta-muted-text);
    font-size: 1rem;
    margin: 0;
    text-decoration: line-through;
  }

  .sb-wave-bottom-cta__current-price {
    color: var(--sb-color-primary-500);
    font-size: clamp(2rem, 4.8vw, 3.2rem);
    letter-spacing: -0.03em;
    line-height: 0.92;
    text-shadow: 0 0 24px rgba(0, 201, 183, 0.14);
  }

  .sb-wave-bottom-cta__value-anchor {
    color: var(--sb-wave-bottom-cta-muted-text);
    font-size: 0.88rem;
    line-height: 1.6;
    margin: 0;
    max-width: 28ch;
  }

  .sb-wave-bottom-cta__guarantee-row {
    align-items: center;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    gap: 12px;
    padding-top: 18px;
  }

  .sb-wave-bottom-cta__guarantee-icon {
    background: var(--sb-color-primary-500);
    display: block;
    flex: 0 0 16px;
    height: 16px;
    mask-image: var(--sb-wave-bottom-cta-guarantee-icon-url);
    mask-position: center;
    mask-repeat: no-repeat;
    mask-size: contain;
    width: 16px;
    -webkit-mask-image: var(--sb-wave-bottom-cta-guarantee-icon-url);
    -webkit-mask-position: center;
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-size: contain;
  }

  .sb-wave-bottom-cta__guarantee-text {
    color: var(--sb-wave-bottom-cta-muted-text);
  }

  .sb-wave-bottom-cta__shipping-row {
    align-items: center;
    display: flex;
    gap: 12px;
  }

  .sb-wave-bottom-cta__shipping-text {
    color: var(--sb-wave-bottom-cta-muted-text);
    line-height: 1.6;
  }

  .sb-wave-bottom-cta__actions {
    align-items: stretch;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .sb-wave-bottom-cta__button {
    box-shadow: 0 18px 36px rgba(0, 201, 183, 0.16);
    justify-content: center;
    width: 100%;
  }

  .sb-wave-bottom-cta__media {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.04) 100%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    height: 100%;
    overflow: hidden;
    padding: 12px;
    width: 100%;
  }

  .sb-wave-bottom-cta__image {
    aspect-ratio: 620 / 554;
    border-radius: 24px;
    display: block;
    flex: 1 1 auto;
    height: 100%;
    object-fit: cover;
    object-position: 38% 50%;
    width: 100%;
  }

  .sb-wave-bottom-cta__included-items {
    color: var(--sb-wave-bottom-cta-muted-text);
    font-size: 0.82rem;
    line-height: 1.7;
    padding: 0 4px 4px;
  }

  .sb-wave-bottom-cta__included-items,
  .sb-wave-bottom-cta__included-items p,
  .sb-wave-bottom-cta__included-items li,
  .sb-wave-bottom-cta__included-items strong {
    color: var(--sb-wave-bottom-cta-muted-text);
  }

  .sb-wave-bottom-cta__included-items > * {
    margin: 0;
  }

  .sb-wave-bottom-cta__included-items ul {
    display: grid;
    gap: 10px;
    margin: 0;
    padding-left: 18px;
  }

  .sb-wave-bottom-cta__included-items li::marker {
    color: var(--sb-color-primary-500);
  }

  @media screen and (max-width: 1180px) {
    .sb-wave-bottom-cta__shell {
      grid-template-columns: minmax(0, 1fr) minmax(260px, 0.86fr);
    }
  }

  @media screen and (max-width: 989px) {
    .sb-wave-bottom-cta__title {
      max-width: none;
    }

    .sb-wave-bottom-cta__shell {
      gap: 24px;
      grid-template-columns: 1fr;
      padding: 24px 18px;
    }

    .sb-wave-bottom-cta__media {
      height: auto;
    }
  }

  @media screen and (max-width: 749px) {
    .sb-wave-bottom-cta__content {
      gap: 16px;
    }

    .sb-wave-bottom-cta__current-price {
      font-size: 2.4rem;
    }

    .sb-wave-bottom-cta__proof {
      padding: 12px 14px;
    }

    .sb-wave-bottom-cta__value-panel {
      padding: 16px;
    }

    .sb-wave-bottom-cta__image {
      aspect-ratio: 4 / 3;
    }
  }

  @media screen and (min-width: 750px) {
    .sb-wave-bottom-cta__value-top {
      align-items: center;
      flex-direction: row;
      justify-content: space-between;
    }

    .sb-wave-bottom-cta__proof {
      align-items: center;
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: space-between;
    }

    .sb-wave-bottom-cta__trust-text {
      text-align: right;
    }
  }
{% endstylesheet %}

