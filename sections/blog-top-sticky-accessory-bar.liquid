{% liquid
  assign active_tag_handle = ''
  assign has_product_tag_filters = false
  assign has_instrument_tag_filters = false
  assign active_tag_is_product_filter = false
  assign active_tag_is_instrument_filter = false
  assign active_product_filter_label = ''
  assign active_instrument_filter_label = ''
  assign active_dropdown_tag_label = ''
  assign all_filter_is_active = true
  assign explore_shop_label = 'sb.blog.explore_shop' | t

  if current_tags != blank
    assign active_tag_handle = current_tags.first | handleize
    assign all_filter_is_active = false
  elsif request.page_type == 'article'
    assign all_filter_is_active = false
  endif
%}

{% capture product_tag_filter_options %}
  {% for tag in blog.all_tags %}
    {% liquid
      assign tag_value = tag | strip
      assign tag_value_handle = tag_value | handleize
      assign tag_value_downcase = tag_value | downcase
      assign tag_prefix = tag_value_downcase | slice: 0, 10
      assign option_label = ''
      assign localized_option_label = ''
      assign locale_fallback_label = ''
      assign option_key = ''
      assign linked_product = blank
      assign linked_collection = blank

      if tag_prefix == 'by_product'
        assign option_label = tag_value | slice: 10, tag_value.size
        assign leading_char = option_label | slice: 0, 1
        if leading_char == '_' or leading_char == '-' or leading_char == ':' or leading_char == '|'
          assign option_label = option_label | slice: 1, option_label.size
        endif
        assign option_label = option_label | strip
        if option_label == blank
          assign option_label = tag_value
        endif

        assign option_key = option_label | handleize
        assign localized_option_label = option_label
        assign linked_product = all_products[option_key]
        assign linked_collection = collections[option_key]

        assign locale_fallback_label = 'sb.blog.product_filters.' | append: option_key | t

        if linked_product != blank
          assign localized_option_label = linked_product.title
        elsif linked_collection != blank
          assign localized_option_label = linked_collection.title
        elsif option_key == 'the-metronome-app'
          assign localized_option_label = 'sb.header.metronome_app' | t
        elsif locale_fallback_label contains 'translation missing:'
        else
          assign localized_option_label = locale_fallback_label
        endif
      endif
    %}

    {% if option_label != blank %}
      {% liquid
        assign has_product_tag_filters = true
        assign option_is_active = false
        if active_tag_handle == tag_value_handle
          assign option_is_active = true
          assign active_tag_is_product_filter = true
          assign active_product_filter_label = localized_option_label
          assign active_dropdown_tag_label = localized_option_label
        endif
      %}
      <a
        class="sb-blog-overview__sticky-filter-option font-caption weight-semibold{% if option_is_active %} is-active{% endif %}"
        href="{{ blog.url }}/tagged/{{ tag_value_handle }}"
      >
        {{ localized_option_label | escape }}
      </a>
    {% endif %}
  {% endfor %}
{% endcapture %}

{% capture instrument_tag_filter_options %}
  {% for tag in blog.all_tags %}
    {% liquid
      assign tag_value = tag | strip
      assign tag_value_handle = tag_value | handleize
      assign tag_value_downcase = tag_value | downcase
      assign tag_prefix = tag_value_downcase | slice: 0, 13
      assign option_label = ''
      assign localized_option_label = ''
      assign option_key = ''

      if tag_prefix == 'by_instrument'
        assign option_label = tag_value | slice: 13, tag_value.size
        assign leading_char = option_label | slice: 0, 1
        if leading_char == '_' or leading_char == '-' or leading_char == ':' or leading_char == '|'
          assign option_label = option_label | slice: 1, option_label.size
        endif
        assign option_label = option_label | strip
        if option_label == blank
          assign option_label = tag_value
        endif

        assign option_key = option_label | handleize | replace: '-', '_'
        assign localized_option_label = 'sb.blog.instrument_filters.' | append: option_key | t
        if localized_option_label contains 'translation missing:'
          assign localized_option_label = option_label
        endif
      endif
    %}

    {% if option_label != blank %}
      {% liquid
        assign has_instrument_tag_filters = true
        assign option_is_active = false
        if active_tag_handle == tag_value_handle
          assign option_is_active = true
          assign active_tag_is_instrument_filter = true
          assign active_instrument_filter_label = localized_option_label
          assign active_dropdown_tag_label = localized_option_label
        endif
      %}
      <a
        class="sb-blog-overview__sticky-filter-option font-caption weight-semibold{% if option_is_active %} is-active{% endif %}"
        href="{{ blog.url }}/tagged/{{ tag_value_handle }}"
      >
        {{ localized_option_label | escape }}
      </a>
    {% endif %}
  {% endfor %}
{% endcapture %}

{% liquid
  assign mobile_categories_trigger_label = 'sb.blog.categories' | t
  if active_dropdown_tag_label != blank
    assign mobile_categories_trigger_label = active_dropdown_tag_label
  elsif active_tag_handle == 'company-news'
    assign mobile_categories_trigger_label = 'sb.blog.company_news' | t
  elsif active_tag_handle == 'music-insights'
    assign mobile_categories_trigger_label = 'sb.blog.music_insights' | t
  elsif active_tag_handle == 'product-insights' or active_tag_handle == 'product-tips'
    assign mobile_categories_trigger_label = 'sb.blog.product_tips' | t
  elsif active_tag_handle == 'gift-guides'
    assign mobile_categories_trigger_label = 'sb.blog.gift_guides' | t
  elsif active_tag_handle != blank
    assign mobile_categories_trigger_label = current_tags.first
  endif
%}

<section class="sb-blog-top-sticky-accessory-bar">
  <div
    class="sb-blog-overview__sticky-nav-wrap sb-blog-overview__sticky-nav-wrap--desktop"
    aria-label="{{ 'sb.blog.sticky_navigation' | t }}"
  >
    <div class="sb-blog-overview__sticky-nav">
      <div class="sb-blog-overview__sticky-nav-left" aria-label="{{ 'sb.blog.category_filters' | t }}">
        <a
          class="sb-blog-overview__sticky-filter font-caption{% if all_filter_is_active %} is-active{% endif %}"
          href="{{ blog.url }}"
        >
          {{ 'sb.blog.all' | t }}
        </a>
        <a
          class="sb-blog-overview__sticky-filter font-caption{% if active_tag_handle == 'company-news' %} is-active{% endif %}"
          href="{{ blog.url }}/tagged/company-news"
        >
          {{ 'sb.blog.company_news' | t }}
        </a>
        <a
          class="sb-blog-overview__sticky-filter font-caption{% if active_tag_handle == 'music-insights' %} is-active{% endif %}"
          href="{{ blog.url }}/tagged/music-insights"
        >
          {{ 'sb.blog.music_insights' | t }}
        </a>
        <a
          class="sb-blog-overview__sticky-filter font-caption{% if active_tag_handle == 'product-insights' or active_tag_handle == 'product-tips' %} is-active{% endif %}"
          href="{{ blog.url }}/tagged/product-tips"
        >
          {{ 'sb.blog.product_tips' | t }}
        </a>
        <a
          class="sb-blog-overview__sticky-filter font-caption{% if active_tag_handle == 'gift-guides' %} is-active{% endif %}"
          href="{{ blog.url }}/tagged/gift-guides"
        >
          {{ 'sb.blog.gift_guides' | t }}
        </a>

        {% if has_product_tag_filters %}
          <div class="sb-blog-overview__sticky-dropdown" data-sb-blog-filter-dropdown>
            <button
              type="button"
              class="sb-blog-overview__sticky-filter sb-blog-overview__sticky-filter--dropdown font-caption{% if active_tag_is_product_filter %} is-active{% endif %}"
              aria-expanded="false"
              aria-controls="SbBlogTopBarByProductPanel-{{ section.id }}"
              data-sb-blog-filter-trigger
            >
              <span>{% if active_product_filter_label != blank %}{{ active_product_filter_label | escape }}{% else %}{{ 'sb.blog.by_product' | t }}{% endif %}</span>
              <span class="sb-blog-overview__sticky-filter-caret" aria-hidden="true">
                {{ 'icon-chevron.svg' | inline_asset_content }}
              </span>
            </button>
            <div
              id="SbBlogTopBarByProductPanel-{{ section.id }}"
              class="sb-blog-overview__sticky-filter-panel"
              data-sb-blog-filter-panel
            >
              <div class="sb-blog-overview__sticky-filter-panel-surface">
                <div class="sb-blog-overview__sticky-filter-panel-inner">
                  {{ product_tag_filter_options }}
                </div>
              </div>
            </div>
          </div>
        {% endif %}

        {% if has_instrument_tag_filters %}
          <div class="sb-blog-overview__sticky-dropdown" data-sb-blog-filter-dropdown>
            <button
              type="button"
              class="sb-blog-overview__sticky-filter sb-blog-overview__sticky-filter--dropdown font-caption{% if active_tag_is_instrument_filter %} is-active{% endif %}"
              aria-expanded="false"
              aria-controls="SbBlogTopBarByInstrumentPanel-{{ section.id }}"
              data-sb-blog-filter-trigger
            >
              <span>{% if active_instrument_filter_label != blank %}{{ active_instrument_filter_label | escape }}{% else %}{{ 'sb.blog.by_instrument' | t }}{% endif %}</span>
              <span class="sb-blog-overview__sticky-filter-caret" aria-hidden="true">
                {{ 'icon-chevron.svg' | inline_asset_content }}
              </span>
            </button>
            <div
              id="SbBlogTopBarByInstrumentPanel-{{ section.id }}"
              class="sb-blog-overview__sticky-filter-panel"
              data-sb-blog-filter-panel
            >
              <div class="sb-blog-overview__sticky-filter-panel-surface">
                <div class="sb-blog-overview__sticky-filter-panel-inner">
                  {{ instrument_tag_filter_options }}
                </div>
              </div>
            </div>
          </div>
        {% endif %}
      </div>
      {%
        render 'radiant-button',
        link: routes.all_products_collection_url,
        label: explore_shop_label,
        size: 'medium',
        extra_class: 'sb-blog-overview__sticky-nav-shop-button font-caption weight-bold'
      %}
    </div>
  </div>

  <div
    class="sb-blog-overview__sticky-nav-wrap sb-blog-overview__sticky-nav-wrap--mobile"
    aria-label="{{ 'sb.blog.sticky_navigation' | t }}"
  >
    <div class="sb-blog-overview__sticky-nav sb-blog-overview__sticky-nav--mobile">
      <div class="sb-blog-overview__sticky-dropdown" data-sb-blog-filter-dropdown>
        <button
          type="button"
          class="sb-blog-overview__sticky-filter sb-blog-overview__sticky-filter--dropdown sb-blog-overview__sticky-filter--mobile font-caption{% if active_tag_handle != blank %} is-active{% endif %}"
          aria-expanded="false"
          aria-controls="SbBlogTopBarCategoriesPanel-{{ section.id }}"
          data-sb-blog-filter-trigger
        >
          <span class="sb-blog-overview__sticky-filter-label sb-blog-overview__sticky-filter-label--mobile weight-semibold">{{ mobile_categories_trigger_label | escape }}</span>
          <span class="sb-blog-overview__sticky-filter-caret" aria-hidden="true">
            {{ 'icon-chevron.svg' | inline_asset_content }}
          </span>
        </button>
      </div>
      {%
        render 'radiant-button',
        link: routes.all_products_collection_url,
        label: explore_shop_label,
        size: 'medium',
        extra_class: 'sb-blog-overview__sticky-nav-shop-button sb-blog-overview__sticky-nav-shop-button--mobile font-caption weight-bold'
      %}
    </div>
  </div>

  <div class="menu-drawer-container sb-blog-overview__drawer-container" data-sb-blog-filter-drawer-container>
    <div
      id="SbBlogTopBarCategoriesPanel-{{ section.id }}"
      class="menu-drawer sb-blog-overview__sticky-filter-panel sb-blog-overview__sticky-filter-panel--mobile"
      data-sb-blog-filter-panel
    >
      <div class="sb-blog-overview__sticky-filter-panel-surface">
        <div class="sb-blog-overview__sticky-filter-panel-inner sb-blog-overview__sticky-filter-panel-inner--mobile">
          <div class="sb-blog-overview__sticky-filter-panel-header">
            <button
              type="button"
              class="menu-drawer__close-button sb-blog-overview__sticky-filter-close"
              data-sb-blog-filter-close
              aria-label="{{ 'sb.blog.close_categories' | t }}"
            >
              <span class="menu-drawer__close-icon sb-blog-overview__sticky-filter-close-icon" aria-hidden="true">
                {{ 'icon-cancel.svg' | inline_asset_content }}
              </span>
            </button>
            <p
              class="sb-blog-overview__sticky-filter-panel-title menu-drawer__animated-element font-callout weight-bold"
              style="--menu-drawer-animation-index: 1;"
            >
              {{ 'sb.blog.categories' | t }}
            </p>
          </div>

          <div class="sb-blog-overview__sticky-filter-panel-list">
            {% assign mobile_filter_animation_index = 2 %}
            <a
              class="sb-blog-overview__sticky-filter-option menu-drawer__animated-element font-caption{% if all_filter_is_active %} is-active{% endif %}"
              href="{{ blog.url }}"
              style="--menu-drawer-animation-index: {{ mobile_filter_animation_index }};"
            >
              {{ 'sb.blog.all' | t }}
            </a>
            {% assign mobile_filter_animation_index = mobile_filter_animation_index | plus: 1 %}
            <a
              class="sb-blog-overview__sticky-filter-option menu-drawer__animated-element font-caption{% if active_tag_handle == 'company-news' %} is-active{% endif %}"
              href="{{ blog.url }}/tagged/company-news"
              style="--menu-drawer-animation-index: {{ mobile_filter_animation_index }};"
            >
              {{ 'sb.blog.company_news' | t }}
            </a>
            {% assign mobile_filter_animation_index = mobile_filter_animation_index | plus: 1 %}
            <a
              class="sb-blog-overview__sticky-filter-option menu-drawer__animated-element font-caption{% if active_tag_handle == 'music-insights' %} is-active{% endif %}"
              href="{{ blog.url }}/tagged/music-insights"
              style="--menu-drawer-animation-index: {{ mobile_filter_animation_index }};"
            >
              {{ 'sb.blog.music_insights' | t }}
            </a>
            {% assign mobile_filter_animation_index = mobile_filter_animation_index | plus: 1 %}
            <a
              class="sb-blog-overview__sticky-filter-option menu-drawer__animated-element font-caption{% if active_tag_handle == 'product-insights' or active_tag_handle == 'product-tips' %} is-active{% endif %}"
              href="{{ blog.url }}/tagged/product-tips"
              style="--menu-drawer-animation-index: {{ mobile_filter_animation_index }};"
            >
              {{ 'sb.blog.product_tips' | t }}
            </a>
            {% assign mobile_filter_animation_index = mobile_filter_animation_index | plus: 1 %}
            <a
              class="sb-blog-overview__sticky-filter-option menu-drawer__animated-element font-caption{% if active_tag_handle == 'gift-guides' %} is-active{% endif %}"
              href="{{ blog.url }}/tagged/gift-guides"
              style="--menu-drawer-animation-index: {{ mobile_filter_animation_index }};"
            >
              {{ 'sb.blog.gift_guides' | t }}
            </a>
            {% assign mobile_filter_animation_index = mobile_filter_animation_index | plus: 1 %}

            {% if has_product_tag_filters %}
              <span
                class="sb-blog-overview__sticky-filter-option sb-blog-overview__sticky-filter-option--group menu-drawer__animated-element font-caption"
                style="--menu-drawer-animation-index: {{ mobile_filter_animation_index }};"
              >
                {{ 'sb.blog.by_product' | t }}
              </span>
              {% assign mobile_filter_animation_index = mobile_filter_animation_index | plus: 1 %}
              <div class="sb-blog-overview__sticky-filter-option-children">
                {% for tag in blog.all_tags %}
                  {% liquid
                    assign tag_value = tag | strip
                    assign tag_value_handle = tag_value | handleize
                    assign tag_value_downcase = tag_value | downcase
                    assign tag_prefix = tag_value_downcase | slice: 0, 10
                    assign option_label = ''

                    if tag_prefix == 'by_product'
                      assign option_label = tag_value | slice: 10, tag_value.size
                      assign leading_char = option_label | slice: 0, 1
                      if leading_char == '_' or leading_char == '-' or leading_char == ':' or leading_char == '|'
                        assign option_label = option_label | slice: 1, option_label.size
                      endif
                      assign option_label = option_label | strip
                      if option_label == blank
                        assign option_label = tag_value
                      endif
                    endif
                  %}
                  {% if option_label != blank %}
                    <a
                      class="sb-blog-overview__sticky-filter-option menu-drawer__animated-element font-caption{% if active_tag_handle == tag_value_handle %} is-active{% endif %}"
                      href="{{ blog.url }}/tagged/{{ tag_value_handle }}"
                      style="--menu-drawer-animation-index: {{ mobile_filter_animation_index }};"
                    >
                      {{ option_label | escape }}
                    </a>
                    {% assign mobile_filter_animation_index = mobile_filter_animation_index | plus: 1 %}
                  {% endif %}
                {% endfor %}
              </div>
            {% endif %}

            {% if has_instrument_tag_filters %}
              <span
                class="sb-blog-overview__sticky-filter-option sb-blog-overview__sticky-filter-option--group menu-drawer__animated-element font-caption"
                style="--menu-drawer-animation-index: {{ mobile_filter_animation_index }};"
              >
                {{ 'sb.blog.by_instrument' | t }}
              </span>
              {% assign mobile_filter_animation_index = mobile_filter_animation_index | plus: 1 %}
              <div class="sb-blog-overview__sticky-filter-option-children">
                {% for tag in blog.all_tags %}
                  {% liquid
                    assign tag_value = tag | strip
                    assign tag_value_handle = tag_value | handleize
                    assign tag_value_downcase = tag_value | downcase
                    assign tag_prefix = tag_value_downcase | slice: 0, 13
                    assign option_label = ''

                    if tag_prefix == 'by_instrument'
                      assign option_label = tag_value | slice: 13, tag_value.size
                      assign leading_char = option_label | slice: 0, 1
                      if leading_char == '_' or leading_char == '-' or leading_char == ':' or leading_char == '|'
                        assign option_label = option_label | slice: 1, option_label.size
                      endif
                      assign option_label = option_label | strip
                      if option_label == blank
                        assign option_label = tag_value
                      endif
                    endif
                  %}
                  {% if option_label != blank %}
                    <a
                      class="sb-blog-overview__sticky-filter-option menu-drawer__animated-element font-caption{% if active_tag_handle == tag_value_handle %} is-active{% endif %}"
                      href="{{ blog.url }}/tagged/{{ tag_value_handle }}"
                      style="--menu-drawer-animation-index: {{ mobile_filter_animation_index }};"
                    >
                      {{ option_label | escape }}
                    </a>
                    {% assign mobile_filter_animation_index = mobile_filter_animation_index | plus: 1 %}
                  {% endif %}
                {% endfor %}
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
    <div class="menu-drawer__backdrop menu-drawer__backdrop--local" data-sb-blog-filter-mobile-backdrop aria-hidden="true"></div>
  </div>

  <div
    class="menu-drawer__backdrop menu-drawer__backdrop--local sb-blog-overview__interaction-overlay"
    data-sb-blog-filter-overlay
    aria-hidden="true"
  ></div>

</section>

{% stylesheet %}
  #header-group ~ .shopify-section[id*='template--']:has(> .sb-blog-top-sticky-accessory-bar),
  .shopify-section.shopify-section-group-header-group ~ .shopify-section[id*='template--']:has(> .sb-blog-top-sticky-accessory-bar),
  .shopify-section:has(> .header) ~ .shopify-section[id*='template--']:has(> .sb-blog-top-sticky-accessory-bar),
  .shopify-section:has(> .sb-blog-top-sticky-accessory-bar) {
    margin-top: 0 !important;
  }

  .shopify-section:has(> .sb-blog-top-sticky-accessory-bar) {
    position: sticky;
    top: 0;
    z-index: 49;
  }

  #header-group:has(#header-component[data-sticky-mode='always']) ~ .shopify-section[id*='template--']:has(> .sb-blog-top-sticky-accessory-bar),
  #header-group:has(#header-component[data-sticky-mode='scroll-up'][data-sticky-state='active'])
    ~ .shopify-section[id*='template--']:has(> .sb-blog-top-sticky-accessory-bar) {
    top: var(--sb-header-height);
  }

  .sb-blog-top-sticky-accessory-bar {
    --sb-drawer-animation-speed: 320ms;
    --sb-drawer-overlay-background: var(--sb-color-always-black-25);
    --sb-drawer-overlay-filter: brightness(0.75);
    --sb-menu-unroll-duration: 420ms;
    --sb-menu-unroll-ease: cubic-bezier(0.22, 1, 0.36, 1);
    --sb-menu-surface-shadow: 0 var(--sb-space-48) var(--sb-space-48) 0 var(--sb-color-always-black-25);
    display: block;
  }

  .sb-blog-overview__sticky-nav-wrap {
    display: none;
  }

  .sb-blog-overview__interaction-overlay {
    z-index: 0;
  }

  .sb-blog-overview__interaction-overlay.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  @media (min-width: 0px) {
    .sb-blog-overview__sticky-nav-wrap--desktop {
      display: block;
      width: 100%;
      padding-top: 16px;
    }

    .sb-blog-overview__sticky-nav-wrap--mobile {
      display: none !important;
    }

    .sb-blog-overview__sticky-nav-wrap--desktop,
    .sb-blog-overview__sticky-dropdown {
      position: relative;
      z-index: 1;
    }

    .sb-blog-overview__sticky-nav {
      --sb-blog-filter-popout-offset: 28px;
      align-items: center;
      background: var(--sb-color-neutral-200);
      border-radius: 24px;
      box-sizing: border-box;
      box-shadow: inset 0 0 0 1px var(--sb-color-neutral-600);
      column-gap: 12px;
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      min-height: 0;
      margin-inline: auto;
      max-width: 1240px;
      padding: 12px 24px;
      width: min(1240px, calc(100vw - 120px));
    }

    .sb-blog-overview__sticky-nav-left {
      align-items: center;
      display: flex;
      flex: 1 1 auto;
      flex-wrap: wrap;
      gap: 12px;
      min-width: 0;
    }

    .sb-blog-overview__sticky-filter {
      align-items: center;
      background: var(--sb-color-neutral-400);
      border: 0;
      border-radius: 12px;
      color: var(--sb-color-neutral-900);
      display: inline-flex;
      font-family: var(--font-primary--family);
      font-size: var(--font-size-caption);
      font-weight: 400;
      height: 36px;
      line-height: 1;
      padding: 0 12px;
      text-decoration: none;
      white-space: nowrap;
    }

    .sb-blog-overview__sticky-filter--dropdown {
      appearance: none;
      cursor: pointer;
      gap: 8px;
      justify-content: center;
    }

    .sb-blog-overview__sticky-dropdown {
      flex: 0 0 auto;
      position: relative;
    }

    .sb-blog-overview__sticky-filter-caret {
      align-items: center;
      display: inline-flex;
      height: 12px;
      justify-content: center;
      transform: rotate(90deg);
      transition: transform 220ms var(--sb-menu-unroll-ease);
      width: 12px;
    }

    .sb-blog-overview__sticky-filter-caret svg {
      display: block;
      height: 100%;
      width: 100%;
    }

    .sb-blog-overview__sticky-filter-caret svg [fill] {
      fill: currentColor;
    }

    .sb-blog-overview__sticky-dropdown[data-open='true'] .sb-blog-overview__sticky-filter-caret {
      transform: rotate(-90deg);
    }

    .sb-blog-overview__sticky-filter:focus-visible {
      background: var(--sb-color-neutral-600);
      color: var(--sb-color-neutral-900);
    }

    @media (hover: hover) and (pointer: fine) {
      .sb-blog-overview__sticky-filter:hover {
        background: var(--sb-color-neutral-600);
        color: var(--sb-color-neutral-900);
      }
    }

    .sb-blog-overview__sticky-filter.is-active {
      background: var(--sb-color-primary-500);
      color: var(--sb-color-always-white);
      font-weight: 600;
    }

    .sb-blog-overview__sticky-filter.is-active:focus-visible {
      background: var(--sb-color-primary-700);
      color: var(--sb-color-always-white);
    }

    @media (hover: hover) and (pointer: fine) {
      .sb-blog-overview__sticky-filter.is-active:hover {
        background: var(--sb-color-primary-700);
        color: var(--sb-color-always-white);
      }
    }

    .sb-blog-overview__sticky-filter-panel {
      align-items: start;
      border-radius: 24px;
      box-shadow: none;
      display: grid;
      grid-template-rows: 0fr;
      isolation: isolate;
      left: 0;
      max-width: calc(100vw - 32px);
      min-width: 0;
      overflow: hidden;
      pointer-events: none;
      position: absolute;
      top: calc(100% + var(--sb-blog-filter-popout-offset));
      transition: grid-template-rows var(--sb-menu-unroll-duration) var(--sb-menu-unroll-ease);
      width: max-content;
      z-index: 82;
    }

    .sb-blog-overview__sticky-filter-panel.is-active,
    .sb-blog-overview__sticky-dropdown[data-open='true'] .sb-blog-overview__sticky-filter-panel {
      box-shadow: var(--sb-menu-surface-shadow);
      grid-template-rows: 1fr;
      pointer-events: auto;
    }

    .sb-blog-overview__sticky-filter-panel.is-closing {
      box-shadow: var(--sb-menu-surface-shadow);
    }

    .sb-blog-overview__sticky-filter-panel-surface {
      align-self: start;
      background: var(--sb-color-neutral-200);
      border-radius: 24px;
      min-height: 0;
      max-width: 100%;
      overflow: hidden;
      width: max-content;
    }

    .sb-blog-overview__sticky-filter-panel-inner {
      display: flex;
      flex-direction: column;
      gap: 8px;
      padding: 20px;
      width: max-content;
    }

    .sb-blog-overview__sticky-filter-option {
      align-items: center;
      border-radius: 12px;
      color: var(--sb-color-neutral-900);
      display: inline-flex;
      font-family: var(--font-primary--family);
      font-size: var(--font-size-caption);
      font-weight: 400;
      height: 36px;
      line-height: 1;
      min-height: 0;
      padding: 0 12px;
      text-decoration: none;
      white-space: nowrap;
    }

    .sb-blog-overview__sticky-filter-option:hover,
    .sb-blog-overview__sticky-filter-option:focus-visible {
      background: var(--sb-color-neutral-400);
      color: var(--sb-color-neutral-900);
    }

    .sb-blog-overview__sticky-filter-option.is-active {
      background: var(--sb-color-primary-500);
      color: var(--sb-color-always-white);
      font-weight: 600;
    }

    .sb-blog-overview__sticky-filter-option.is-active:hover,
    .sb-blog-overview__sticky-filter-option.is-active:focus-visible {
      background: var(--sb-color-primary-700);
      color: var(--sb-color-always-white);
    }

    .sb-blog-overview__sticky-nav-shop-button {
      flex: 0 0 auto;
      margin-left: 0;
      justify-self: end;
      white-space: nowrap;
    }

  }

  .shopify-section:has(> .sb-blog-top-sticky-accessory-bar .sb-blog-overview__drawer-container.menu-open),
  .shopify-section:has(> .sb-blog-top-sticky-accessory-bar .sb-blog-overview__drawer-container.is-closing) {
    z-index: 110;
  }

  @media (max-width: 989px) {
    .shopify-section:has(> .sb-blog-top-sticky-accessory-bar) {
      height: auto;
    }

    .sb-blog-overview__sticky-nav-wrap--desktop {
      display: none !important;
    }

    .sb-blog-overview__sticky-nav-wrap--mobile {
      display: block !important;
      width: 100%;
      padding-top: var(--sb-space-16);
    }

    .sb-blog-overview__sticky-nav--mobile {
      --sb-blog-filter-popout-offset: 28px;
      align-items: center;
      background: var(--sb-color-neutral-200);
      border-radius: 24px;
      box-sizing: border-box;
      box-shadow: inset 0 0 0 1px var(--sb-color-neutral-600);
      column-gap: 16px;
      grid-template-columns: minmax(0, 1fr) auto;
      justify-items: start;
      min-height: 0;
      padding: 12px;
      width: 100%;
    }

    .sb-blog-overview__drawer-container {
      position: relative;
      z-index: 1;
    }

    .sb-blog-overview__interaction-overlay {
      display: none;
    }

    .sb-blog-overview__sticky-nav--mobile .sb-blog-overview__sticky-dropdown {
      min-width: 0;
      max-width: 100%;
    }

    .sb-blog-overview__sticky-filter--mobile {
      justify-content: flex-start;
      max-width: 100%;
      min-width: 0;
    }

    .sb-blog-overview__sticky-filter-label--mobile {
      flex: 1 1 auto;
      line-height: 1.2;
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .sb-blog-overview__sticky-filter-caret {
      align-items: center;
      display: inline-flex;
      height: 12px;
      justify-content: center;
      transform: none;
      transition: transform 220ms var(--sb-menu-unroll-ease);
      width: 12px;
    }

    .sb-blog-overview__sticky-filter-caret svg {
      display: block;
      height: 100%;
      width: 100%;
    }

    .sb-blog-overview__sticky-filter-caret svg [fill] {
      fill: currentColor;
    }

    .sb-blog-overview__sticky-nav--mobile .sb-blog-overview__sticky-dropdown[data-open='true'] .sb-blog-overview__sticky-filter-caret {
      transform: none;
    }

    .sb-blog-overview__sticky-nav-shop-button--mobile {
      justify-self: end;
      margin-left: 0;
      white-space: nowrap;
    }

    .sb-blog-overview__sticky-filter-option-children {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-left: 16px;
      width: calc(100% - 16px);
    }

    .sb-blog-overview__drawer-container {
      --sb-drawer-animation-speed: 320ms;
      --sb-drawer-overlay-background: var(--sb-color-always-black-25);
      --sb-drawer-overlay-filter: brightness(0.75);
    }

    .sb-blog-overview__sticky-filter-panel--mobile {
      border-radius: 0;
    }

    .sb-blog-overview__sticky-filter-panel--mobile .sb-blog-overview__sticky-filter-panel-surface {
      border-radius: 0;
      height: 100%;
      max-width: 100%;
      width: 100%;
    }

    .sb-blog-overview__sticky-filter-panel-inner--mobile {
      gap: 0;
      height: 100%;
      overflow-y: auto;
      padding: calc(20px + env(safe-area-inset-top, 0px)) 20px calc(20px + env(safe-area-inset-bottom, 0px));
      width: 100%;
    }

    .sb-blog-overview__sticky-filter-panel-header {
      align-items: flex-start;
      display: flex;
      flex-direction: column;
      gap: 20px;
      margin-bottom: 20px;
    }

    .sb-blog-overview__sticky-filter-close.menu-drawer__close-button {
      margin: 0;
    }

    .sb-blog-overview__sticky-filter-panel-title {
      color: var(--sb-color-neutral-900);
      margin: 0;
    }

    .sb-blog-overview__sticky-filter-panel-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
      width: 100%;
    }

    .sb-blog-overview__sticky-filter-panel-list .sb-blog-overview__sticky-filter-option {
      width: 100%;
    }

    .sb-blog-overview__sticky-filter-option--group {
      cursor: default;
      pointer-events: none;
    }

    .sb-blog-overview__sticky-filter-option--group:hover,
    .sb-blog-overview__sticky-filter-option--group:focus-visible {
      background: var(--sb-color-neutral-400);
      color: var(--sb-color-neutral-900);
    }

    .sb-blog-overview__sticky-filter-option--group.is-active {
      background: var(--sb-color-primary-500);
      color: var(--sb-color-always-white);
    }
  }

{% endstylesheet %}

<script>
  (() => {
    const root = document.getElementById('shopify-section-{{ section.id }}')?.querySelector('.sb-blog-top-sticky-accessory-bar');
    if (!root || root.dataset.blogTopAccessoryInit === 'true') return;
    root.dataset.blogTopAccessoryInit = 'true';
    const section = root.closest('.shopify-section');

    const blogFilterDropdowns = Array.from(root.querySelectorAll('[data-sb-blog-filter-dropdown]'));
    const interactionOverlay = root.querySelector('[data-sb-blog-filter-overlay]');
    const blogFilterMobileQuery = window.matchMedia('(max-width: 989px)');
    const desktopStickyNavWrap = root.querySelector('.sb-blog-overview__sticky-nav-wrap--desktop');
    const desktopStickyNav = desktopStickyNavWrap ? desktopStickyNavWrap.querySelector('.sb-blog-overview__sticky-nav') : null;
    let lastIsMobileViewport = blogFilterMobileQuery.matches;
    const blogDrawerOpenFrames = new WeakMap();
    if (!blogFilterDropdowns.length) return;

    const cancelBlogDrawerOpenFrame = (drawerContainer) => {
      if (!drawerContainer) return;
      const openFrame = blogDrawerOpenFrames.get(drawerContainer);
      if (!openFrame) return;
      window.cancelAnimationFrame(openFrame);
      blogDrawerOpenFrames.delete(drawerContainer);
    };

    const getDropdownPanel = (dropdown) => {
      if (!dropdown) return null;
      const trigger = dropdown.querySelector('[data-sb-blog-filter-trigger]');
      const panelId = trigger ? trigger.getAttribute('aria-controls') : '';
      if (panelId) {
        return root.querySelector(`#${CSS.escape(panelId)}`) || document.getElementById(panelId);
      }
      return dropdown.querySelector('[data-sb-blog-filter-panel]');
    };

    const getDropdownDrawerContainer = (dropdown) => {
      const panel = getDropdownPanel(dropdown);
      if (panel) {
        const drawerContainer = panel.closest('[data-sb-blog-filter-drawer-container]');
        if (drawerContainer) return drawerContainer;
      }
      return dropdown ? dropdown.querySelector('[data-sb-blog-filter-drawer-container]') : null;
    };

    const syncDesktopBlogFilterLayout = () => {
      const isMobileViewport = blogFilterMobileQuery.matches;

      if (isMobileViewport || !desktopStickyNavWrap || !desktopStickyNav) {
        blogFilterDropdowns.forEach((dropdown) => {
          const panel = getDropdownPanel(dropdown);
          if (!panel) return;
          panel.style.removeProperty('top');
        });
        return;
      }

      const stickyNavBottom = Math.min(window.innerHeight, Math.max(0, desktopStickyNav.getBoundingClientRect().bottom));

      blogFilterDropdowns.forEach((dropdown) => {
        const panel = getDropdownPanel(dropdown);
        if (!panel || panel.classList.contains('sb-blog-overview__sticky-filter-panel--mobile')) return;

        const dropdownRect = dropdown.getBoundingClientRect();
        const panelTop = Math.max(0, stickyNavBottom - dropdownRect.top + 16);
        panel.style.top = `${panelTop}px`;
      });
    };

    const closeBlogFilterDropdown = (dropdown, { returnFocus = false } = {}) => {
      if (!dropdown || dropdown.getAttribute('data-open') !== 'true') return;

      const trigger = dropdown.querySelector('[data-sb-blog-filter-trigger]');
      const panel = getDropdownPanel(dropdown);
      const drawerContainer = getDropdownDrawerContainer(dropdown);
      if (!trigger || !panel) return;

      trigger.setAttribute('aria-expanded', 'false');
      dropdown.removeAttribute('data-open');
      if (drawerContainer) {
        cancelBlogDrawerOpenFrame(drawerContainer);
        drawerContainer.classList.remove('menu-open');
        drawerContainer.classList.add('is-closing');
        window.clearTimeout(Number(drawerContainer.dataset.blogDrawerCloseTimer || 0));
        const closeTimer = window.setTimeout(() => {
          drawerContainer.classList.remove('is-closing');
          delete drawerContainer.dataset.blogDrawerCloseTimer;
          updateBlogFilterBackdropState();
        }, 360);
        drawerContainer.dataset.blogDrawerCloseTimer = String(closeTimer);
      } else {
        panel.classList.add('is-closing');
        panel.classList.remove('is-active');

        let closeSettled = false;
        const finalizeClose = (event) => {
          if (event && event.propertyName !== 'grid-template-rows' && event.propertyName !== 'transform') return;
          if (closeSettled || dropdown.getAttribute('data-open') === 'true') return;
          closeSettled = true;
          panel.removeEventListener('transitionend', finalizeClose);
          panel.classList.remove('is-closing');
          if (returnFocus) trigger.focus();
        };

        panel.addEventListener('transitionend', finalizeClose);
        window.setTimeout(finalizeClose, 620);
      }
      if (returnFocus && drawerContainer) trigger.focus();
    };

    const closeAllBlogFilterDropdowns = ({ except = null } = {}) => {
      blogFilterDropdowns.forEach((dropdown) => {
        if (dropdown === except) return;
        closeBlogFilterDropdown(dropdown);
      });
    };

    const updateBlogFilterBackdropState = () => {
      const hasOpenDropdown = blogFilterDropdowns.some((dropdown) => dropdown.getAttribute('data-open') === 'true');
      syncDesktopBlogFilterLayout();
      if (section) {
        section.style.zIndex = hasOpenDropdown ? '110' : '';
      }
      if (interactionOverlay) {
        interactionOverlay.classList.toggle('is-active', hasOpenDropdown && !blogFilterMobileQuery.matches);
      }
    };

    const openBlogFilterDropdown = (dropdown) => {
      if (!dropdown || dropdown.getAttribute('data-open') === 'true') return;

      const trigger = dropdown.querySelector('[data-sb-blog-filter-trigger]');
      const panel = getDropdownPanel(dropdown);
      const drawerContainer = getDropdownDrawerContainer(dropdown);
      if (!trigger || !panel) return;

      closeAllBlogFilterDropdowns({ except: dropdown });
      trigger.setAttribute('aria-expanded', 'true');
      dropdown.setAttribute('data-open', 'true');
      if (drawerContainer) {
        window.clearTimeout(Number(drawerContainer.dataset.blogDrawerCloseTimer || 0));
        cancelBlogDrawerOpenFrame(drawerContainer);
        drawerContainer.classList.remove('is-closing');
        drawerContainer.classList.remove('menu-open');
        const openFrame = window.requestAnimationFrame(() => {
          if (dropdown.getAttribute('data-open') !== 'true') return;
          drawerContainer.classList.add('menu-open');
          blogDrawerOpenFrames.delete(drawerContainer);
        });
        blogDrawerOpenFrames.set(drawerContainer, openFrame);
        delete drawerContainer.dataset.blogDrawerCloseTimer;
      } else {
        panel.classList.remove('is-closing');
        panel.classList.add('is-active');
      }
      updateBlogFilterBackdropState();
    };

    const handleBlogFilterDropdownDocumentClick = (event) => {
      const target = event.target;
      if (!(target instanceof Node)) return;
      const targetElement = target instanceof Element ? target : target.parentElement;
      if (
        targetElement
        && (
          targetElement.closest('[data-sb-blog-filter-panel]')
          || targetElement.closest('[data-sb-blog-filter-drawer-container]')
          || targetElement.closest('[data-sb-blog-filter-mobile-backdrop]')
        )
      ) {
        return;
      }
      if (blogFilterDropdowns.some((dropdown) => {
        if (dropdown.contains(target)) return true;
        const drawerContainer = getDropdownDrawerContainer(dropdown);
        return drawerContainer ? drawerContainer.contains(target) : false;
      })) return;
      closeAllBlogFilterDropdowns();
      updateBlogFilterBackdropState();
    };

    const handleBlogFilterDropdownKeyUp = (event) => {
      if (event.key !== 'Escape') return;
      const openDropdown = blogFilterDropdowns.find((dropdown) => dropdown.getAttribute('data-open') === 'true');
      if (!openDropdown) return;
      closeBlogFilterDropdown(openDropdown, { returnFocus: true });
      updateBlogFilterBackdropState();
    };

    blogFilterDropdowns.forEach((dropdown) => {
      const trigger = dropdown.querySelector('[data-sb-blog-filter-trigger]');
      const panel = getDropdownPanel(dropdown);
      const drawerContainer = getDropdownDrawerContainer(dropdown);
      if (!trigger || !panel) return;
      const closeButtons = Array.from(panel.querySelectorAll('[data-sb-blog-filter-close]'));

      dropdown.removeAttribute('data-open');
      panel.classList.remove('is-active');
      panel.classList.remove('is-closing');
      if (drawerContainer) {
        drawerContainer.classList.remove('menu-open');
        drawerContainer.classList.remove('is-closing');
      }
      trigger.setAttribute('aria-expanded', 'false');

      closeButtons.forEach((closeButton) => {
        closeButton.addEventListener('click', (event) => {
          event.preventDefault();
          event.stopPropagation();
          closeBlogFilterDropdown(dropdown, { returnFocus: true });
          updateBlogFilterBackdropState();
        });
      });

      trigger.addEventListener('click', (event) => {
        event.preventDefault();
        event.stopPropagation();
        if (dropdown.getAttribute('data-open') === 'true') {
          closeBlogFilterDropdown(dropdown);
          updateBlogFilterBackdropState();
          return;
        }
        openBlogFilterDropdown(dropdown);
      });
    });

    document.addEventListener('click', handleBlogFilterDropdownDocumentClick);
    document.addEventListener('keyup', handleBlogFilterDropdownKeyUp);
    document.addEventListener('sb:blog-filter:request-close', () => {
      closeAllBlogFilterDropdowns();
      updateBlogFilterBackdropState();
    });
    root.querySelectorAll('[data-sb-blog-filter-mobile-backdrop]').forEach((backdrop) => {
      backdrop.addEventListener('click', () => {
        closeAllBlogFilterDropdowns();
        updateBlogFilterBackdropState();
      });
    });
    if (interactionOverlay) {
      interactionOverlay.addEventListener('click', () => {
        closeAllBlogFilterDropdowns();
        updateBlogFilterBackdropState();
      });
      interactionOverlay.addEventListener('wheel', (event) => {
        event.preventDefault();
      }, { passive: false });
      interactionOverlay.addEventListener('touchmove', (event) => {
        event.preventDefault();
      }, { passive: false });
    }
    window.addEventListener('resize', () => {
      const isMobileViewport = blogFilterMobileQuery.matches;
      if (lastIsMobileViewport && !isMobileViewport) {
        document.body.classList.add('is-blog-filter-resize-closing');
        closeAllBlogFilterDropdowns();
        updateBlogFilterBackdropState();
        window.requestAnimationFrame(() => {
          document.body.classList.remove('is-blog-filter-resize-closing');
        });
      }
      lastIsMobileViewport = isMobileViewport;
      syncDesktopBlogFilterLayout();
    });
    window.addEventListener('scroll', syncDesktopBlogFilterLayout, { passive: true });
    updateBlogFilterBackdropState();
  })();
</script>

