<script>
  (() => {
    const root = document.getElementById('sb-manual-{{ section.id }}');
    if (!root || root.dataset.manualInit === 'true') return;
    root.dataset.manualInit = 'true';

    const mobileTopBar = root.querySelector('[data-manual-top-bar]');
    const mobileTopBarOrigin = mobileTopBar?.parentNode || null;
    let mobileTopBarHost = null;

    const links = [...root.querySelectorAll('[data-manual-link]')];
    const chapters = [...root.querySelectorAll('.sb-manual-chapters__chapter')];
    const sidebar = root.querySelector('.sb-manual-chapters__sidebar');
    const chapterDropdowns = Array.from(root.querySelectorAll('[data-manual-chapter-dropdown]'));
    const chapterCloseButtons = Array.from(root.querySelectorAll('[data-manual-chapter-close]'));
    const currentChapterLabels = Array.from(root.querySelectorAll('[data-manual-current-chapter-label]'));
    const chapterFallbackLabel = {{ 'sb.manual.chapter' | t | json }};
    const chaptersFallbackLabel = {{ 'sb.manual.chapters' | t | json }};
    if (!links.length || !chapters.length) return;

    const isMobileViewport = () => window.matchMedia('(max-width: 989px)').matches;
    let wasMobileViewport = isMobileViewport();

    const ensureMobileTopBarHost = () => {
      if (mobileTopBarHost && mobileTopBarHost.isConnected) return mobileTopBarHost;

      const firstTemplateSection = document.querySelector('.shopify-section[id*="template--"]');
      if (!firstTemplateSection) return null;
      const parent = firstTemplateSection.parentNode;
      if (!(parent instanceof Node)) return null;

      const host = document.createElement('div');
      host.className = 'shopify-section sb-manual-top-bar-host';
      parent.insertBefore(host, firstTemplateSection);
      mobileTopBarHost = host;
      return mobileTopBarHost;
    };

    const syncMobileTopBarPlacement = () => {
      if (!mobileTopBar || !mobileTopBarOrigin) return;

      if (!isMobileViewport()) {
        if (mobileTopBarHost) {
          if (mobileTopBarHost.parentNode) {
            mobileTopBarHost.parentNode.removeChild(mobileTopBarHost);
          }
          mobileTopBarHost = null;
        }
        if (mobileTopBar.parentNode !== mobileTopBarOrigin) {
          mobileTopBarOrigin.insertBefore(mobileTopBar, mobileTopBarOrigin.firstChild);
        }
        return;
      }

      const host = ensureMobileTopBarHost();
      if (!host) return;

      if (mobileTopBar.parentNode !== host) {
        host.insertBefore(mobileTopBar, host.firstChild);
      }
    };

    const chapterData = chapters.map((chapter) => {
      const heading = chapter.querySelector('.sb-manual-chapters__heading');
      const label = `${heading?.textContent || chapter.id || ''}`.trim() || chapterFallbackLabel;
      return { id: chapter.id, heading: heading || chapter, label };
    });

    const chapterLabelMap = new Map();
    links.forEach((link) => {
      const targetId = `${link.dataset.target || ''}`.trim();
      const label = `${link.dataset.manualLabel || link.textContent || ''}`.trim();
      if (!targetId || !label || chapterLabelMap.has(targetId)) return;
      chapterLabelMap.set(targetId, label);
    });
    if (!chapterLabelMap.size && chapterData[0]) {
      chapterLabelMap.set(chapterData[0].id, chapterData[0].label);
    }

    const setCurrentChapterLabel = (id) => {
      const nextLabel = chapterLabelMap.get(id) || chapterData[0]?.label || chaptersFallbackLabel;
      currentChapterLabels.forEach((labelNode) => {
        if (`${labelNode.textContent || ''}`.trim() === nextLabel) return;
        labelNode.textContent = nextLabel;
      });
    };

    const parseSpaceVar = (name, fallback) => {
      const rawValue = getComputedStyle(document.documentElement).getPropertyValue(name).trim();
      const parsed = Number.parseFloat(rawValue);
      return Number.isFinite(parsed) ? parsed : fallback;
    };

    const getHeadingOffset = () => parseSpaceVar('--sb-space-96', 96);

    const syncManualScrollTargetOffsetVar = () => {
      const headingOffset = getHeadingOffset();
      const nextOffset = Math.max(Math.round(headingOffset), 0);
      const nextOffsetValue = `${nextOffset}px`;
      if (root.style.getPropertyValue('--sb-manual-scroll-target-offset') !== nextOffsetValue) {
        root.style.setProperty('--sb-manual-scroll-target-offset', nextOffsetValue);
      }
    };

    let layoutTicking = false;
    const requestLayoutSync = () => {
      if (layoutTicking) return;
      layoutTicking = true;
      window.requestAnimationFrame(() => {
        syncManualScrollTargetOffsetVar();
        layoutTicking = false;
      });
    };

    const getStickyOffset = () => {
      const headingOffset = getHeadingOffset();
      if (isMobileViewport()) {
        return headingOffset;
      }

      if (!sidebar || window.getComputedStyle(sidebar).display === 'none') {
        return headingOffset;
      }

      const sidebarTop = Number.parseFloat(window.getComputedStyle(sidebar).top);
      if (Number.isFinite(sidebarTop)) return Math.max(sidebarTop + 8, headingOffset);
      return headingOffset;
    };

    const getScrollTargetOffset = () => {
      const headingOffset = getHeadingOffset();
      return Math.max(Math.round(headingOffset), headingOffset);
    };

    const setActive = (id) => {
      links.forEach((link) => {
        link.classList.toggle('is-active', link.dataset.target === id);
      });
      setCurrentChapterLabel(id);
    };

    const getActiveChapterId = () => {
      const viewportHeight = window.innerHeight || document.documentElement.clientHeight || 0;
      const stickyTriggerLine = getStickyOffset();
      const activationOffset = getScrollTargetOffset();
      const triggerLine = Math.min(
        Math.max(Math.round(activationOffset + 1), Math.round(stickyTriggerLine + 1), 1),
        Math.max(viewportHeight - 1, 1)
      );
      const pageY = window.scrollY || window.pageYOffset || 0;
      const triggerPageY = pageY + triggerLine;
      let current = chapterData[0].id;

      chapterData.forEach((chapter) => {
        const headingTop = chapter.heading.getBoundingClientRect().top + pageY;
        if (headingTop <= triggerPageY) current = chapter.id;
      });

      return current;
    };

    let ticking = false;
    const syncActive = () => {
      setActive(getActiveChapterId());
    };

    const requestSync = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(() => {
        syncActive();
        ticking = false;
      });
    };
    const findChapterById = (id) => chapterData.find((chapter) => chapter.id === id) || null;
    const navigateToChapter = (targetId, { updateHash = true } = {}) => {
      const nextId = `${targetId || ''}`.trim();
      if (!nextId) return;
      const chapter = findChapterById(nextId);
      if (!chapter) return;

      if (updateHash) {
        const nextHash = `#${nextId}`;
        if (window.location.hash !== nextHash) {
          window.history.pushState({}, '', `${window.location.pathname}${window.location.search}${nextHash}`);
        }
      }

      const currentY = window.scrollY || window.pageYOffset || 0;
      const targetTop = chapter.heading.getBoundingClientRect().top + currentY - getScrollTargetOffset();
      window.scrollTo({
        top: Math.max(Math.round(targetTop), 0),
        behavior: 'smooth',
      });

      requestSync();
      setActive(nextId);
    };

    const updateChapterBackdropState = () => {
      const isOpen = chapterDropdowns.some((dropdown) => dropdown.getAttribute('data-open') === 'true');
      chapterDropdowns.forEach((dropdown) => {
        const drawerContainer = dropdown.querySelector('[data-manual-drawer-container]');
        if (!drawerContainer) return;
        drawerContainer.classList.toggle('menu-open', dropdown.getAttribute('data-open') === 'true');
      });
      document.documentElement.classList.toggle('is-manual-chapter-open', isOpen);
      if (document.body) {
        document.body.classList.toggle('is-manual-chapter-open', isOpen);
      }
    };

    const closeChapterDropdown = (dropdown, { returnFocus = false } = {}) => {
      if (!dropdown || dropdown.getAttribute('data-open') !== 'true') return;
      const trigger = dropdown.querySelector('[data-manual-chapter-trigger]');
      const drawerContainer = dropdown.querySelector('[data-manual-drawer-container]');
      if (!trigger) return;

      trigger.setAttribute('aria-expanded', 'false');
      dropdown.removeAttribute('data-open');
      if (drawerContainer) {
        drawerContainer.classList.remove('menu-open');
        drawerContainer.classList.add('is-closing');
        window.clearTimeout(Number(drawerContainer.dataset.manualDrawerCloseTimer || 0));
        const closeTimer = window.setTimeout(() => {
          drawerContainer.classList.remove('is-closing');
          delete drawerContainer.dataset.manualDrawerCloseTimer;
          updateChapterBackdropState();
        }, 360);
        drawerContainer.dataset.manualDrawerCloseTimer = String(closeTimer);
      }
      updateChapterBackdropState();
      if (returnFocus) trigger.focus();
    };

    const closeAllChapterDropdowns = ({ exceptDropdown = null, returnFocus = false } = {}) => {
      chapterDropdowns.forEach((dropdown) => {
        if (exceptDropdown && dropdown === exceptDropdown) return;
        closeChapterDropdown(dropdown, { returnFocus });
      });
      updateChapterBackdropState();
    };

    const openChapterDropdown = (dropdown) => {
      if (!dropdown) return;
      const trigger = dropdown.querySelector('[data-manual-chapter-trigger]');
      const drawerContainer = dropdown.querySelector('[data-manual-drawer-container]');
      if (!trigger) return;

      closeAllChapterDropdowns({ exceptDropdown: dropdown });
      trigger.setAttribute('aria-expanded', 'true');
      dropdown.setAttribute('data-open', 'true');
      if (drawerContainer) {
        window.clearTimeout(Number(drawerContainer.dataset.manualDrawerCloseTimer || 0));
        drawerContainer.classList.remove('is-closing');
        drawerContainer.classList.add('menu-open');
        delete drawerContainer.dataset.manualDrawerCloseTimer;
      }
      updateChapterBackdropState();
    };

    chapterDropdowns.forEach((dropdown) => {
      const trigger = dropdown.querySelector('[data-manual-chapter-trigger]');
      if (!trigger) return;

      trigger.addEventListener('click', (event) => {
        event.preventDefault();
        const isOpen = dropdown.getAttribute('data-open') === 'true';
        if (isOpen) {
          closeChapterDropdown(dropdown, { returnFocus: false });
        } else {
          openChapterDropdown(dropdown);
        }
      });
    });

    chapterCloseButtons.forEach((button) => {
      button.addEventListener('click', () => {
        closeAllChapterDropdowns();
      });
    });

    root.querySelectorAll('[data-manual-chapter-backdrop]').forEach((backdrop) => {
      backdrop.addEventListener('click', () => {
        closeAllChapterDropdowns();
      });
    });

    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') return;
      closeAllChapterDropdowns({ returnFocus: true });
    });

    links.forEach((link) => {
      link.addEventListener('click', (event) => {
        if (
          event.defaultPrevented
          || event.button !== 0
          || event.metaKey
          || event.ctrlKey
          || event.shiftKey
          || event.altKey
        ) {
          return;
        }
        event.preventDefault();
        const targetId = `${link.dataset.target || link.getAttribute('href') || ''}`.replace(/^#/, '').trim();
        closeAllChapterDropdowns();
        navigateToChapter(targetId, { updateHash: true });
      });
    });

    root.querySelectorAll('[data-manual-accordion-trigger]').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const accordionItem = trigger.closest('.sb-manual-chapters__accordion');
        if (!accordionItem) return;

        const isOpening = !accordionItem.classList.contains('is-open');
        root.querySelectorAll('.sb-manual-chapters__accordion').forEach((item) => {
          item.classList.remove('is-open');
          const itemTrigger = item.querySelector('[data-manual-accordion-trigger]');
          if (itemTrigger) itemTrigger.setAttribute('aria-expanded', 'false');
        });

        if (isOpening) {
          accordionItem.classList.add('is-open');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });

    window.addEventListener(
      'scroll',
      () => {
        requestSync();
      },
      { passive: true }
    );
    window.addEventListener(
      'resize',
      () => {
        const nextIsMobileViewport = isMobileViewport();
        if (wasMobileViewport && !nextIsMobileViewport) {
          document.body.classList.add('is-manual-chapter-resize-closing');
          closeAllChapterDropdowns();
          window.requestAnimationFrame(() => {
            document.body.classList.remove('is-manual-chapter-resize-closing');
          });
        }
        wasMobileViewport = nextIsMobileViewport;
        syncMobileTopBarPlacement();
        requestLayoutSync();
        requestSync();
      },
      { passive: true }
    );
    window.addEventListener('hashchange', () => {
      syncMobileTopBarPlacement();
      requestLayoutSync();
      requestSync();
    });
    window.addEventListener('load', () => {
      syncMobileTopBarPlacement();
      requestLayoutSync();
      requestSync();
    });
    document.addEventListener('sb:cart-drawer:state-change', () => {
      requestLayoutSync();
      requestSync();
    });

    if (document.fonts && typeof document.fonts.ready === 'object') {
      document.fonts.ready.then(() => {
        syncMobileTopBarPlacement();
        requestLayoutSync();
      }).catch(() => {});
    }

    if (window.ResizeObserver) {
      const observer = new ResizeObserver(() => {
        requestLayoutSync();
        requestSync();
      });
      if (sidebar) observer.observe(sidebar);
    }
    syncMobileTopBarPlacement();
    requestLayoutSync();
    syncActive();
    window.setTimeout(syncActive, 120);
    window.setTimeout(syncActive, 360);
  })();
</script>

