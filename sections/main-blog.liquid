{% liquid
  assign posts_per_page = section.settings.posts_per_page | default: 12
  assign sidebar_blocks = section.blocks | where: 'type', 'sidebar_item'
  assign first_sidebar_block = sidebar_blocks[0]
  assign second_sidebar_block = sidebar_blocks[1]
%}

<section class="sb-blog-overview">
  <div class="sb-blog-overview__inner">
    {% if section.settings.show_blog_title %}
      <header class="sb-blog-overview__header">
        <h1 class="sb-blog-overview__title font-title weight-bold">{{ blog.title }}</h1>
      </header>
    {% endif %}

    {% paginate blog.articles by posts_per_page %}
      {% liquid
        assign show_featured_layout = false
        if paginate.current_page == 1
          assign show_featured_layout = true
        endif

        assign archive_offset = 0
        if show_featured_layout
          assign archive_offset = 9
        endif

        assign fallback_sidebar_article_one = blog.articles[0]
        assign fallback_sidebar_article_two = blog.articles[1]

        assign has_three_articles = false
        if blog.articles[2] != blank
          assign has_three_articles = true
        endif

        assign has_nine_articles = false
        if blog.articles[8] != blank
          assign has_nine_articles = true
        endif
      %}

      {% capture sidebar_card_one_markup %}
        {% if first_sidebar_block != blank %}
          {% render 'sb-blog-sidebar-card', block: first_sidebar_block %}
        {% elsif fallback_sidebar_article_one != blank %}
          {% render 'sb-blog-sidebar-card', fallback_article: fallback_sidebar_article_one %}
        {% endif %}
      {% endcapture %}

      {% capture sidebar_card_two_markup %}
        {% if second_sidebar_block != blank %}
          {% render 'sb-blog-sidebar-card', block: second_sidebar_block %}
        {% elsif fallback_sidebar_article_two != blank %}
          {% render 'sb-blog-sidebar-card', fallback_article: fallback_sidebar_article_two %}
        {% endif %}
      {% endcapture %}

      <div class="sb-blog-overview__layout">
        <div class="sb-blog-overview__main-column">
          {% if show_featured_layout %}
            <div class="sb-blog-overview__featured" aria-label="Featured articles">
              <div class="sb-blog-overview__row sb-blog-overview__row--feature">
                {% for article in blog.articles limit: 1 %}
                  {% render 'sb-blog-overview-article-card',
                    article: article,
                    blog_title: blog.title,
                    card_class: 'sb-blog-overview-card--feature',
                    show_excerpt: true
                  %}
                {% endfor %}
              </div>

              <div class="sb-blog-overview__row sb-blog-overview__row--half">
                {% for article in blog.articles limit: 2 offset: 1 %}
                  {% render 'sb-blog-overview-article-card',
                    article: article,
                    blog_title: blog.title,
                    card_class: 'sb-blog-overview-card--half',
                    show_excerpt: false
                  %}
                {% endfor %}
              </div>

              {% if sidebar_card_one_markup != blank and has_three_articles %}
                <div class="sb-blog-overview__mobile-insert" aria-label="{{ section.settings.sidebar_heading }}">
                  {{ sidebar_card_one_markup }}
                </div>
              {% endif %}

              <div class="sb-blog-overview__row sb-blog-overview__row--third">
                {% for article in blog.articles limit: 3 offset: 3 %}
                  {% render 'sb-blog-overview-article-card',
                    article: article,
                    blog_title: blog.title,
                    card_class: 'sb-blog-overview-card--third',
                    show_excerpt: false
                  %}
                {% endfor %}
              </div>

              <div class="sb-blog-overview__row sb-blog-overview__row--third">
                {% for article in blog.articles limit: 3 offset: 6 %}
                  {% render 'sb-blog-overview-article-card',
                    article: article,
                    blog_title: blog.title,
                    card_class: 'sb-blog-overview-card--third',
                    show_excerpt: false
                  %}
                {% endfor %}
              </div>

              {% if sidebar_card_two_markup != blank and has_nine_articles %}
                <div class="sb-blog-overview__mobile-insert" aria-label="{{ section.settings.sidebar_heading }}">
                  {{ sidebar_card_two_markup }}
                </div>
              {% endif %}
            </div>
          {% endif %}

          <div class="sb-blog-overview__archive" aria-label="Archive">
            {% if section.settings.archive_heading != blank %}
              <h2 class="sb-blog-overview__archive-title font-title weight-bold">{{ section.settings.archive_heading }}</h2>
            {% endif %}

            <div class="sb-blog-overview__archive-list">
              {% for article in blog.articles offset: archive_offset %}
                {% render 'sb-blog-overview-article-card',
                  article: article,
                  blog_title: blog.title,
                  card_class: 'sb-blog-overview-card--archive',
                  show_excerpt: false
                %}
              {% endfor %}
            </div>
          </div>

          {% if paginate.pages > 1 %}
            <nav class="sb-blog-overview__pagination font-caption weight-regular" aria-label="Pagination">
              {{ paginate | default_pagination }}
            </nav>
          {% endif %}
        </div>

        <aside class="sb-blog-overview__sidebar" aria-label="{{ section.settings.sidebar_heading }}">
          <div class="sb-blog-overview__sidebar-stack" data-sb-blog-sticky-stack>
            {% if section.settings.sidebar_heading != blank %}
              <h3 class="sb-blog-overview__sidebar-heading font-callout weight-semibold" data-sb-sidebar-sticky-card>
                {{ section.settings.sidebar_heading }}
              </h3>
            {% endif %}

            {% if sidebar_card_one_markup != blank %}
              <div class="sb-blog-overview__sidebar-card-wrap" data-sb-sidebar-sticky-card>
                {{ sidebar_card_one_markup }}
              </div>
            {% endif %}

            {% if sidebar_card_two_markup != blank %}
              <div class="sb-blog-overview__sidebar-card-wrap" data-sb-sidebar-sticky-card>
                {{ sidebar_card_two_markup }}
              </div>
            {% endif %}
          </div>
        </aside>
      </div>
    {% endpaginate %}
  </div>
</section>

{% stylesheet %}
  .sb-blog-overview {
    padding: var(--sb-space-96) 0;
  }

  .sb-blog-overview__inner {
    margin: 0 auto;
    width: min(
      calc((var(--sb-space-128) * 9) + var(--sb-space-64) + var(--sb-space-24)),
      calc(100% - (var(--page-margin) * 2))
    );
  }

  .sb-blog-overview__header {
    margin-bottom: var(--sb-space-48);
  }

  .sb-blog-overview__title {
    color: var(--sb-color-neutral-900);
    margin: 0;
  }

  .sb-blog-overview__layout {
    align-items: start;
    column-gap: var(--sb-space-64);
    display: grid;
    grid-template-columns: calc((var(--sb-space-128) * 6) + var(--sb-space-32)) minmax(0, 1fr);
  }

  .sb-blog-overview__main-column {
    min-width: 0;
  }

  .sb-blog-overview__featured {
    display: flex;
    flex-direction: column;
    gap: var(--sb-space-30);
  }

  .sb-blog-overview__row {
    min-width: 0;
  }

  .sb-blog-overview__row--half,
  .sb-blog-overview__row--third {
    column-gap: var(--sb-space-30);
    display: grid;
  }

  .sb-blog-overview__row--half {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .sb-blog-overview__row--third {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .sb-blog-overview-card {
    background: var(--sb-color-neutral-200);
    border-radius: var(--sb-space-24);
    display: flex;
    flex-direction: column;
    min-width: 0;
    overflow: hidden;
  }

  .sb-blog-overview-card__media {
    background: var(--sb-color-neutral-400);
    display: block;
    overflow: hidden;
  }

  .sb-blog-overview-card__image {
    display: block;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .sb-blog-overview-card__image--placeholder {
    background: var(--sb-color-neutral-300);
  }

  .sb-blog-overview-card__content {
    display: flex;
    flex: 1 0 auto;
    flex-direction: column;
    gap: var(--sb-space-12);
    padding: var(--sb-space-24);
  }

  .sb-blog-overview-card__category,
  .sb-blog-overview-card__date {
    color: var(--sb-color-neutral-800);
    margin: 0;
  }

  .sb-blog-overview-card__title {
    margin: 0;
  }

  .sb-blog-overview-card__title a {
    color: var(--sb-color-neutral-900);
    text-decoration: none;
  }

  .sb-blog-overview-card__title a:hover,
  .sb-blog-overview-card__title a:focus-visible {
    color: var(--sb-color-primary-500);
  }

  .sb-blog-overview-card__excerpt {
    color: var(--sb-color-neutral-800);
    margin: 0;
  }

  .sb-blog-overview-card--feature .sb-blog-overview-card__media {
    aspect-ratio: 20 / 9;
  }

  .sb-blog-overview-card--half .sb-blog-overview-card__media,
  .sb-blog-overview-card--third .sb-blog-overview-card__media {
    aspect-ratio: 16 / 9;
  }

  .sb-blog-overview__archive {
    margin-top: var(--sb-space-96);
  }

  .sb-blog-overview__archive-title {
    color: var(--sb-color-neutral-900);
    margin: 0 0 var(--sb-space-30);
  }

  .sb-blog-overview__archive-list {
    display: flex;
    flex-direction: column;
  }

  .sb-blog-overview-card--archive {
    background: transparent;
    border-radius: 0;
    border-bottom: 1px solid var(--sb-color-neutral-600);
    column-gap: var(--sb-space-24);
    display: grid;
    grid-template-columns: calc((var(--sb-space-128) * 2) + var(--sb-space-12)) minmax(0, 1fr);
    margin: 0;
    padding: 0 0 var(--sb-space-24);
  }

  .sb-blog-overview-card--archive + .sb-blog-overview-card--archive {
    margin-top: var(--sb-space-24);
  }

  .sb-blog-overview-card--archive .sb-blog-overview-card__media {
    aspect-ratio: 16 / 9;
    border-radius: var(--sb-space-12);
  }

  .sb-blog-overview-card--archive .sb-blog-overview-card__content {
    padding: 0;
  }

  .sb-blog-overview__sidebar {
    min-width: 0;
  }

  .sb-blog-overview__sidebar-stack {
    display: flex;
    flex-direction: column;
    gap: var(--sb-space-32);
  }

  .sb-blog-overview__sidebar-heading,
  .sb-blog-overview__sidebar-card-wrap {
    position: sticky;
  }

  .sb-blog-overview__sidebar-heading {
    color: var(--sb-color-neutral-900);
    margin: 0;
  }

  .sb-blog-overview__sidebar-card-wrap .sb-blog-sidebar-card {
    background: var(--sb-color-neutral-200);
    border-radius: var(--sb-space-24);
    display: flex;
    flex-direction: column;
    gap: 0;
    overflow: hidden;
  }

  .sb-blog-overview__sidebar-card-wrap .sb-blog-sidebar-card__media {
    border-radius: 0;
    max-height: calc(var(--sb-space-128) + var(--sb-space-64));
  }

  .sb-blog-overview__sidebar-card-wrap .sb-blog-sidebar-card__image {
    aspect-ratio: 16 / 9;
  }

  .sb-blog-overview__sidebar-card-wrap .sb-blog-sidebar-card__content {
    gap: var(--sb-space-12);
    padding: var(--sb-space-24);
  }

  .sb-blog-overview .sb-blog-sidebar-card__title {
    color: var(--sb-color-neutral-900);
    margin: 0;
    text-decoration: none;
  }

  .sb-blog-overview .sb-blog-sidebar-card__title:hover,
  .sb-blog-overview .sb-blog-sidebar-card__title:focus-visible {
    color: var(--sb-color-primary-500);
  }

  .sb-blog-overview .sb-blog-sidebar-card__meta,
  .sb-blog-overview .sb-blog-sidebar-card__text {
    color: var(--sb-color-neutral-800);
    margin: 0;
  }

  .sb-blog-overview__mobile-insert {
    display: none;
  }

  .sb-blog-overview__mobile-insert .sb-blog-sidebar-card {
    background: var(--sb-color-neutral-200);
    border-radius: var(--sb-space-24);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .sb-blog-overview__mobile-insert .sb-blog-sidebar-card__media {
    border-radius: 0;
  }

  .sb-blog-overview__mobile-insert .sb-blog-sidebar-card__image {
    aspect-ratio: 16 / 9;
  }

  .sb-blog-overview__mobile-insert .sb-blog-sidebar-card__content {
    gap: var(--sb-space-12);
    padding: var(--sb-space-24);
  }

  .sb-blog-overview__pagination {
    margin-top: var(--sb-space-48);
  }

  .sb-blog-overview__pagination .pagination {
    align-items: center;
    display: flex;
    gap: var(--sb-space-8);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media screen and (max-width: 989px) {
    .sb-blog-overview {
      padding: var(--sb-space-48) 0;
    }

    .sb-blog-overview__header {
      margin-bottom: var(--sb-space-30);
    }

    .sb-blog-overview__layout {
      display: block;
    }

    .sb-blog-overview__featured {
      gap: 0;
    }

    .sb-blog-overview__row--half,
    .sb-blog-overview__row--third {
      display: block;
    }

    .sb-blog-overview-card {
      margin-bottom: var(--sb-space-24);
    }

    .sb-blog-overview-card--archive {
      background: var(--sb-color-neutral-200);
      border-radius: var(--sb-space-24);
      border-bottom: 0;
      display: flex;
      margin: 0 0 var(--sb-space-24);
      overflow: hidden;
      padding: 0;
    }

    .sb-blog-overview-card--archive .sb-blog-overview-card__media {
      aspect-ratio: 16 / 9;
      border-radius: 0;
    }

    .sb-blog-overview-card--archive .sb-blog-overview-card__content {
      padding: var(--sb-space-24);
    }

    .sb-blog-overview__archive {
      margin-top: var(--sb-space-48);
    }

    .sb-blog-overview__archive-title {
      margin-bottom: var(--sb-space-24);
    }

    .sb-blog-overview__sidebar {
      display: none;
    }

    .sb-blog-overview__mobile-insert {
      display: block;
      margin-bottom: var(--sb-space-24);
    }
  }
{% endstylesheet %}

{% javascript %}
  (() => {
    const stacks = Array.from(document.querySelectorAll('[data-sb-blog-sticky-stack]'));
    if (!stacks.length) return;

    const parseSpaceVar = (name, fallback) => {
      const rawValue = getComputedStyle(document.documentElement).getPropertyValue(name).trim();
      const parsed = Number.parseFloat(rawValue);
      return Number.isFinite(parsed) ? parsed : fallback;
    };

    const applyStickyOffsets = () => {
      const baseTop = parseSpaceVar('--sb-space-96', 96);
      const gap = parseSpaceVar('--sb-space-32', 32);

      stacks.forEach((stack) => {
        const cards = Array.from(stack.querySelectorAll('[data-sb-sidebar-sticky-card]'));
        let currentTop = baseTop;

        cards.forEach((card) => {
          card.style.top = `${currentTop}px`;
          currentTop += card.offsetHeight + gap;
        });
      });
    };

    window.addEventListener('resize', applyStickyOffsets);
    window.addEventListener('load', applyStickyOffsets);

    applyStickyOffsets();
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Main blog",
  "max_blocks": 2,
  "settings": [
    {
      "type": "checkbox",
      "id": "show_blog_title",
      "label": "Show blog title",
      "default": true
    },
    {
      "type": "range",
      "id": "posts_per_page",
      "label": "Posts per page",
      "min": 9,
      "max": 24,
      "step": 1,
      "default": 18
    },
    {
      "type": "text",
      "id": "archive_heading",
      "label": "Archive heading",
      "default": "Archive"
    },
    {
      "type": "text",
      "id": "sidebar_heading",
      "label": "Sidebar heading",
      "default": "Top articles and product picks"
    }
  ],
  "blocks": [
    {
      "type": "sidebar_item",
      "name": "Sidebar item",
      "settings": [
        {
          "type": "select",
          "id": "content_type",
          "label": "Content type",
          "default": "article",
          "options": [
            {
              "value": "article",
              "label": "Article"
            },
            {
              "value": "product",
              "label": "Product"
            },
            {
              "value": "custom",
              "label": "Custom link"
            }
          ]
        },
        {
          "type": "article",
          "id": "article",
          "label": "Article"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom title"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Custom URL"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image",
          "info": "Target minimum 752x423 at 2x export (376x212)."
        },
        {
          "type": "text",
          "id": "description",
          "label": "Custom description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Main blog",
      "blocks": [
        {
          "type": "sidebar_item"
        },
        {
          "type": "sidebar_item"
        }
      ]
    }
  ]
}
{% endschema %}
