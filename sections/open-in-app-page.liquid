{% liquid
  assign open_in_app_button_label = 'sb.common.continue' | t
%}

<section class="sb-open-in-app-page">
  <div class="sb-open-in-app-page__content" data-open-in-app-root data-sb-motion="reveal">
    <div class="sb-open-in-app-page__deep-link-group" data-open-in-app-deep-link-group data-sb-motion-item hidden>
      <p class="sb-open-in-app-page__body font-body weight-regular">
        {{ 'sb.app.open_in_app_intro' | t }}<br>
        <a
          class="sb-open-in-app-page__link"
          data-open-in-app-link
          href="#"
        >
          &nbsp;
        </a>
      </p>

      <div class="sb-open-in-app-page__button-wrap">
        {% render 'radiant-button',
          label: open_in_app_button_label,
          link: '#',
          size: 'large',
          icon_position: 'none'
        %}
      </div>
    </div>
  </div>

  <script>
    (() => {
      const sectionRoot = document.currentScript?.closest('.sb-open-in-app-page');
      if (!(sectionRoot instanceof HTMLElement)) return;

      const deepLinkGroup = sectionRoot.querySelector('[data-open-in-app-deep-link-group]');
      const deepLinkElement = sectionRoot.querySelector('[data-open-in-app-link]');
      const openLinkButton = sectionRoot.querySelector('.sb-open-in-app-page__button-wrap .sb-button-radiant');

      if (!(deepLinkElement instanceof HTMLAnchorElement) || !(openLinkButton instanceof HTMLAnchorElement)) {
        return;
      }

      const requestedTarget = new URLSearchParams(window.location.search).get('target');
      const sanitizedTarget = requestedTarget ? requestedTarget.trim().replace(/^\/+|\/+$/g, '') : '';
      const resolvedDeepLinkUrl = sanitizedTarget ? `https://app.soundbrenner.com/${sanitizedTarget}` : '';
      const hasValidDeepLink = !!resolvedDeepLinkUrl;

      if (deepLinkGroup instanceof HTMLElement) {
        deepLinkGroup.hidden = !hasValidDeepLink;
      }

      if (!hasValidDeepLink) return;

      deepLinkElement.textContent = resolvedDeepLinkUrl;
      deepLinkElement.href = resolvedDeepLinkUrl;
      openLinkButton.href = resolvedDeepLinkUrl;
    })();
  </script>
</section>

{% stylesheet %}
  .sb-open-in-app-page {
    padding: 0;
  }

  .shopify-section[id*='template--']:has(> .sb-open-in-app-page),
  .shopify-section[id*='template--']:has(> .sb-open-in-app-page) + .shopify-section[id*='template--'] {
    margin-top: 48px !important;
  }

  .sb-open-in-app-page__body {
    color: var(--sb-color-neutral-900);
    margin: 0;
  }

  .sb-open-in-app-page__content {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .sb-open-in-app-page__deep-link-group {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .sb-open-in-app-page__deep-link-group[hidden] {
    display: none !important;
  }

  .sb-open-in-app-page__link {
    color: var(--sb-color-primary-500);
    overflow-wrap: anywhere;
    text-decoration: none;
  }

  .sb-open-in-app-page__link:focus-visible,
  .sb-open-in-app-page__link:active {
    color: var(--sb-color-primary-500);
    text-decoration: underline;
  }

  @media (hover: hover) and (pointer: fine) {
    .sb-open-in-app-page__link:hover {
      color: var(--sb-color-primary-500);
      text-decoration: underline;
    }
  }

  .sb-open-in-app-page__button-wrap {
    width: fit-content;
  }

  @media screen and (max-width: 749px) {
    .sb-open-in-app-page__button-wrap {
      width: 100%;
    }

    .sb-open-in-app-page__button-wrap .sb-button-radiant {
      justify-content: center;
      width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Open in app page",
  "settings": [],
  "presets": [
    {
      "name": "Open in app page"
    }
  ]
}
{% endschema %}
