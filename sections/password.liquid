<section class="sb-password-hero">
  <div class="sb-password-hero__inner">
    <a class="sb-password-hero__brand" href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }}">
      {% if settings.logo %}
        {{
          settings.logo
          | image_url: width: 360
          | image_tag:
            class: 'sb-password-hero__logo',
            alt: shop.name,
            loading: 'eager'
        }}
      {% else %}
        <span class="sb-password-hero__wordmark" aria-hidden="true">
          {{ 'logo-soundbrenner-wordmark.svg' | inline_asset_content }}
        </span>
        <span class="visually-hidden">{{ shop.name }}</span>
      {% endif %}
    </a>

    <h1 class="sb-password-hero__title">{{ 'password.title' | t }}</h1>

    {% if shop.password_message != blank %}
      <div class="sb-password-hero__message">{{ shop.password_message }}</div>
    {% else %}
      <p class="sb-password-hero__message">{{ 'sb.password.message_fallback' | t }}</p>
    {% endif %}

    <div class="sb-password-hero__actions">
      <button
        type="button"
        class="sb-password-button"
        data-password-dialog-open
        aria-controls="PasswordDialog"
      >
        {{ 'sb.password.enter_using_password' | t }}
      </button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:general.password",
  "settings": []
}
{% endschema %}
