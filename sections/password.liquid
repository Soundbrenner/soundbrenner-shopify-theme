<section class="sb-password-hero">
  <div class="sb-password-hero__inner">
    {% if settings.logo %}
      <a class="sb-password-hero__brand" href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }}">
        {{
          settings.logo
          | image_url: width: 128
          | image_tag:
            class: 'sb-password-hero__logo',
            alt: shop.name,
            loading: 'eager'
        }}
      </a>
    {% endif %}

    <h1 class="sb-password-hero__title">{{ 'sb.password.page_title' | t }}</h1>

    <div class="sb-password-hero__actions">
      {% render 'radiant-button',
        label: 'sb.password.enter_using_password' | t,
        size: 'large',
        extra_class: 'sb-password-button sb-password-button--enter font-caption weight-bold'
      %}

      {% render 'radiant-button',
        label: 'sb.password.log_in_here' | t,
        link: '/admin',
        size: 'large',
        extra_class: 'sb-password-button sb-password-button--login font-caption weight-bold'
      %}
    </div>
  </div>
</section>

{% stylesheet %}
  .sb-password-hero {
    align-items: center;
    display: flex;
    justify-content: center;
    margin: 0 auto;
    min-height: 100%;
    text-align: center;
    width: 100%;
  }

  .sb-password-hero__inner {
    align-items: center;
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: 100%;
  }

  .sb-password-hero__brand {
    color: inherit;
    display: inline-flex;
    margin-bottom: var(--sb-space-48);
    text-decoration: none;
  }

  .sb-password-hero__brand:focus-visible,
  .sb-password-button:focus-visible {
    outline: 2px solid var(--sb-color-primary-500);
    outline-offset: 4px;
  }

  .sb-password-hero__logo {
    display: block;
    height: var(--sb-space-64);
    margin: 0 auto;
    object-fit: contain;
    width: auto;
  }

  .sb-password-hero__title {
    font-family: var(--font-display--family);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: var(--font-title-line-height);
    margin: 0 0 var(--sb-space-48);
  }

  .sb-password-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    justify-content: center;
    width: 100%;
  }

  .sb-password-button {
    box-sizing: border-box;
    max-width: 400px;
    width: 100%;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.password",
  "settings": []
}
{% endschema %}
