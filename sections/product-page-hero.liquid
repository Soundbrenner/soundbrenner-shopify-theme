    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "visible_if": "{{ section.settings.use_resource_title_description == false }}"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline",
      "default": "Tagline",
      "visible_if": "{{ section.settings.use_resource_title_description == false }}"
    },
    {
