{% liquid
  assign hide_section = false
  assign hero_header_ref = blank
  assign hero_header = blank
  assign hero_media_title = blank
  assign hero_video_desktop_url = blank
  assign hero_video_mobile_url = blank
  assign hero_video_embed_url = blank
  assign hero_video_mobile_embed_url = blank
  assign hero_video_embed_provider = blank
  assign hero_video_mobile_embed_provider = blank
  assign hero_has_youtube_embed = false
  assign hero_has_vimeo_embed = false
  assign hero_use_iframe_video = false
  assign hero_mobile_use_iframe_video = false
  assign hero_media_desktop_field = blank
  assign hero_media_mobile_field = blank
  assign hero_image_desktop_field = blank
  assign hero_image_mobile_field = blank
  assign hero_media_desktop_width = 1240
  assign hero_media_desktop_height = 600
  assign hero_media_mobile_width = 402
  assign hero_media_mobile_height = 369
  assign hero_has_video = false
  assign hero_image_desktop_url = blank
  assign hero_image_mobile_url = blank
  assign hero_product_tagline = blank
  assign hero_product_tagline_html = blank
  assign hero_manual_mode = false
  assign hero_display_kicker = blank
  assign hero_display_title = blank
  assign hero_display_tagline = blank
  assign hero_display_chip = blank
  assign hero_display_subheadline = blank
  assign hero_tagline_font_class = 'font-hero-large'
  assign hero_selected_variant = blank
  assign hero_has_compare_price = false
  assign hero_has_linked_videos = false
  assign hero_video_anchor_link = blank
  assign hero_show_price = false
  assign hero_show_button = false
  assign hero_button_label = blank
  assign hero_button_link = blank

  if request.page_type != 'product' or product == blank
    assign hero_manual_mode = true
    assign hero_media_title = section.settings.title
    assign hero_display_kicker = section.settings.kicker
    assign hero_display_title = section.settings.title
    assign hero_display_tagline = section.settings.tagline
    assign hero_display_chip = section.settings.chip_text | strip
    assign hero_display_subheadline = section.settings.subheadline
    assign hero_media_desktop_field = section.settings.media
    assign hero_media_mobile_field = section.settings.media_mobile
    assign hero_show_button = section.settings.show_button
    assign hero_button_label = section.settings.button_label
    assign hero_button_link = section.settings.button_link

    if section.settings.use_resource_title_description and page != blank
      assign hero_media_title = page.title
      assign hero_display_title = page.title
      assign hero_display_tagline = page.content | strip_html
    endif
  else
    assign hero_header_ref = product.metafields.custom.sbv2_product_page_header
    assign hero_header = hero_header_ref.value | default: hero_header_ref.reference.value | default: hero_header_ref.reference | default: hero_header_ref
    if hero_header == blank
      assign hide_section = true
    endif
  endif

  if hide_section == false
    if section.settings.use_smaller_tagline_font
      assign hero_tagline_font_class = 'font-hero'
    endif

    if hero_manual_mode
      assign hero_video_anchor_link = section.settings.button_link
    else
      assign hero_video_anchor_link = '#sb-hero-video-product-' | append: product.id
    endif

    unless hero_manual_mode
      assign hero_media_title = product.title

      assign hero_media_desktop_field = hero_header.media.value | default: hero_header.media
      assign hero_media_mobile_field = hero_header.media_mobile.value | default: hero_header.media_mobile
    endunless

    assign hero_media_desktop_type = hero_media_desktop_field.media_type | append: ''
    assign hero_media_mobile_type = hero_media_mobile_field.media_type | append: ''

    assign hero_video_desktop_field = blank
    assign hero_video_mobile_field = blank

    if hero_media_desktop_field != blank
      if hero_media_desktop_type contains 'video'
        assign hero_video_desktop_field = hero_media_desktop_field
      elsif hero_media_desktop_type == 'image'
        assign hero_image_desktop_field = hero_media_desktop_field
      endif
    endif

    if hero_media_mobile_field != blank
      if hero_media_mobile_type contains 'video'
        assign hero_video_mobile_field = hero_media_mobile_field
      elsif hero_media_mobile_type == 'image'
        assign hero_image_mobile_field = hero_media_mobile_field
      endif
    endif

    if hero_video_desktop_field != blank
      if hero_video_desktop_field.sources != blank
        for hero_video_source in hero_video_desktop_field.sources
          assign hero_video_source_url = hero_video_source.url | default: hero_video_source.src
          assign hero_video_source_format = hero_video_source.format | downcase
          assign hero_video_source_mime = hero_video_source.mime_type | downcase

          if hero_video_source_url != blank
            if hero_video_source_format contains 'mp4' or hero_video_source_mime contains 'mp4'
              assign hero_video_desktop_url = hero_video_source_url
              break
            endif
            if hero_video_desktop_url == blank
              assign hero_video_desktop_url = hero_video_source_url
            endif
          endif
        endfor
      endif
      if hero_video_desktop_url == blank
        assign hero_video_desktop_url = hero_video_desktop_field.url | default: hero_video_desktop_field.src | default: hero_video_desktop_field
      endif
    endif

    if hero_video_mobile_field != blank
      if hero_video_mobile_field.sources != blank
        for hero_video_mobile_source in hero_video_mobile_field.sources
          assign hero_video_mobile_source_url = hero_video_mobile_source.url | default: hero_video_mobile_source.src
          assign hero_video_mobile_source_format = hero_video_mobile_source.format | downcase
          assign hero_video_mobile_source_mime = hero_video_mobile_source.mime_type | downcase

          if hero_video_mobile_source_url != blank
            if hero_video_mobile_source_format contains 'mp4' or hero_video_mobile_source_mime contains 'mp4'
              assign hero_video_mobile_url = hero_video_mobile_source_url
              break
            endif
            if hero_video_mobile_url == blank
              assign hero_video_mobile_url = hero_video_mobile_source_url
            endif
          endif
        endfor
      endif
      if hero_video_mobile_url == blank
        assign hero_video_mobile_url = hero_video_mobile_field.url | default: hero_video_mobile_field.src | default: hero_video_mobile_field
      endif
    endif

    assign hero_video_desktop_url = hero_video_desktop_url | append: '' | strip
    assign hero_video_mobile_url = hero_video_mobile_url | append: '' | strip

    if hero_video_desktop_url == blank and hero_video_mobile_url != blank
      assign hero_video_desktop_url = hero_video_mobile_url
    endif
    if hero_video_mobile_url == blank and hero_video_desktop_url != blank
      assign hero_video_mobile_url = hero_video_desktop_url
    endif

    if hero_video_desktop_url != blank
      assign hero_has_video = true
      assign hero_video_desktop_downcase = hero_video_desktop_url | downcase

      if hero_video_desktop_downcase contains 'youtube.com/watch'
        assign hero_youtube_id = hero_video_desktop_url | split: 'v=' | last | split: '&' | first
        assign hero_youtube_id = hero_youtube_id | split: '?' | first | split: '&' | first | split: '/' | last
        if hero_youtube_id != blank
          assign hero_video_embed_url = 'https://www.youtube.com/embed/' | append: hero_youtube_id
          assign hero_video_embed_provider = 'youtube'
          assign hero_use_iframe_video = true
        endif
      elsif hero_video_desktop_downcase contains 'youtu.be/'
        assign hero_youtube_id = hero_video_desktop_url | split: 'youtu.be/' | last | split: '?' | first | split: '&' | first
        assign hero_youtube_id = hero_youtube_id | split: '?' | first | split: '&' | first | split: '/' | last
        if hero_youtube_id != blank
          assign hero_video_embed_url = 'https://www.youtube.com/embed/' | append: hero_youtube_id
          assign hero_video_embed_provider = 'youtube'
          assign hero_use_iframe_video = true
        endif
      elsif hero_video_desktop_downcase contains 'vimeo.com/'
        assign hero_vimeo_id = hero_video_desktop_url | split: 'vimeo.com/' | last | split: '?' | first | split: '&' | first | split: '/' | first
        if hero_vimeo_id != blank
          assign hero_video_embed_url = 'https://player.vimeo.com/video/' | append: hero_vimeo_id
          assign hero_video_embed_provider = 'vimeo'
          assign hero_use_iframe_video = true
        endif
      endif
    endif

    if hero_video_mobile_url != blank
      assign hero_has_video = true
      assign hero_video_mobile_downcase = hero_video_mobile_url | downcase

      if hero_video_mobile_downcase contains 'youtube.com/watch'
        assign hero_mobile_youtube_id = hero_video_mobile_url | split: 'v=' | last | split: '&' | first
        assign hero_mobile_youtube_id = hero_mobile_youtube_id | split: '?' | first | split: '&' | first | split: '/' | last
        if hero_mobile_youtube_id != blank
          assign hero_video_mobile_embed_url = 'https://www.youtube.com/embed/' | append: hero_mobile_youtube_id
          assign hero_video_mobile_embed_provider = 'youtube'
          assign hero_mobile_use_iframe_video = true
        endif
      elsif hero_video_mobile_downcase contains 'youtu.be/'
        assign hero_mobile_youtube_id = hero_video_mobile_url | split: 'youtu.be/' | last | split: '?' | first | split: '&' | first
        assign hero_mobile_youtube_id = hero_mobile_youtube_id | split: '?' | first | split: '&' | first | split: '/' | last
        if hero_mobile_youtube_id != blank
          assign hero_video_mobile_embed_url = 'https://www.youtube.com/embed/' | append: hero_mobile_youtube_id
          assign hero_video_mobile_embed_provider = 'youtube'
          assign hero_mobile_use_iframe_video = true
        endif
      elsif hero_video_mobile_downcase contains 'vimeo.com/'
        assign hero_mobile_vimeo_id = hero_video_mobile_url | split: 'vimeo.com/' | last | split: '?' | first | split: '&' | first | split: '/' | first
        if hero_mobile_vimeo_id != blank
          assign hero_video_mobile_embed_url = 'https://player.vimeo.com/video/' | append: hero_mobile_vimeo_id
          assign hero_video_mobile_embed_provider = 'vimeo'
          assign hero_mobile_use_iframe_video = true
        endif
      endif
    endif

    if hero_video_embed_url == blank and hero_video_mobile_embed_url != blank
      assign hero_video_embed_url = hero_video_mobile_embed_url
      assign hero_video_embed_provider = hero_video_mobile_embed_provider
      assign hero_use_iframe_video = hero_mobile_use_iframe_video
    endif
    if hero_video_mobile_embed_url == blank and hero_video_embed_url != blank
      assign hero_video_mobile_embed_url = hero_video_embed_url
      assign hero_video_mobile_embed_provider = hero_video_embed_provider
      assign hero_mobile_use_iframe_video = hero_use_iframe_video
    endif

    if hero_video_embed_provider == 'youtube' or hero_video_mobile_embed_provider == 'youtube'
      assign hero_has_youtube_embed = true
    endif
    if hero_video_embed_provider == 'vimeo' or hero_video_mobile_embed_provider == 'vimeo'
      assign hero_has_vimeo_embed = true
    endif

    if hero_has_video == false
      if hero_image_desktop_field != blank
        assign hero_image_desktop_direct_url = hero_image_desktop_field.url | default: hero_image_desktop_field.src
        if hero_image_desktop_field.width != blank
          assign hero_image_desktop_width = hero_image_desktop_field.width | default: 2480 | at_most: 2480
          assign hero_image_desktop_url = hero_image_desktop_field | image_url: width: hero_image_desktop_width
        elsif hero_image_desktop_direct_url != blank
          assign hero_image_desktop_url = hero_image_desktop_direct_url
        else
          assign hero_image_desktop_url = hero_image_desktop_field
        endif
      endif

      if hero_image_mobile_field != blank
        assign hero_image_mobile_direct_url = hero_image_mobile_field.url | default: hero_image_mobile_field.src
        if hero_image_mobile_field.width != blank
          assign hero_image_mobile_width = hero_image_mobile_field.width | default: 1206 | at_most: 1206
          assign hero_image_mobile_url = hero_image_mobile_field | image_url: width: hero_image_mobile_width
        elsif hero_image_mobile_direct_url != blank
          assign hero_image_mobile_url = hero_image_mobile_direct_url
        else
          assign hero_image_mobile_url = hero_image_mobile_field
        endif
      endif

      if hero_image_desktop_url == blank and hero_image_mobile_url != blank
        assign hero_image_desktop_url = hero_image_mobile_url
      endif
      if hero_image_mobile_url == blank and hero_image_desktop_url != blank
        assign hero_image_mobile_url = hero_image_desktop_url
      endif
    endif

    assign hero_has_media = false
    if hero_manual_mode and hero_has_video == false and hero_image_desktop_url == blank and hero_image_mobile_url == blank
      assign hero_image_desktop_url = 'placeholder-hero-card-desktop.jpg' | asset_url
      assign hero_image_mobile_url = 'placeholder-hero-card-mobile.jpg' | asset_url
    endif
    if hero_has_video or hero_image_desktop_url != blank or hero_image_mobile_url != blank
      assign hero_has_media = true
    endif

    if hero_has_media == false
      assign hide_section = true
    endif

    if hide_section == false
      if hero_manual_mode
        if hero_media_title == blank and hero_display_kicker == blank and hero_display_tagline == blank and hero_display_subheadline == blank
          assign hide_section = true
        endif
      else
        assign hero_show_price = true
        assign hero_display_title = product.title
        assign hero_product_settings_ref = product.metafields.custom.sbv2_product_settings.value | default: product.metafields.custom.sbv2_product_settings
        if hero_product_settings_ref != blank
          assign hero_product_tagline = hero_product_settings_ref.tagline.value | default: hero_product_settings_ref.tagline
          assign hero_product_tagline_html = hero_product_settings_ref.tagline | metafield_tag
        endif

        assign hero_linked_videos_ref = product.metafields.custom.sbv2_hero_videos
        assign hero_linked_videos_root = hero_linked_videos_ref.value | default: hero_linked_videos_ref.reference.value | default: hero_linked_videos_ref.reference | default: hero_linked_videos_ref
        if hero_linked_videos_root != blank
          assign hero_linked_video_items = hero_linked_videos_root.videos.value | default: hero_linked_videos_root.videos.references | default: hero_linked_videos_root.videos
          if hero_linked_video_items != blank
            for hero_linked_video_item in hero_linked_video_items limit: 4
              assign hero_linked_video_entry = hero_linked_video_item.value | default: hero_linked_video_item.reference.value | default: hero_linked_video_item.reference | default: hero_linked_video_item
              assign hero_linked_video_youtube_id = hero_linked_video_entry.youtube_id.value | default: hero_linked_video_entry.youtube_id | append: '' | strip
              if hero_linked_video_youtube_id contains 'youtube.com/watch'
                assign hero_linked_video_youtube_id = hero_linked_video_youtube_id | split: 'v=' | last | split: '&' | first
              elsif hero_linked_video_youtube_id contains 'youtu.be/'
                assign hero_linked_video_youtube_id = hero_linked_video_youtube_id | split: 'youtu.be/' | last | split: '?' | first | split: '&' | first
              endif
              assign hero_linked_video_youtube_id = hero_linked_video_youtube_id | split: '?' | first | split: '&' | first | split: '/' | last

              if hero_linked_video_youtube_id != blank
                assign hero_has_linked_videos = true
                break
              endif
            endfor
          endif
        endif

        assign hero_selected_variant = product.selected_or_first_available_variant
        assign hero_currency_code = cart.currency.iso_code | default: localization.country.currency.iso_code | default: shop.currency | upcase
        if hero_selected_variant == blank and product.variants != blank
          assign hero_selected_variant = product.variants.first
        endif
        if hero_selected_variant.compare_at_price > hero_selected_variant.price
          assign hero_has_compare_price = true
        endif
      endif
    endif
  endif
%}

{% if hide_section %}
  <script>
    (() => {
      const sectionWrapper = document.currentScript && document.currentScript.closest('.shopify-section');
      if (sectionWrapper) {
        sectionWrapper.style.setProperty('display', 'none', 'important');
      }
    })();
  </script>
{% else %}
  {% # theme-check-disable RemoteAsset %}
  {% if hero_has_youtube_embed %}
    <link rel="preconnect" href="https://www.youtube.com">
    <link rel="preconnect" href="https://i.ytimg.com" crossorigin>
  {% endif %}
  {% if hero_has_vimeo_embed %}
    <link rel="preconnect" href="https://player.vimeo.com">
    <link rel="preconnect" href="https://i.vimeocdn.com" crossorigin>
  {% endif %}
  {% # theme-check-enable RemoteAsset %}
  <section
    class="sb-product-page-hero{% if hero_manual_mode %} sb-product-page-hero--manual{% endif %}"
    data-product-hero
    {% unless hero_manual_mode %}
      data-product-id="{{ product.id }}"
    {% endunless %}
  >
    <div class="sb-product-page-hero__media-wrap">
      <div class="sb-product-page-hero__media" id="sb-product-page-hero-media-{{ section.id }}">
        {% if hero_has_video %}
          {% if hero_use_iframe_video and hero_video_embed_url != blank and hero_mobile_use_iframe_video and hero_video_mobile_embed_url != blank and hero_video_mobile_embed_url != hero_video_embed_url %}
            <iframe
              class="sb-product-page-hero__media-iframe sb-product-page-hero__media-iframe--desktop"
              src="about:blank"
              data-embed-src="{{ hero_video_embed_url | escape }}"
              title="{{ hero_media_title | escape }}"
              loading="eager"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            ></iframe>
            <iframe
              class="sb-product-page-hero__media-iframe sb-product-page-hero__media-iframe--mobile"
              src="about:blank"
              data-embed-src="{{ hero_video_mobile_embed_url | escape }}"
              title="{{ hero_media_title | escape }}"
              loading="eager"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            ></iframe>
          {% elsif hero_use_iframe_video and hero_video_embed_url != blank %}
            <iframe
              class="sb-product-page-hero__media-iframe"
              src="{{ hero_video_embed_url | escape }}"
              title="{{ hero_media_title | escape }}"
              loading="eager"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            ></iframe>
          {% elsif hero_video_mobile_url != blank and hero_video_mobile_url != hero_video_desktop_url %}
            <video
              class="sb-product-page-hero__media-video sb-product-page-hero__media-video--desktop"
              autoplay
              loop
              muted
              playsinline
              preload="metadata"
              width="{{ hero_media_desktop_width }}"
              height="{{ hero_media_desktop_height }}"
              src="{{ hero_video_desktop_url }}"
            ></video>
            <video
              class="sb-product-page-hero__media-video sb-product-page-hero__media-video--mobile"
              autoplay
              loop
              muted
              playsinline
              preload="metadata"
              width="{{ hero_media_mobile_width }}"
              height="{{ hero_media_mobile_height }}"
              src="{{ hero_video_mobile_url }}"
            ></video>
          {% else %}
            <video
              class="sb-product-page-hero__media-video"
              autoplay
              loop
              muted
              playsinline
              preload="metadata"
              width="{{ hero_media_desktop_width }}"
              height="{{ hero_media_desktop_height }}"
              src="{{ hero_video_desktop_url }}"
            ></video>
          {% endif %}
        {% elsif hero_image_desktop_url != blank %}
          <picture>
            <source media="(max-width: 749px)" srcset="{{ hero_image_mobile_url }}">
            <img
              class="sb-product-page-hero__media-image"
              src="{{ hero_image_desktop_url }}"
              alt="{{ hero_media_title | escape }}"
              loading="eager"
              fetchpriority="high"
              width="{{ hero_media_desktop_width }}"
              height="{{ hero_media_desktop_height }}"
            >
          </picture>
        {% endif %}
      </div>
    </div>

    <div class="sb-product-page-hero__content">
      {% if hero_manual_mode %}
        {% if hero_display_chip != blank %}
          <p class="sb-product-page-hero__chip font-caption weight-semibold">{{ hero_display_chip | escape }}</p>
        {% endif %}

        {% if hero_display_kicker != blank %}
          <p class="sb-product-page-hero__name font-body weight-semibold">{{ hero_display_kicker }}</p>
        {% endif %}

        {% if hero_display_title != blank %}
          <h1 class="sb-product-page-hero__tagline {{ hero_tagline_font_class }} weight-bold">{{ hero_display_title }}</h1>
        {% endif %}

        {% if hero_display_subheadline != blank %}
          <div class="sb-product-page-hero__subheadline font-body weight-regular rte">
            {{ hero_display_subheadline }}
          </div>
        {% endif %}
      {% else %}
        {% if hero_display_title != blank %}
          <h1 class="sb-product-page-hero__name font-body weight-semibold">{{ hero_display_title }}</h1>
        {% endif %}
      {% endif %}

      {% if hero_manual_mode == false and hero_product_tagline_html != blank %}
        <div class="sb-product-page-hero__tagline sb-product-page-hero__tagline--rich {{ hero_tagline_font_class }} weight-bold rte">
          {{ hero_product_tagline_html }}
        </div>
      {% elsif hero_manual_mode == false and hero_product_tagline != blank %}
        <p class="sb-product-page-hero__tagline {{ hero_tagline_font_class }} weight-bold">{{ hero_product_tagline }}</p>
      {% elsif hero_manual_mode == false and hero_display_tagline != blank %}
        <p class="sb-product-page-hero__tagline {{ hero_tagline_font_class }} weight-bold">{{ hero_display_tagline }}</p>
      {% endif %}

      {% if hero_show_price %}
        <div
          class="sb-product-page-hero__price-row"
          data-product-hero-price-root
          data-product-id="{{ product.id }}"
          data-product-variant-ids="{% for variant in product.variants %}{% unless forloop.first %},{% endunless %}{{ variant.id }}{% endfor %}"
          data-currency="{{ hero_currency_code }}"
          data-initial-variant-id="{{ hero_selected_variant.id }}"
          data-initial-price="{{ hero_selected_variant.price | default: 0 }}"
          data-initial-compare-price="{{ hero_selected_variant.compare_at_price | default: 0 }}"

        >
          <p
            class="sb-product-page-hero__price sb-product-page-hero__price--compare font-body weight-regular"
            data-product-hero-compare-price
            {% unless hero_has_compare_price %}
              hidden
            {% endunless %}
          >
            {% render 'sb-money-no-decimals', amount: hero_selected_variant.compare_at_price, currency: hero_currency_code, context: 'storefront' %}
          </p>
          <p class="sb-product-page-hero__price sb-product-page-hero__price--current font-body weight-regular" data-product-hero-current-price>
            {% render 'sb-money-no-decimals', amount: hero_selected_variant.price, currency: hero_currency_code, context: 'storefront' %}
          </p>
        </div>
      {% endif %}

      {% if hero_has_linked_videos %}
        <div class="sb-product-page-hero__actions">
          {% render 'radiant-button',
            label: 'Watch video',
            link: hero_video_anchor_link,
            size: 'large',
            icon_position: 'trailing',
            extra_class: 'sb-product-page-hero__watch-video-button font-caption weight-bold'
          %}
        </div>
      {% elsif hero_show_button and hero_button_label != blank and hero_button_link != blank %}
        <div class="sb-product-page-hero__actions">
          {% render 'radiant-button',
            label: hero_button_label,
            link: hero_button_link,
            size: 'large',
            icon_position: 'trailing',
            extra_class: 'sb-product-page-hero__manual-button font-caption weight-bold'
          %}
        </div>
      {% endif %}

    </div>
  </section>

  <script>
    (() => {
      const section = document.currentScript && document.currentScript.closest('.shopify-section');
      if (!section) return;

      const heroRoot = section.querySelector('[data-product-hero]');
      if (!heroRoot) return;

      const priceRoot = heroRoot.querySelector('[data-product-hero-price-root]');
      if (!priceRoot) return;
      const comparePriceElement = heroRoot.querySelector('[data-product-hero-compare-price]');
      const currentPriceElement = heroRoot.querySelector('[data-product-hero-current-price]');
      const watchVideoButton = heroRoot.querySelector('.sb-product-page-hero__watch-video-button');
      const currencyCode = `${priceRoot?.dataset.currency || ''}`.trim().toUpperCase();
      const productId = priceRoot?.dataset.productId || '';
      const variantIds = String(priceRoot?.dataset.productVariantIds || '')
        .split(',')
        .map((value) => value.trim())
        .filter(Boolean);
      const variantIdSet = new Set(variantIds);

      const storefrontPricing = window.SBStorefrontPricing || null;

      const formatMoney = (amountInCents) => {
        const normalizedCents = Number(amountInCents || 0);
        if (storefrontPricing && typeof storefrontPricing.formatMoney === 'function') {
          return storefrontPricing.formatMoney(normalizedCents, currencyCode, { context: 'storefront' });
        }
        return `${Math.round(normalizedCents / 100)}`;
      };

      const parseMoneyCents = (value) => {
        if (value === null || value === undefined || value === '') return null;
        const parsed = Number(value);
        return Number.isFinite(parsed) ? parsed : null;
      };

      const resolveDisplayPrice = (priceCents, comparePriceCents) => {
        if (storefrontPricing && typeof storefrontPricing.resolvePrice === 'function') {
          const resolved = storefrontPricing.resolvePrice({
            productId,
            priceCents,
            comparePriceCents,
          }) || {};
          const currentPriceCents = Number(resolved.currentPriceCents);
          const resolvedComparePriceCents = Number(resolved.comparePriceCents);
          return {
            currentPriceCents: Number.isFinite(currentPriceCents) ? currentPriceCents : Number(priceCents || 0),
            comparePriceCents:
              Number.isFinite(resolvedComparePriceCents) && resolvedComparePriceCents > currentPriceCents
                ? resolvedComparePriceCents
                : null,
          };
        }

        const normalizedPrice = Number(priceCents || 0);
        const normalizedCompare = Number(comparePriceCents || 0);
        return {
          currentPriceCents: normalizedPrice,
          comparePriceCents: normalizedCompare > normalizedPrice ? normalizedCompare : null,
        };
      };

      const applyVariantPrice = (variant) => {
        if (!variant || !currentPriceElement) return;
        const nextPrice = parseMoneyCents(variant.price);
        if (nextPrice === null) return;
        const nextComparePrice = parseMoneyCents(variant.compare_at_price);
        const resolvedPricing = resolveDisplayPrice(nextPrice, nextComparePrice);

        currentPriceElement.textContent = formatMoney(resolvedPricing.currentPriceCents);

        if (!comparePriceElement) return;
        if (resolvedPricing.comparePriceCents !== null && resolvedPricing.comparePriceCents > resolvedPricing.currentPriceCents) {
          comparePriceElement.textContent = formatMoney(resolvedPricing.comparePriceCents);
          comparePriceElement.hidden = false;
        } else {
          comparePriceElement.textContent = '';
          comparePriceElement.hidden = true;
        }
      };

      applyVariantPrice({
        id: priceRoot?.dataset.initialVariantId || '',
        price: parseMoneyCents(priceRoot?.dataset.initialPrice),
        compare_at_price: parseMoneyCents(priceRoot?.dataset.initialComparePrice),
      });

      document.addEventListener('variant:update', (event) => {
        const variant = event?.detail?.resource;
        if (!variant) return;
        const variantId = String(variant.id || '').trim();
        if (!variantId) return;

        const sourceRoot = event.target && event.target.closest ? event.target.closest('.sb-product-main') : null;
        const sourceProductId = sourceRoot?.dataset?.productId || '';
        if (productId && sourceProductId && sourceProductId !== productId) return;
        if (!sourceProductId && variantIdSet.size && !variantIdSet.has(variantId)) return;
        if (parseMoneyCents(variant.price) === null) return;

        applyVariantPrice(variant);
      });

      const responsiveMediaIframes = Array.from(heroRoot.querySelectorAll('.sb-product-page-hero__media-iframe[data-embed-src]'));
      const mobileMediaQuery = window.matchMedia('(max-width: 749px)');
      const EMPTY_IFRAME_SRC = 'about:blank';

      const isFrameActiveForViewport = (frame) => {
        if (frame.classList.contains('sb-product-page-hero__media-iframe--mobile')) {
          return mobileMediaQuery.matches;
        }
        if (frame.classList.contains('sb-product-page-hero__media-iframe--desktop')) {
          return !mobileMediaQuery.matches;
        }
        return true;
      };

      const syncResponsiveHeroEmbeds = () => {
        if (responsiveMediaIframes.length < 2) return;

        responsiveMediaIframes.forEach((frame) => {
          if (!(frame instanceof HTMLIFrameElement)) return;
          const embedSource = (frame.dataset.embedSrc || '').trim();
          if (!embedSource) return;

          if (isFrameActiveForViewport(frame)) {
            if (frame.getAttribute('src') !== embedSource) {
              frame.setAttribute('src', embedSource);
            }
            return;
          }

          if (frame.getAttribute('src') !== EMPTY_IFRAME_SRC) {
            frame.setAttribute('src', EMPTY_IFRAME_SRC);
          }
        });
      };

      if (responsiveMediaIframes.length > 1) {
        syncResponsiveHeroEmbeds();
        if (typeof mobileMediaQuery.addEventListener === 'function') {
          mobileMediaQuery.addEventListener('change', syncResponsiveHeroEmbeds);
        } else if (typeof mobileMediaQuery.addListener === 'function') {
          mobileMediaQuery.addListener(syncResponsiveHeroEmbeds);
        }
      }

      if (watchVideoButton) {
        const watchVideoActions = watchVideoButton.closest('.sb-product-page-hero__actions');

        const getHeroVideoTarget = () => {
          if (watchVideoButton && watchVideoButton.tagName === 'A') {
            const href = (watchVideoButton.getAttribute('href') || '').trim();
            if (href.startsWith('#') && href.length > 1) {
              const anchorTarget = document.getElementById(href.slice(1));
              if (anchorTarget) return anchorTarget;
            }
          }

          const allTargets = Array.from(document.querySelectorAll('[data-hero-video-anchor]'));
          if (!allTargets.length) return null;
          if (productId) {
            const productTarget = allTargets.find((item) => `${item.dataset.productId || ''}` === `${productId}`);
            if (productTarget) return productTarget;
          }
          return allTargets[0] || null;
        };

        const syncWatchVideoVisibility = () => {
          const hasHeroVideoTarget = Boolean(getHeroVideoTarget());
          if (watchVideoActions) {
            watchVideoActions.hidden = !hasHeroVideoTarget;
          }
        };

        watchVideoButton.addEventListener('click', (event) => {
          event.preventDefault();

          const target = getHeroVideoTarget();
          if (!target) return;
          const fallbackOffset = Number.parseFloat(
            getComputedStyle(document.documentElement).getPropertyValue('--sb-space-96')
          ) || 96;
          const targetTop = window.scrollY + target.getBoundingClientRect().top - fallbackOffset;
          window.scrollTo({ top: Math.max(targetTop, 0), behavior: 'smooth' });
        });

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', syncWatchVideoVisibility, { once: true });
        } else {
          syncWatchVideoVisibility();
        }
        window.addEventListener('load', syncWatchVideoVisibility);
        document.addEventListener('shopify:section:load', syncWatchVideoVisibility);
        document.addEventListener('shopify:section:unload', syncWatchVideoVisibility);
      }
    })();
  </script>
{% endif %}

{% stylesheet %}
  .sb-product-page-hero {
    --sb-product-page-hero-mobile-media-width: 402;
    --sb-product-page-hero-mobile-media-height: 369;
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .sb-product-page-hero__media-wrap {
    margin: 0;
    width: 100%;
  }

  .sb-product-page-hero__media {
    aspect-ratio: 1240 / 600;
    background: var(--sb-color-neutral-100);
    border-radius: 0;
    box-shadow: none;
    overflow: hidden;
    position: relative;
    width: 100%;
  }

  .sb-product-page-hero__media-image,
  .sb-product-page-hero__media-video,
  .sb-product-page-hero__media-iframe {
    border: 0;
    display: block;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    width: 100%;
  }

  .sb-product-page-hero__media-iframe {
    position: relative;
  }

  .sb-product-page-hero__media-video--mobile,
  .sb-product-page-hero__media-iframe--mobile {
    display: none;
  }

  .sb-product-page-hero__media picture {
    display: block;
    height: 100%;
    width: 100%;
  }

  .sb-product-page-hero__content {
    margin-top: 36px;
    width: 100%;
  }

  .sb-product-page-hero__name {
    color: var(--sb-color-neutral-900);
    margin: 0;
  }

  .sb-product-page-hero__chip {
    align-items: center;
    align-self: center;
    background: var(--sb-color-neutral-200);
    border-radius: var(--sb-radius-pill);
    color: var(--sb-color-neutral-900);
    display: inline-flex;
    justify-content: center;
    margin: 0;
    max-width: 100%;
    padding: 8px 12px;
    width: fit-content;
  }

  .sb-product-page-hero__tagline {
    color: var(--sb-color-neutral-900);
    font-family: var(--font-display--family);
    margin: 20px 0 0;
    text-wrap: balance;
  }

  .sb-product-page-hero__subheadline {
    color: var(--sb-color-neutral-900);
    margin: 20px 0 0;
    text-wrap: balance;
  }

  .sb-product-page-hero__subheadline > * {
    margin: 0;
  }

  .sb-product-page-hero__subheadline > * + * {
    margin-top: 20px;
  }

  .sb-product-page-hero__tagline .metafield-single_line_text_field {
    text-wrap: balance;
  }

  .sb-product-page-hero__tagline--rich > * {
    font-family: inherit;
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
    margin: 0;
  }

  .sb-product-page-hero__tagline--rich > * + * {
    margin-top: 20px;
  }

  .sb-product-page-hero__price-row {
    align-items: center;
    column-gap: var(--sb-space-8);
    display: inline-flex;
    flex-wrap: wrap;
    margin-top: 20px;
    row-gap: var(--sb-space-8);
  }

  .sb-product-page-hero__price {
    margin: 0;
  }

  .sb-product-page-hero__price--compare {
    color: var(--sb-color-neutral-800);
    text-decoration: line-through;
  }

  .sb-product-page-hero__price--current {
    color: var(--sb-color-blue-500);
  }

  .sb-product-page-hero__actions {
    display: flex;
    justify-content: center;
    margin-top: 24px;
    width: 100%;
  }

  .sb-product-page-hero__watch-video-button {
    width: fit-content;
  }

  @media (min-width: 750px) {
    .sb-product-page-hero {
      position: relative;
    }

    .sb-product-page-hero__media-wrap {
      position: relative;
      z-index: 1;
    }

    .sb-product-page-hero__content {
      display: flex;
      flex-direction: column;
      justify-content: center;
      inset: 0;
      margin-top: 0;
      max-width: min(640px, 56%);
      padding: var(--sb-space-64) var(--sb-space-64) var(--sb-space-64) 0;
      position: absolute;
      text-align: left;
      z-index: 2;
    }

    .sb-product-page-hero--manual .sb-product-page-hero__content {
      padding-left: var(--sb-space-64);
    }

    .sb-product-page-hero__actions {
      justify-content: flex-start;
    }

    .sb-product-page-hero__chip {
      align-self: flex-start;
    }
  }

  @media (max-width: 749px) {
    .sb-product-page-hero {
      align-items: stretch;
      display: flex;
      flex-direction: column-reverse;
      gap: 0;
      height: auto;
      margin-inline: calc(var(--page-margin) * -1);
      overflow: visible;
      padding: 0;
      position: relative;
      width: calc(100% + (var(--page-margin) * 2));
    }

    .sb-product-page-hero__media-wrap {
      bottom: auto;
      left: auto;
      position: relative;
      width: 100%;
      z-index: 1;
    }

    .sb-product-page-hero__media {
      aspect-ratio: var(--sb-product-page-hero-mobile-media-width) / var(--sb-product-page-hero-mobile-media-height);
      margin-inline: 0;
      max-width: none;
      width: 100%;
    }

    .sb-product-page-hero__media-video--desktop,
    .sb-product-page-hero__media-iframe--desktop {
      display: none;
    }

    .sb-product-page-hero__media-video--mobile,
    .sb-product-page-hero__media-iframe--mobile {
      display: block;
    }

    .sb-product-page-hero__content {
      align-items: center;
      display: flex;
      flex-direction: column;
      margin-top: 0;
      padding-inline: 36px;
      position: relative;
      text-align: center;
      width: 100%;
      z-index: 2;
    }
  }
{% endstylesheet %}

