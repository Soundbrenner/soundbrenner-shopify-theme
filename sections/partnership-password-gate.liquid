{% assign gate_title = 'sb.partnership_password.title' | t %}
{% assign gate_description = 'sb.partnership_password.description' | t %}
{% assign gate_label = 'sb.partnership_password.password_label' | t %}
{% assign gate_button = 'sb.partnership_password.enter' | t %}
{% assign gate_error = 'sb.partnership_password.error' | t %}
{% assign gate_email = 'florian@soundbrenner.com' %}
{% assign gate_email_link = 'mailto:' | append: gate_email %}

<section
  class="sb-partnership-password-gate full-width"
  data-partnership-password-gate
  data-password-hash="48d41b7edd6d3ea474d9b74e3608078058ce15563fd04169ba16444b25617339"
>
  <form class="sb-partnership-password-gate__card" data-password-form novalidate>
    <div class="sb-partnership-password-gate__intro">
      <h1 class="sb-partnership-password-gate__title">{{ gate_title }}</h1>
      <p class="sb-partnership-password-gate__description">{{ gate_description }}</p>
    </div>

    <label class="sb-partnership-password-gate__field" data-password-field>
      <span class="sb-partnership-password-gate__field-label">{{ gate_label }}</span>
      <input
        class="sb-partnership-password-gate__input"
        type="password"
        name="partnership-password"
        autocomplete="current-password"
        data-password-input
        aria-describedby="PartnershipPasswordError"
      >
    </label>

    {% render 'radiant-button',
      label: gate_button,
      button_type: 'submit',
      size: 'large',
      extra_class: 'sb-partnership-password-gate__button font-caption weight-bold'
    %}

    <p class="sb-partnership-password-gate__help">
      {{ 'sb.partnership_password.access_help_html' | t: email: gate_email, link: gate_email_link }}
    </p>

    <div class="sb-partnership-password-gate__error" id="PartnershipPasswordError" data-password-error hidden>
      <span class="sb-partnership-password-gate__error-icon" aria-hidden="true">
        {{ 'icon-error.svg' | inline_asset_content }}
      </span>
      <span class="sb-partnership-password-gate__error-text">{{ gate_error }}</span>
    </div>
  </form>
</section>

{% stylesheet %}
  html:has(.sb-partnership-password-gate:not([hidden])) {
    background: var(--sb-color-always-black);
  }

  html:has(.sb-partnership-password-gate:not([hidden])) body {
    background: var(--sb-color-always-black);
  }

  html:has(.sb-partnership-password-gate:not([hidden])) .shopify-section[id*='template--']:not(:has(> .sb-partnership-password-gate)) {
    display: none !important;
  }

  .sb-partnership-password-gate {
    align-items: center;
    background: var(--sb-color-always-black);
    box-sizing: border-box;
    display: flex;
    justify-content: center;
    padding: 24px;
  }

  .sb-partnership-password-gate[hidden] {
    display: none !important;
  }

  .sb-partnership-password-gate__card {
    background: var(--sb-color-neutral-200);
    border: 0;
    border-radius: 24px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin: 0;
    max-width: 400px;
    padding: 24px;
    width: 100%;
  }

  .sb-partnership-password-gate__intro {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .sb-partnership-password-gate__title {
    color: var(--sb-color-neutral-900);
    font-family: var(--font-display--family);
    font-size: 24px;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.35;
    margin: 0;
  }

  .sb-partnership-password-gate__description,
  .sb-partnership-password-gate__help,
  .sb-partnership-password-gate__error {
    color: var(--sb-color-neutral-900);
    font-family: var(--font-primary--family);
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0;
    line-height: 1.35;
    margin: 0;
  }

  .sb-partnership-password-gate__field {
    background: var(--sb-color-neutral-400);
    border-radius: 20px;
    box-shadow: none;
    box-sizing: border-box;
    cursor: text;
    display: block;
    height: 56px;
    padding: 0 16px;
    position: relative;
  }

  .sb-partnership-password-gate__field:focus-within {
    box-shadow: none;
  }

  .sb-partnership-password-gate__field.is-invalid {
    box-shadow: none;
  }

  .sb-partnership-password-gate__field.is-invalid .sb-partnership-password-gate__field-label {
    color: var(--sb-color-red-500);
  }

  .sb-partnership-password-gate__field-label {
    color: var(--sb-color-neutral-800);
    font-family: var(--font-primary--family);
    font-size: 16px;
    font-weight: 400;
    left: 16px;
    letter-spacing: 0;
    line-height: 1.35;
    position: absolute;
    top: 50%;
    transform: translateY(-50%) scale(1);
    transform-origin: left top;
    transition: color 150ms ease, transform 150ms ease;
  }

  .sb-partnership-password-gate__input {
    appearance: none;
    background: var(--sb-color-neutral-400) !important;
    border: 0;
    bottom: 8px;
    caret-color: var(--sb-color-primary-500);
    color: var(--sb-color-neutral-900);
    font-family: var(--font-primary--family);
    font-size: 16px;
    font-weight: 400;
    left: 16px;
    letter-spacing: 0.08em;
    line-height: 1.35;
    opacity: 0;
    outline: none;
    padding: 0;
    position: absolute;
    right: 16px;
    transform: translateY(4px);
    transition: opacity 150ms ease, transform 150ms ease;
    width: auto;
  }

  .sb-partnership-password-gate__field:not(.has-value) .sb-partnership-password-gate__input {
    bottom: 0;
    inset: 0;
    left: 16px;
    right: 16px;
  }

  .sb-partnership-password-gate__field.has-value .sb-partnership-password-gate__input {
    opacity: 1;
    transform: translateY(0);
  }

  .sb-partnership-password-gate__field.has-value .sb-partnership-password-gate__field-label {
    transform: translateY(-19px) scale(0.75);
  }

  .sb-partnership-password-gate__input:-webkit-autofill {
    -webkit-box-shadow: 0 0 0 1000px var(--sb-color-neutral-400) inset !important;
    -webkit-text-fill-color: var(--sb-color-neutral-900);
  }

  .sb-partnership-password-gate__error {
    align-items: center;
    color: var(--sb-color-red-500);
    display: flex;
    gap: 10px;
  }

  .sb-partnership-password-gate__error[hidden] {
    display: none;
  }

  .sb-partnership-password-gate__error-icon {
    color: var(--sb-color-red-500);
    display: block;
    flex: 0 0 20px;
    height: 20px;
    width: 20px;
  }

  .sb-partnership-password-gate__error-icon svg {
    display: block;
    height: 100%;
    width: 100%;
  }

  .sb-partnership-password-gate__error-icon svg path:not([fill='none']),
  .sb-partnership-password-gate__error-icon svg circle:not([fill='none']),
  .sb-partnership-password-gate__error-icon svg rect:not([fill='none']) {
    fill: currentColor;
  }

  .sb-partnership-password-gate__error-text {
    color: var(--sb-color-red-500);
    font-family: var(--font-primary--family);
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0;
    line-height: 1.35;
  }

  .sb-partnership-password-gate__button {
    width: 100%;
  }

  .sb-partnership-password-gate__help a {
    color: var(--sb-color-primary-500);
    text-decoration: none;
  }

  .sb-partnership-password-gate__help a:focus-visible {
    outline: 2px solid var(--sb-color-primary-500);
    outline-offset: 3px;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media (hover: hover) and (pointer: fine) {
    .sb-partnership-password-gate__help a:hover {
      text-decoration: underline;
      text-underline-offset: 2px;
    }
  }
{% endstylesheet %}

{% javascript %}
  (() => {
    const storageKey = 'sb-partnership-password-unlocked-v2';
    const encoder = new TextEncoder();

    const hashValue = async (value) => {
      const digest = await crypto.subtle.digest('SHA-256', encoder.encode(value));
      return Array.from(new Uint8Array(digest))
        .map((byte) => byte.toString(16).padStart(2, '0'))
        .join('');
    };

    const initializeGate = (gate) => {
      const form = gate.querySelector('[data-password-form]');
      const field = gate.querySelector('[data-password-field]');
      const input = gate.querySelector('[data-password-input]');
      const error = gate.querySelector('[data-password-error]');
      const expectedHash = gate.getAttribute('data-password-hash') || '';
      if (!form || !field || !input || !expectedHash) return;

      const setUnlocked = () => {
        sessionStorage.setItem(storageKey, 'true');
        gate.hidden = true;
      };

      const updateFieldState = () => {
        field.classList.toggle('has-value', document.activeElement === input || input.value.trim() !== '');
      };

      if (sessionStorage.getItem(storageKey) === 'true') {
        setUnlocked();
        return;
      }

      input.addEventListener('focus', updateFieldState);
      input.addEventListener('blur', updateFieldState);
      input.addEventListener('input', () => {
        field.classList.remove('is-invalid');
        if (error) error.hidden = true;
        updateFieldState();
      });

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        const passwordHash = await hashValue(input.value);
        if (passwordHash === expectedHash) {
          setUnlocked();
          return;
        }

        field.classList.add('is-invalid');
        if (error) error.hidden = false;
        input.select();
      });

      updateFieldState();
    };

    document.querySelectorAll('[data-partnership-password-gate]').forEach(initializeGate);
  })();
{% endjavascript %}

