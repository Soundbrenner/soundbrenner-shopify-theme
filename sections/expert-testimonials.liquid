{% liquid
  assign use_product_metaobjects = section.settings.use_product_metaobjects
  assign section_title = blank
  assign hide_section = false
  assign section_items = blank
  assign manual_has_items = false

  if use_product_metaobjects
    if request.page_type == 'product' and product != blank
      assign source_testimonials_ref = product.metafields.custom.sbv2_expert_testimonials_carousel.value | default: product.metafields.custom.sbv2_expert_testimonials_carousel.reference.value | default: product.metafields.custom.sbv2_expert_testimonials_carousel.reference | default: product.metafields.custom.sbv2_expert_testimonials_carousel

      if source_testimonials_ref != blank
        assign section_title = source_testimonials_ref.title.value | default: source_testimonials_ref.title
        assign section_items = source_testimonials_ref.items.value | default: source_testimonials_ref.items.references | default: source_testimonials_ref.items
      endif
    endif

    if section_items == blank
      assign hide_section = true
    endif
  else
    assign section_title = section.settings.title

    for block in section.blocks
      assign block_testimonial = block.settings.testimonial.value | default: block.settings.testimonial.reference.value | default: block.settings.testimonial.reference | default: block.settings.testimonial
      assign block_image = block.settings.image
      assign block_name = block.settings.name | append: '' | strip
      assign block_title = block.settings.title | append: '' | strip
      assign block_quote = block.settings.quote | append: '' | strip
      if block_testimonial != blank or block_image != blank or block_name != blank or block_title != blank or block_quote != blank
        assign manual_has_items = true
        break
      endif
    endfor

    if manual_has_items == false
      assign hide_section = true
    endif
  endif
%}

{% if hide_section %}
  <script>
    (() => {
      const sectionWrapper = document.currentScript && document.currentScript.closest('.shopify-section');
      if (sectionWrapper) {
        sectionWrapper.style.setProperty('display', 'none', 'important');
      }
    })();
  </script>
{% else %}
  <section class="sb-expert-testimonials-carousel" data-sb-carousel data-sb-motion="reveal">
    <div class="sb-expert-testimonials-carousel__motion" data-sb-motion-item>
    {% if section_title != blank %}
      <h2 class="sb-expert-testimonials-carousel__title font-title weight-bold">{{ section_title }}</h2>
    {% endif %}
    {% if section.settings.subtitle != blank and use_product_metaobjects == false %}
      <div class="sb-expert-testimonials-carousel__subtitle font-body weight-bold rte">
        {{ section.settings.subtitle }}
      </div>
    {% endif %}

    <div class="sb-expert-testimonials-carousel__viewport" data-sb-carousel-viewport>
      <div class="sb-expert-testimonials-carousel__track" data-sb-carousel-track>
        {% if use_product_metaobjects %}
          {% assign rendered_expert_count = 0 %}
          {% for item in section_items %}
            {% liquid
              assign expert_entry = item.value | default: item.reference.value | default: item.reference | default: item
              assign expert_image = expert_entry.image.value | default: expert_entry.image
              assign expert_name = expert_entry.name.value | default: expert_entry.name
              assign expert_title = expert_entry.title.value | default: expert_entry.title
              assign expert_quote = expert_entry.quote.value | default: expert_entry.quote

              assign expert_image_request_width = 849
              if expert_image != blank and expert_image.width != blank
                assign expert_image_request_width = expert_image.width | at_most: 849
              endif
            %}

            {% liquid
              assign rendered_expert_count = rendered_expert_count | plus: 1
              assign expert_image_loading = 'lazy'
              if rendered_expert_count <= 2
                assign expert_image_loading = 'eager'
              endif
            %}

            <article class="sb-expert-testimonials-carousel__item" data-sb-carousel-item>
              <div class="sb-expert-testimonials-carousel__media">
                {% if expert_image != blank %}
                  <img
                    src="{{ expert_image | image_url: width: expert_image_request_width }}"
                    alt="{{ expert_name | default: expert_title | default: expert_quote | escape }}"
                    loading="{{ expert_image_loading }}"
                    width="283"
                    height="283"
                  >
                {% else %}
                  <div class="sb-expert-testimonials-carousel__media-placeholder" aria-hidden="true"></div>
                {% endif %}
              </div>

              {% if expert_name != blank %}
                <p class="sb-expert-testimonials-carousel__name font-callout weight-bold">{{ expert_name }}</p>
              {% endif %}
              {% if expert_title != blank %}
                <p class="sb-expert-testimonials-carousel__role font-body weight-regular">{{ expert_title }}</p>
              {% endif %}
              {% if expert_quote != blank %}
                <p class="sb-expert-testimonials-carousel__quote font-body weight-regular">{{ expert_quote }}</p>
              {% endif %}
            </article>
          {% endfor %}
        {% else %}
          {% assign rendered_expert_count = 0 %}
          {% for block in section.blocks %}
            {% liquid
              assign expert_entry = block.settings.testimonial.value | default: block.settings.testimonial.reference.value | default: block.settings.testimonial.reference | default: block.settings.testimonial
            %}

            {% liquid
              assign expert_image = expert_entry.image.value | default: expert_entry.image
              assign expert_name = expert_entry.name.value | default: expert_entry.name
              assign expert_title = expert_entry.title.value | default: expert_entry.title
              assign expert_quote = expert_entry.quote.value | default: expert_entry.quote
              if expert_entry == blank
                assign expert_image = block.settings.image
                assign expert_name = block.settings.name
                assign expert_title = block.settings.title
                assign expert_quote = block.settings.quote
              endif

              if expert_image == blank and expert_name == blank and expert_title == blank and expert_quote == blank
                continue
              endif

              assign expert_image_request_width = 849
              if expert_image != blank and expert_image.width != blank
                assign expert_image_request_width = expert_image.width | at_most: 849
              endif
            %}

            {% liquid
              assign rendered_expert_count = rendered_expert_count | plus: 1
              assign expert_image_loading = 'lazy'
              if rendered_expert_count <= 2
                assign expert_image_loading = 'eager'
              endif
            %}

            <article class="sb-expert-testimonials-carousel__item" data-sb-carousel-item {{ block.shopify_attributes }}>
              <div class="sb-expert-testimonials-carousel__media">
                {% if expert_image != blank %}
                  <img
                    src="{{ expert_image | image_url: width: expert_image_request_width }}"
                    alt="{{ expert_name | default: expert_title | default: expert_quote | escape }}"
                    loading="{{ expert_image_loading }}"
                    width="283"
                    height="283"
                  >
                {% else %}
                  <div class="sb-expert-testimonials-carousel__media-placeholder" aria-hidden="true"></div>
                {% endif %}
              </div>

              {% if expert_name != blank %}
                <p class="sb-expert-testimonials-carousel__name font-callout weight-bold">{{ expert_name }}</p>
              {% endif %}
              {% if expert_title != blank %}
                <p class="sb-expert-testimonials-carousel__role font-body weight-regular">{{ expert_title }}</p>
              {% endif %}
              {% if expert_quote != blank %}
                <p class="sb-expert-testimonials-carousel__quote font-body weight-regular">{{ expert_quote }}</p>
              {% endif %}
            </article>
          {% endfor %}
        {% endif %}
      </div>
    </div>

    <div class="sb-expert-testimonials-carousel__controls" data-sb-carousel-controls>
      <button type="button" class="sb-expert-testimonials-carousel__arrow" data-sb-carousel-prev aria-label="{{ 'sb.common.previous' | t }}" disabled>
        <span class="sb-expert-testimonials-carousel__arrow-icon sb-expert-testimonials-carousel__arrow-icon--left" aria-hidden="true">
          {{ 'icon-carousel-arrow-filled.svg' | inline_asset_content }}
        </span>
      </button>

      <button type="button" class="sb-expert-testimonials-carousel__arrow" data-sb-carousel-next aria-label="{{ 'sb.common.next' | t }}" disabled>
        <span class="sb-expert-testimonials-carousel__arrow-icon sb-expert-testimonials-carousel__arrow-icon--right" aria-hidden="true">
          {{ 'icon-carousel-arrow-filled.svg' | inline_asset_content }}
        </span>
      </button>
    </div>
    </div>
  </section>
{% endif %}

{% stylesheet %}
  .sb-expert-testimonials-carousel {
    --sb-carousel-gap: var(--sb-space-36);
    --sb-carousel-bleed-inline: var(--page-margin);
    width: 100%;
  }

  .sb-expert-testimonials-carousel__motion {
    width: 100%;
  }

  .sb-expert-testimonials-carousel__title {
    color: var(--sb-color-neutral-900);
    margin: 0;
    text-align: center;
  }

  .sb-expert-testimonials-carousel__subtitle {
    color: var(--sb-color-neutral-900);
    margin: var(--sb-space-24) auto var(--sb-space-48);
    max-width: 820px;
    text-align: center;
  }

  .sb-expert-testimonials-carousel__title + .sb-expert-testimonials-carousel__viewport {
    margin-top: var(--sb-space-48);
  }

  .sb-expert-testimonials-carousel__subtitle > * {
    margin: 0;
  }

  .sb-expert-testimonials-carousel__subtitle > * + * {
    margin-top: var(--sb-space-8);
  }

  .sb-expert-testimonials-carousel__viewport {
    margin-left: calc(-1 * var(--sb-carousel-bleed-inline));
    margin-right: calc(-1 * var(--sb-carousel-bleed-inline));
    overflow-x: auto;
    overflow-y: hidden;
    padding-left: var(--sb-carousel-bleed-inline);
    padding-right: var(--sb-carousel-bleed-inline);
    scrollbar-width: none;
    width: calc(100% + (var(--sb-carousel-bleed-inline) * 2));
    -webkit-overflow-scrolling: touch;
  }

  .sb-expert-testimonials-carousel__viewport::-webkit-scrollbar {
    display: none;
  }

  .sb-expert-testimonials-carousel__track {
    display: flex;
    gap: var(--sb-carousel-gap);
    padding: 0;
    width: max-content;
  }

  .sb-expert-testimonials-carousel__item {
    flex: 0 0 283px;
    max-width: 283px;
    min-width: 283px;
  }

  .sb-expert-testimonials-carousel__media {
    border-radius: 24px;
    height: 283px;
    overflow: hidden;
    width: 283px;
  }

  .sb-expert-testimonials-carousel__media img,
  .sb-expert-testimonials-carousel__media-placeholder {
    display: block;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .sb-expert-testimonials-carousel__media-placeholder {
    background: var(--sb-color-neutral-200);
  }

  .sb-expert-testimonials-carousel__name {
    color: var(--sb-color-neutral-900);
    font-family: var(--font-primary--family);
    margin: var(--sb-space-24) 0 0;
  }

  .sb-expert-testimonials-carousel__role {
    color: var(--sb-color-neutral-900);
    margin: var(--sb-space-12) 0 0;
  }

  .sb-expert-testimonials-carousel__quote {
    color: var(--sb-color-neutral-900);
    font-style: italic;
    margin: var(--sb-space-12) 0 0;
  }

  .sb-expert-testimonials-carousel__controls {
    align-items: center;
    display: none;
    gap: 16px;
    justify-content: flex-end;
    margin: 48px 0 0;
  }

  .sb-expert-testimonials-carousel.is-overflowing .sb-expert-testimonials-carousel__controls {
    display: flex;
  }

  .sb-expert-testimonials-carousel__arrow {
    align-items: center;
    background: transparent;
    border: 0;
    cursor: pointer;
    display: inline-flex;
    height: 48px;
    justify-content: center;
    padding: 0;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    width: 48px;
  }

  .sb-expert-testimonials-carousel__arrow[disabled] {
    cursor: default;
    opacity: 0.5;
  }

  .sb-expert-testimonials-carousel__arrow-icon {
    display: inline-flex;
    height: 48px;
    width: 48px;
  }

  .sb-expert-testimonials-carousel__arrow-icon--right {
    transform: scaleX(-1);
  }

  .sb-expert-testimonials-carousel__arrow-icon svg {
    display: block;
    height: 100%;
    width: 100%;
  }

  .sb-expert-testimonials-carousel__arrow-icon svg path:first-child {
    fill: var(--sb-color-neutral-200);
  }

  .sb-expert-testimonials-carousel__arrow-icon svg path:last-child {
    fill: var(--sb-color-neutral-800);
  }

  .sb-expert-testimonials-carousel__arrow:focus-visible:not([disabled]) .sb-expert-testimonials-carousel__arrow-icon svg path:last-child {
    fill: var(--sb-color-primary-500);
  }

  @media (hover: hover) and (pointer: fine) {
    .sb-expert-testimonials-carousel__arrow:hover:not([disabled]) .sb-expert-testimonials-carousel__arrow-icon svg path:last-child {
      fill: var(--sb-color-primary-500);
    }
  }

  .sb-expert-testimonials-carousel.is-not-overflowing .sb-expert-testimonials-carousel__track {
    margin-inline: auto;
  }
{% endstylesheet %}

{% render 'sb-carousel-init' %}

{% schema %}
{
  "name": "Testimonials carousel",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_product_metaobjects",
      "label": "Use product page metaobjects",
      "default": true
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Expert testimonials",
      "visible_if": "{{ section.settings.use_product_metaobjects == false }}"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "<p>Expert testimonials subtitle.</p>",
      "visible_if": "{{ section.settings.use_product_metaobjects == false }}"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "metaobject",
          "id": "testimonial",
          "label": "Testimonial",
          "metaobject_type": "sbv2_expert_testimonials_carousel_item",
          "info": "Select an individual testimonial."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Target minimum 283x283 at 3x export (849x849).",
          "visible_if": "{{ section.settings.use_product_metaobjects == false }}"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Testimonial name",
          "visible_if": "{{ section.settings.use_product_metaobjects == false }}"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Testimonial title",
          "visible_if": "{{ section.settings.use_product_metaobjects == false }}"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "visible_if": "{{ section.settings.use_product_metaobjects == false }}"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials carousel"
    }
  ]
}
{% endschema %}
