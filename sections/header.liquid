<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {% if settings.logo %}
      "logo": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }},
    {% endif %}
    "url": {{ request.origin | append: page.url | json }}
  }
</script>

{% liquid
  assign primary_navigation = section.settings.primary_navigation
  assign header_sticky_mode = 'always'
  assign show_language = true
  if localization.available_languages.size <= 1
    assign show_language = false
  endif
  assign show_country = true
  if localization.available_countries.size <= 1
    assign show_country = false
  endif
  assign show_country_flag = true
  assign localization_position = 'right'
  assign seasonal_shipping_country_name = localization.country.name | default: localization.country.iso_code | strip
  if seasonal_shipping_country_name == blank
    assign seasonal_shipping_country_name = 'sb.cart.your_country' | t
  endif
  assign seasonal_shipping_country_iso = localization.country.iso_code | upcase | strip
  assign seasonal_shipping_country_handle = seasonal_shipping_country_iso | downcase
  assign seasonal_shipping_is_blocked = false
  assign seasonal_shipping_has_free_shipping = false
  assign seasonal_entry_threshold_cents = 0
  assign seasonal_shipping_advertised_min_time = blank
  assign seasonal_shipping_advertised_max_time = blank
  assign seasonal_shipping_entry = shop.metaobjects['database_localized_shipping_info'][seasonal_shipping_country_handle]
  if seasonal_shipping_entry != blank and seasonal_shipping_country_iso != blank
    assign seasonal_entry_ship_to = seasonal_shipping_entry.ship_to_it.value | default: seasonal_shipping_entry.ship_to_it | append: '' | downcase
    assign seasonal_entry_has_free_shipping = seasonal_shipping_entry.free_shipping_available.value | default: seasonal_shipping_entry.free_shipping_available | append: '' | downcase
    assign seasonal_entry_taxes_included = seasonal_shipping_entry.taxes_included_in_price.value | default: seasonal_shipping_entry.taxes_included_in_price | append: '' | downcase
    assign seasonal_entry_threshold = seasonal_shipping_entry.free_shipping_threshold_in_local_currency.value | default: seasonal_shipping_entry.free_shipping_threshold_in_local_currency
    assign seasonal_shipping_advertised_min_time = seasonal_shipping_entry.advertised_min_time.value | default: seasonal_shipping_entry.advertised_min_time
    assign seasonal_shipping_advertised_max_time = seasonal_shipping_entry.advertised_max_time.value | default: seasonal_shipping_entry.advertised_max_time
    if seasonal_entry_ship_to == 'false' or seasonal_entry_ship_to == '0' or seasonal_entry_ship_to == 'no'
      assign seasonal_shipping_is_blocked = true
    endif
    if seasonal_entry_has_free_shipping == 'true' or seasonal_entry_has_free_shipping == '1' or seasonal_entry_has_free_shipping == 'yes'
      assign seasonal_shipping_has_free_shipping = true
    endif
    if seasonal_entry_threshold != blank
      assign seasonal_entry_threshold_cents = seasonal_entry_threshold | times: 100
    endif
  endif

  assign trustpilot_entry = metaobjects.trustpilot.values | first
  assign trustpilot_url = 'https://www.trustpilot.com/review/soundbrenner.com'
  assign search_shortcut_bestseller_handles = 'wave-in-ear-monitors|wave-pro-in-ear-monitors|pulse-vibrating-metronome|core-2-practice-companion|minuendo-earplugs|wave-pro-hi-fi-over-ear-3-5mm-audio-cable-with-microphone-2-5m-8-2-ft|wave-pro-hi-fi-usb-c-connector|usb-c-to-3-5mm-audio-adapter' | split: '|'
  assign search_shortcut_bestseller_ids = ''
  for search_shortcut_bestseller_handle in search_shortcut_bestseller_handles
    assign search_shortcut_bestseller_product = all_products[search_shortcut_bestseller_handle]
    if search_shortcut_bestseller_product == blank
      continue
    endif
    if search_shortcut_bestseller_ids != blank
      assign search_shortcut_bestseller_ids = search_shortcut_bestseller_ids | append: ','
    endif
    assign search_shortcut_bestseller_ids = search_shortcut_bestseller_ids | append: search_shortcut_bestseller_product.id
  endfor
  assign trustpilot_rating_raw = trustpilot_entry.rating.value | default: trustpilot_entry.rating
  assign trustpilot_rating_template = ''
  if trustpilot_rating_raw != blank
    assign trustpilot_rating_text = 'sb.trustpilot.rating_out_of_five' | t: rating: trustpilot_rating_raw
    assign trustpilot_rating_template = 'sb.trustpilot.rating_out_of_five' | t: rating: '__RATING__'
  else
    assign trustpilot_rating_text = 'sb.trustpilot.rating_out_of_five' | t: rating: 'X.X'
  endif
  assign metronome_rating_raw = trustpilot_entry.the_metronome_app_review_rating.value | default: trustpilot_entry.the_metronome_app_review_rating
  assign metronome_count_raw = trustpilot_entry.the_metronome_app_review_count.value | default: trustpilot_entry.the_metronome_app_review_count
  assign metronome_rating_display = metronome_rating_raw | strip
  assign metronome_count_display = metronome_count_raw | strip
  assign cart_placeholder_image = 'icon-square-placeholder.svg' | asset_url
%}
{% if show_country or show_language %}
  <script src="{{ 'localization.js' | asset_url }}" defer></script>
{% endif %}
<script src="{{ 'cart-system.js' | asset_url }}" defer></script>
<script src="{{ 'header-announcement.js' | asset_url }}" defer></script>
<script src="{{ 'header-drawer.js' | asset_url }}" defer></script>
<script src="{{ 'header-menu.js' | asset_url }}" defer></script>
<script src="{{ 'header-sticky.js' | asset_url }}" defer></script>
<script src="{{ 'header.js' | asset_url }}" defer></script>
{{ 'header.css' | asset_url | stylesheet_tag }}
{{ 'search-shortcut.css' | asset_url | stylesheet_tag }}
<script src="{{ 'search-shortcut.js' | asset_url }}" defer></script>

<header-component
  id="header-component"
  class="header full-width"
  {% unless header_sticky_mode == 'none' %}
    sticky="{{ header_sticky_mode }}"
  {% endunless %}
  data-sticky-mode="{{ header_sticky_mode }}"
  data-sticky-state="inactive"
  data-scroll-direction="none"
>
  <div class="header__inner" data-header-ref="headerInner">
    <div class="header__icons header__icons--left">
      <button
        type="button"
        class="header__icon-link header__icon-link--menu"
        aria-label="{{ 'sb.common.menu' | t }}"
        aria-expanded="false"
        data-mobile-menu-toggle
      >
        <span class="header__icon-asset" aria-hidden="true">
          {{ 'icon-primary-navigation-menu.svg' | inline_asset_content }}
        </span>
      </button>
      <a
        class="header__icon-link header__icon-link--search header__icon-link--mobile-only"
        href="{{ routes.search_url }}"
        aria-label="{{ 'sb.common.search' | t }}"
        aria-expanded="false"
        data-search-shortcut-open
      >
        <span class="header__icon-asset" aria-hidden="true">
          {{ 'icon-primary-navigation-search.svg' | inline_asset_content }}
        </span>
      </a>
    </div>

    <a class="header__brand" href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }}">
      <span class="header__brand-logo" aria-hidden="true">
        {{ 'logo-soundbrenner-wordmark.svg' | inline_asset_content }}
      </span>
    </a>

    <nav class="header__menu" aria-label="{{ 'sb.common.primary' | t }}" data-header-ref="headerMenu">
      {% if primary_navigation != blank and primary_navigation.links.size > 0 %}
        {% for link in primary_navigation.links %}
          {% liquid
            assign link_index = forloop.index
            assign link_path = link.url | split: '?' | first
            assign is_active_link = false
            if link.current or request.path == link_path
              assign is_active_link = true
            endif

            assign has_primary_cards = false
            assign dropdown_card_count = 0

            for block in section.blocks
              if block.type == 'primary_item_product' or block.type == 'primary_item_collection' or block.type == 'primary_item_page' or block.type == 'primary_item_app'
                assign card_menu_index = block.settings.menu_item_index | plus: 0
                if card_menu_index == link_index
                  assign has_primary_cards = true
                  assign dropdown_card_count = dropdown_card_count | plus: 1
                endif
              endif
            endfor

            assign has_dropdown = false
            if has_primary_cards
              assign has_dropdown = true
            endif

            assign dropdown_card_count = dropdown_card_count | at_least: 1 | at_most: 4
          %}

          <div class="header__menu-item{% if has_dropdown %} has-dropdown{% endif %}">
            <a
              class="header__menu-link font-caption weight-regular{% if is_active_link %} is-active{% endif %}"
              href="{{ link.url }}"
            >
              {{ link.title }}
            </a>

            {% if has_dropdown %}
              <div class="header__primary-menu" aria-label="{{ link.title | escape }}" style="--sb-primary-columns: {{ dropdown_card_count }};">
                <div class="header__primary-menu-panel">
                  <div class="header__primary-menu-panel-inner">
                  <a class="header__primary-menu-title font-callout weight-bold" href="{{ link.url }}">{{ link.title }}</a>
                  <div class="header__primary-menu-grid">
                    {% for block in section.blocks %}
                      {% liquid
                        assign block_type_key = block.type

                        if block_type_key != 'primary_item_product' and block_type_key != 'primary_item_collection' and block_type_key != 'primary_item_page' and block_type_key != 'primary_item_app'
                          continue
                        endif

                        assign block_menu_index = block.settings.menu_item_index | plus: 0
                        if block_menu_index != link_index
                          continue
                        endif
                        assign app_mode = false
                        assign card_product = blank
                        assign card_collection = blank
                        assign card_page = blank
                        assign hide_on_mobile = false

                        case block_type_key
                          when 'primary_item_product'
                            assign card_product = block.settings.product
                          when 'primary_item_collection'
                            assign card_collection = block.settings.collection
                            assign hide_on_mobile = block.settings.hide_on_mobile
                          when 'primary_item_page'
                            assign card_page = block.settings.page
                          when 'primary_item_app'
                            assign app_mode = true
                        endcase
                        assign card_image = block.settings.image
                        assign card_title = blank
                        assign card_body = blank
                        assign card_link = blank
                        assign card_rating_value = 4.8
                        assign card_rating_display = metronome_rating_display | default: '4.8'
                        assign card_rating_count_display = metronome_count_display | default: '100K+'
                        assign card_star_icon_url = 'icon-review-star.svg' | asset_url
                        assign card_app_store_link = 'https://apps.apple.com/us/app/the-metronome-by-soundbrenner/id1048954353'
                        assign card_google_play_link = 'https://play.google.com/store/apps/details?id=com.soundbrenner.pulse'

                        if app_mode == true
                          assign app_page = block.settings.app_page
                          if app_page != blank
                            assign card_link = app_page.url
                          else
                            assign card_link = routes.root_url | append: 'pages/the-app'
                          endif
                          assign card_title = 'sb.header.metronome_app' | t
                          assign card_body = 'sb.header.download_ios_android' | t
                          assign parsed_rating_value = card_rating_display | split: ' ' | first | plus: 0
                          if parsed_rating_value > 0
                            assign card_rating_value = parsed_rating_value
                          endif
                        else
                          if card_product != blank
                            assign card_link = card_product.url
                            assign card_title = card_product.title
                            assign product_settings_ref = card_product.metafields.custom.sbv2_product_settings.value | default: card_product.metafields.custom.sbv2_product_settings
                            if product_settings_ref != blank
                              assign card_body = product_settings_ref.tagline.value | default: product_settings_ref.tagline
                            endif
                            if card_body == blank and card_product.description != blank
                              assign card_body = card_product.description | strip_html
                            endif
                          elsif card_collection != blank
                            assign card_link = card_collection.url
                            assign card_title = card_collection.title
                            assign card_body = card_collection.description | strip_html
                          elsif card_page != blank
                            assign card_link = card_page.url
                            assign card_title = card_page.title
                            assign card_body = card_page.content | strip_html
                          endif
                        endif

                        assign card_image_url = blank
                        if card_image != blank
                          assign card_image_url = card_image | image_url: width: 502
                        endif

                        assign card_badge_label = blank
                        assign card_badge_type = blank
                        if card_product != blank and card_product.tags != blank
                          for product_tag in card_product.tags
                            assign product_tag_downcase = product_tag | downcase
                            if product_tag_downcase == 'bestseller'
                              assign card_badge_label = 'sb.product.badge_bestseller' | t
                              assign card_badge_type = 'bestseller'
                              break
                            endif
                            if product_tag_downcase == 'new'
                              assign card_badge_label = 'sb.product.badge_new' | t
                              assign card_badge_type = 'new'
                            endif
                          endfor
                        endif
                      %}

                      <article class="header__primary-card" data-hide-on-mobile="{{ hide_on_mobile }}" {{ block.shopify_attributes }}>
                        <a class="header__primary-card-media" href="{{ card_link | default: '#' }}">
                          {% if card_badge_label != blank %}
                            <span class="header__primary-card-badge header__primary-card-badge--{{ card_badge_type }} font-caption weight-semibold">
                              {{ card_badge_label }}
                            </span>
                          {% endif %}

                          {% # theme-check-disable RemoteAsset %}
                          {% if card_image_url != blank %}
                            <img
                              class="header__primary-card-image"
                              src="{{ card_image_url }}"
                              alt="{{ card_title | default: link.title | escape }}"
                              loading="eager"
                              fetchpriority="low"
                              decoding="async"
                              width="502"
                              height="502"
                            >
                          {% else %}
                            <img
                              class="header__primary-card-image"
                              src="{{ 'placeholder-primary-navigation-item.jpg' | asset_url }}"
                              alt="{{ card_title | default: link.title | escape }}"
                              loading="eager"
                              fetchpriority="low"
                              decoding="async"
                              width="502"
                              height="502"
                            >
                          {% endif %}
                          {% # theme-check-enable RemoteAsset %}
                        </a>

                        <p class="header__primary-card-title font-body weight-bold">
                          <a class="header__primary-card-title-link" href="{{ card_link | default: '#' }}">{{ card_title | default: link.title }}</a>
                        </p>

                        {% if app_mode == true %}
                          <div class="header__primary-card-app">
                            <p class="header__primary-card-rating font-caption weight-semibold">
                              <span class="header__primary-card-stars" aria-hidden="true">
                                {% for star_index in (1..5) %}
                                  {% assign prior_stars = star_index | minus: 1 %}
                                  {% assign star_fill = 0 %}
                                  {% if card_rating_value >= star_index %}
                                    {% assign star_fill = 100 %}
                                  {% elsif card_rating_value > prior_stars %}
                                    {% assign star_fill = card_rating_value | minus: prior_stars | times: 100 | round %}
                                  {% endif %}
                                  <span class="header__primary-card-star" style="--sb-star-fill: {{ star_fill }}%; --sb-star-icon-url: url('{{ card_star_icon_url }}');"></span>
                                {% endfor %}
                              </span>
                              <span
                                data-sb-localized-rating-value="{{ card_rating_display | escape }}"
                                data-sb-localized-rating-digits="1"
                              >
                                {{ card_rating_display }}
                              </span>
                            </p>
                            <p
                              class="header__primary-card-rating-count font-caption weight-regular"
                              data-sb-localized-count-value="{{ card_rating_count_display | escape }}"
                              data-sb-localized-count-template="{{ 'sb.header.ratings' | t: count: '__COUNT__' | escape }}"
                            >
                              {{ 'sb.header.ratings' | t: count: card_rating_count_display }}
                            </p>

                            <div class="header__primary-card-app-links">
                              <a href="{{ card_app_store_link }}" target="_blank" rel="noopener noreferrer" aria-label="{{ 'sb.app.download_app_store' | t }}">
                                <img
                                  src="{{ 'app-download-app-store.png' | asset_url }}"
                                  alt="{{ 'sb.app.download_app_store' | t }}"
                                  loading="lazy"
                                  width="100"
                                  height="30"
                                >
                              </a>
                              <a href="{{ card_google_play_link }}" target="_blank" rel="noopener noreferrer" aria-label="{{ 'sb.app.download_google_play' | t }}">
                                <img
                                  src="{{ 'app-download-google-play.png' | asset_url }}"
                                  alt="{{ 'sb.app.download_google_play' | t }}"
                                  loading="lazy"
                                  width="100"
                                  height="30"
                                >
                              </a>
                            </div>
                          </div>
                        {% else %}
                          {% if card_body != blank %}
                            <p class="header__primary-card-body font-caption weight-regular">{{ card_body }}</p>
                          {% endif %}

                          {% if block_type_key == 'primary_item_product' %}
                            {% assign accessories_collection = block.settings.accessories_collection %}
                            {% if accessories_collection == blank and card_product != blank and card_product.collections != blank %}
                              {% assign fallback_non_generic_collection = blank %}
                              {% for candidate_collection in card_product.collections %}
                                {% assign candidate_handle = candidate_collection.handle | downcase %}
                                {% assign candidate_title = candidate_collection.title | downcase %}
                                {% if candidate_handle contains 'accessor' or candidate_title contains 'accessor' %}
                                  {% assign accessories_collection = candidate_collection %}
                                  {% break %}
                                {% endif %}

                                {% if fallback_non_generic_collection == blank %}
                                  {% assign is_generic_collection = false %}
                                  {% if candidate_handle == 'all' or candidate_handle == 'all-products' or candidate_handle contains 'shop-all' or candidate_title contains 'shop all' %}
                                    {% assign is_generic_collection = true %}
                                  {% endif %}
                                  {% unless is_generic_collection %}
                                    {% assign fallback_non_generic_collection = candidate_collection %}
                                  {% endunless %}
                                {% endif %}
                              {% endfor %}
                              {% if accessories_collection == blank %}
                                {% if fallback_non_generic_collection != blank %}
                                  {% assign accessories_collection = fallback_non_generic_collection %}
                                {% else %}
                                  {% assign accessories_collection = card_product.collections.first %}
                                {% endif %}
                              {% endif %}
                            {% endif %}
                            {% if accessories_collection != blank %}
                              <ul class="header__primary-card-links font-caption weight-semibold" role="list">
                                <li>
                                  <a href="{{ accessories_collection.url }}">{{ 'sb.header.accessories' | t }}</a>
                                </li>
                              </ul>
                            {% endif %}
                          {% elsif block_type_key == 'primary_item_collection' %}
                            {% assign linked_product_1 = block.settings.related_product_1 %}
                            {% assign linked_product_2 = block.settings.related_product_2 %}
                            {% assign linked_product_3 = block.settings.related_product_3 %}
                            {% assign has_card_links = false %}
                            {% if linked_product_1 != blank or linked_product_2 != blank or linked_product_3 != blank %}
                              {% assign has_card_links = true %}
                            {% endif %}
                            {% if has_card_links %}
                              <ul class="header__primary-card-links font-caption weight-semibold" role="list">
                                {% if linked_product_1 != blank %}
                                  {% assign linked_product_1_settings = linked_product_1.metafields.custom.sbv2_product_settings.value | default: linked_product_1.metafields.custom.sbv2_product_settings %}
                                  {% assign linked_product_1_tagline = blank %}
                                  {% if linked_product_1_settings != blank %}
                                    {% assign linked_product_1_tagline = linked_product_1_settings.tagline.value | default: linked_product_1_settings.tagline %}
                                  {% endif %}
                                  <li>
                                    <a
                                      href="{{ linked_product_1.url }}"
                                      data-mobile-product-title="{{ linked_product_1.title | escape }}"
                                      data-mobile-product-description="{{ linked_product_1.description | strip_html | escape }}"
                                      data-mobile-product-tagline="{{ linked_product_1_tagline | escape }}"
                                    >
                                      {{ linked_product_1.title }}
                                    </a>
                                  </li>
                                {% endif %}
                                {% if linked_product_2 != blank %}
                                  {% assign linked_product_2_settings = linked_product_2.metafields.custom.sbv2_product_settings.value | default: linked_product_2.metafields.custom.sbv2_product_settings %}
                                  {% assign linked_product_2_tagline = blank %}
                                  {% if linked_product_2_settings != blank %}
                                    {% assign linked_product_2_tagline = linked_product_2_settings.tagline.value | default: linked_product_2_settings.tagline %}
                                  {% endif %}
                                  <li>
                                    <a
                                      href="{{ linked_product_2.url }}"
                                      data-mobile-product-title="{{ linked_product_2.title | escape }}"
                                      data-mobile-product-description="{{ linked_product_2.description | strip_html | escape }}"
                                      data-mobile-product-tagline="{{ linked_product_2_tagline | escape }}"
                                    >
                                      {{ linked_product_2.title }}
                                    </a>
                                  </li>
                                {% endif %}
                                {% if linked_product_3 != blank %}
                                  {% assign linked_product_3_settings = linked_product_3.metafields.custom.sbv2_product_settings.value | default: linked_product_3.metafields.custom.sbv2_product_settings %}
                                  {% assign linked_product_3_tagline = blank %}
                                  {% if linked_product_3_settings != blank %}
                                    {% assign linked_product_3_tagline = linked_product_3_settings.tagline.value | default: linked_product_3_settings.tagline %}
                                  {% endif %}
                                  <li>
                                    <a
                                      href="{{ linked_product_3.url }}"
                                      data-mobile-product-title="{{ linked_product_3.title | escape }}"
                                      data-mobile-product-description="{{ linked_product_3.description | strip_html | escape }}"
                                      data-mobile-product-tagline="{{ linked_product_3_tagline | escape }}"
                                    >
                                      {{ linked_product_3.title }}
                                    </a>
                                  </li>
                                {% endif %}
                              </ul>
                            {% endif %}
                          {% endif %}
                        {% endif %}
                      </article>
                    {% endfor %}
                  </div>
                  </div>
                </div>
              </div>
            {% endif %}
          </div>
        {% endfor %}
      {% endif %}
    </nav>

    <div class="header__icons header__icons--right">
      {% if show_country or show_language %}
        {% if show_country %}
          <dropdown-localization-component class="header__localization header__icon-link--desktop-only">
            <button
              type="button"
              class="header__localization-button font-caption2 weight-semibold"
              aria-label="{{ 'sb.common.region_selector' | t }}"
              aria-expanded="false"
              aria-controls="HeaderLocalizationPanel-{{ section.id }}"
              data-localization-ref="button"
            >
              <span
                class="header__localization-flag"
                style="background-image: url({{ localization.country | image_url: width: 32 }});"
                aria-hidden="true"
              ></span>
            </button>
            <div
              id="HeaderLocalizationPanel-{{ section.id }}"
              class="header__localization-panel header__localization-panel--{{ localization_position }}"
              data-localization-ref="panel"
            >
              <div class="header__localization-panel-surface">
                <div class="header__localization-panel-inner">
                  {% render 'localization-form',
                    show_country: show_country,
                    show_language: show_language,
                    localization_style: 'dropdown',
                    form_id: section.id | append: '-dropdown'
                  %}
                </div>
              </div>
            </div>
          </dropdown-localization-component>
        {% elsif show_language %}
          <div class="header__localization header__localization--language-only header__icon-link--desktop-only">
            {% render 'localization-form',
              show_country: false,
              show_language: show_language,
              localization_style: 'dropdown',
              form_id: section.id | append: '-inline'
            %}
          </div>
        {% endif %}
      {% endif %}
      <div class="header__utility-icons" style="min-width: 20px;">
        <a
          class="header__icon-link header__icon-link--search"
          href="{{ routes.search_url }}"
          aria-label="{{ 'sb.common.search' | t }}"
          aria-expanded="false"
          data-search-shortcut-open
        >
          <span class="header__icon-asset" aria-hidden="true">
            {{ 'icon-primary-navigation-search.svg' | inline_asset_content }}
          </span>
        </a>
        {% if shop.customer_accounts_enabled %}
          <div class="header__icon-link header__icon-link--account">
            <shopify-account
              aria-label="{{ 'sb.common.account' | t }}"
              {% if section.settings.customer_account_menu != blank %}
                menu="{{ section.settings.customer_account_menu }}"
              {% endif %}
            >
              {% unless customer %}
                <span slot="signed-out-avatar" class="header__account-signed-out" aria-hidden="true">
                  {{ 'icon-primary-navigation-account.svg' | inline_asset_content }}
                </span>
              {% endunless %}
            </shopify-account>
          </div>
        {% else %}
          <a
            class="header__icon-link header__icon-link--account"
            href="{{ routes.account_login_url }}"
            aria-label="{{ 'sb.common.account' | t }}"
          >
            <span class="header__icon-asset" aria-hidden="true">
              {{ 'icon-primary-navigation-account.svg' | inline_asset_content }}
            </span>
          </a>
        {% endif %}
        <a
          class="header__icon-link header__icon-link--cart"
          href="{{ routes.cart_url }}"
          data-header-cart-link
          data-header-cart-page="{% if request.page_type == 'cart' %}true{% else %}false{% endif %}"
          aria-label="{{ 'cart.title' | t }}"
          aria-expanded="false"
          style="align-items: center; display: inline-flex; height: 20px; justify-content: center; min-height: 20px; min-width: 20px; width: 20px;"
        >
          <span class="header__cart-count-badge font-caption weight-bold{% if cart.item_count > 9 %} is-double-digit{% endif %}" data-header-cart-count {% if cart.item_count == 0 %}hidden{% endif %}>
            {% if cart.item_count > 99 %}99+{% else %}{{ cart.item_count }}{% endif %}
          </span>
          <span class="header__icon-asset" aria-hidden="true" style="align-items: center; display: inline-flex; height: 20px; justify-content: center; width: 20px;">
            {{ 'icon-primary-navigation-cart.svg' | inline_asset_content }}
          </span>
        </a>
      </div>
    </div>
  </div>
</header-component>
{% render 'header-search-shortcut',
  search_shortcut_bestseller_ids: search_shortcut_bestseller_ids
%}
{% render 'header-mobile-drawer',
  section: section,
  primary_navigation: primary_navigation,
  show_country: show_country,
  show_language: show_language,
  show_country_flag: show_country_flag,
  trustpilot_url: trustpilot_url,
  trustpilot_rating_raw: trustpilot_rating_raw,
  trustpilot_rating_template: trustpilot_rating_template,
  trustpilot_rating_text: trustpilot_rating_text,
  metronome_rating_display: metronome_rating_display,
  metronome_count_display: metronome_count_display
%}
{% render 'header-cart-drawer',
  section: section,
  primary_navigation: primary_navigation,
  seasonal_shipping_has_free_shipping: seasonal_shipping_has_free_shipping,
  seasonal_shipping_is_blocked: seasonal_shipping_is_blocked,
  seasonal_entry_threshold_cents: seasonal_entry_threshold_cents,
  seasonal_shipping_advertised_min_time: seasonal_shipping_advertised_min_time,
  seasonal_shipping_advertised_max_time: seasonal_shipping_advertised_max_time,
  seasonal_shipping_entry: seasonal_shipping_entry,
  seasonal_shipping_country_name: seasonal_shipping_country_name,
  seasonal_entry_taxes_included: seasonal_entry_taxes_included,
  cart_placeholder_image: cart_placeholder_image
%}


