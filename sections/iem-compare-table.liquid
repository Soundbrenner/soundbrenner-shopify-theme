{% capture sb_iem_compare_table_yes_icon %}
  <img
    src="https://cdn.shopify.com/s/files/1/1306/4847/files/check.svg?v=1774512519"
    alt=""
    loading="lazy"
    width="18"
    height="18"
  >
{% endcapture %}
{% capture sb_iem_compare_table_no_icon %}
  <img
    src="https://cdn.shopify.com/s/files/1/1306/4847/files/cancel.svg?v=1774512519"
    alt=""
    loading="lazy"
    width="18"
    height="18"
  >
{% endcapture %}

<section class="sb-iem-compare-table">
  <div class="sb-iem-compare-table__header">
    <p class="sb-iem-compare-table__eyebrow font-caption weight-semibold">
      Compare your options
    </p>
    <h2 class="sb-iem-compare-table__title font-title weight-bold">
      Why Wave is the right first step
    </h2>
  </div>

  <div class="sb-iem-compare-table__frame">
    <div class="sb-iem-compare-table__scroll" tabindex="0">
      <div class="sb-iem-compare-table__table" role="table" aria-label="Comparison table for Wave and alternative listening options">
        <div
          class="sb-iem-compare-table__cell sb-iem-compare-table__cell--corner"
          role="columnheader"
          style="background: var(--sb-color-always-black);"
        >
          <span class="sb-iem-compare-table__corner-logo" aria-label="Soundbrenner">
            {{ 'logo-soundbrenner-wordmark.svg' | inline_asset_content }}
          </span>
        </div>

        <div class="sb-iem-compare-table__cell sb-iem-compare-table__cell--product sb-iem-compare-table__cell--wave" role="columnheader">
          <span class="sb-iem-compare-table__badge font-caption2 weight-semibold">Best fit for musicians</span>
          <p class="sb-iem-compare-table__product-name font-body weight-bold">Soundbrenner Wave IEMs</p>
          <p class="sb-iem-compare-table__product-note font-caption weight-regular">Built for practice and performance</p>
        </div>

        <div
          class="sb-iem-compare-table__cell sb-iem-compare-table__cell--product"
          role="columnheader"
          style="background: var(--sb-color-always-black); color: var(--sb-color-always-white);"
        >
          <p class="sb-iem-compare-table__product-name font-body weight-bold" style="color: var(--sb-color-always-white);">Consumer headphones</p>
          <p class="sb-iem-compare-table__product-note font-caption weight-regular" style="color: var(--sb-color-always-white);">Great for casual listening</p>
