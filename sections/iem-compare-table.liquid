    { "type": "text", "id": "alt_one_note", "label": "Alternative 1 note", "default": "Great for casual listening" },
    { "type": "text", "id": "alt_two_name", "label": "Alternative 2 heading", "default": "Bluetooth in-ears" },
    { "type": "text", "id": "alt_two_note", "label": "Alternative 2 note", "default": "Made for convenience first" },
    { "type": "text", "id": "alt_three_name", "label": "Alternative 3 heading", "default": "Expensive IEMs" },
    { "type": "text", "id": "alt_three_note", "label": "Alternative 3 note", "default": "Strong performance at a much higher price" },
