{% stylesheet %}
  .sb-iem-compare-table {
    display: flex;
    flex-direction: column;
    gap: 56px;
    width: 100%;
  }

  .sb-iem-compare-table__header {
    display: flex;
    flex-direction: column;
    gap: var(--sb-space-12);
    margin: 0 auto;
    max-width: 760px;
    text-align: center;
  }

  .sb-iem-compare-table__eyebrow,
  .sb-iem-compare-table__title,
  .sb-iem-compare-table__subtitle,
  .sb-iem-compare-table__product-name,
  .sb-iem-compare-table__product-note,
  .sb-iem-compare-table__feature-name,
  .sb-iem-compare-table__feature-note {
    margin: 0;
  }

  .sb-iem-compare-table__eyebrow {
    color: var(--sb-color-primary-500);
    text-transform: uppercase;
  }

  .sb-iem-compare-table__title,
  .sb-iem-compare-table__subtitle {
    color: var(--sb-color-neutral-900);
  }

  .sb-iem-compare-table__subtitle {
    margin-inline: auto;
    max-width: 620px;
  }

  .sb-iem-compare-table__frame {
    background: var(--sb-color-always-black);
    border: 1px solid var(--sb-color-neutral-700);
    border-radius: var(--sb-space-24);
    box-shadow: 0 0 10px 0 var(--sb-color-always-black-12);
    overflow: hidden;
  }

  .sb-iem-compare-table__scroll {
    overflow-x: auto;
    width: 100%;
  }

  .sb-iem-compare-table__scroll:focus-visible {
    outline: 2px solid var(--sb-color-primary-500);
    outline-offset: 4px;
  }

  .sb-iem-compare-table__table {
    background: var(--sb-color-always-black);
    display: grid;
    grid-template-columns: minmax(220px, 1.35fr) repeat(4, minmax(156px, 1fr));
    min-width: 920px;
  }

  .sb-iem-compare-table__cell {
    align-items: center;
    background: var(--sb-color-always-black) !important;
    border-right: 1px solid var(--sb-color-neutral-700);
    border-top: 1px solid var(--sb-color-neutral-700);
    color: var(--sb-color-neutral-100);
    display: flex;
    justify-content: center;
    min-height: 94px;
    padding: var(--sb-space-20);
  }

  .sb-iem-compare-table__cell:nth-child(5n) {
    border-right: 0;
  }

  .sb-iem-compare-table__cell--corner,
  .sb-iem-compare-table__cell--product {
    background: var(--sb-color-always-black) !important;
    border-top: 0;
    min-height: 208px;
  }

  .sb-iem-compare-table__cell--corner {
    background: var(--sb-color-always-black) !important;
    border-right-color: var(--sb-color-neutral-700);
    justify-content: center;
    padding: 32px;
  }

  .sb-iem-compare-table__cell--product {
    align-items: flex-start;
    color: var(--sb-color-neutral-100);
    flex-direction: column;
    gap: 14px;
    justify-content: center;
    padding: 32px 28px;
    text-align: left;
  }

  .sb-iem-compare-table__cell--product.sb-iem-compare-table__cell--wave {
    background: linear-gradient(180deg, var(--sb-color-primary-500) 0%, var(--sb-color-primary-700) 100%);
    border-right-color: var(--sb-color-primary-700);
    color: var(--sb-color-always-white);
  }

  .sb-iem-compare-table__cell--label {
    align-items: flex-start;
    background: var(--sb-color-always-black) !important;
    justify-content: flex-start;
    position: sticky;
    left: 0;
    text-align: left;
    z-index: 1;
  }

  .sb-iem-compare-table__cell--wave {
    background: rgba(0, 201, 183, 0.14) !important;
    box-shadow: inset 0 0 0 1px var(--sb-color-primary-500);
  }

  .sb-iem-compare-table__cell--icon {
    padding: var(--sb-space-16);
  }

  .sb-iem-compare-table__label-copy {
    display: flex;
    flex-direction: column;
    gap: var(--sb-space-6);
  }

  .sb-iem-compare-table__feature-note,
  .sb-iem-compare-table__product-note {
    color: var(--sb-color-always-white);
    opacity: 0.82;
  }

  .sb-iem-compare-table__feature-name,
  .sb-iem-compare-table__product-name {
    color: var(--sb-color-always-white);
  }

  .sb-iem-compare-table__corner-logo {
    color: var(--sb-color-always-white);
    display: inline-flex;
    max-width: 220px;
    width: 100%;
  }

  .sb-iem-compare-table__corner-logo svg {
    display: block;
    height: auto;
    width: 100%;
  }

  .sb-iem-compare-table__corner-logo svg path:not([fill='none']) {
    fill: currentColor !important;
  }

  .sb-iem-compare-table__badge {
    background: rgba(255, 255, 255, 0.18);
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 999px;
    color: var(--sb-color-always-white);
    display: inline-flex;
    padding: 6px 12px;
  }

  .sb-iem-compare-table__status {
    align-items: center;
    border-radius: 999px;
    display: inline-flex;
    height: 44px;
    justify-content: center;
    width: 44px;
  }

  .sb-iem-compare-table__status svg {
    display: block;
    height: 18px;
    width: 18px;
  }

  .sb-iem-compare-table__status svg path:not([fill='none']),
  .sb-iem-compare-table__status svg circle:not([fill='none']),
  .sb-iem-compare-table__status svg rect:not([fill='none']) {
    fill: currentColor !important;
  }

  .sb-iem-compare-table__status--yes {
    background: var(--sb-color-primary-500);
    color: var(--sb-color-always-white);
  }

  .sb-iem-compare-table__status--no {
    background: var(--sb-color-neutral-400);
    color: var(--sb-color-neutral-800);
  }

  @media screen and (max-width: 989px) {
    .sb-iem-compare-table {
      gap: 40px;
    }

    .sb-iem-compare-table__frame {
      border-radius: var(--sb-space-20);
    }

    .sb-iem-compare-table__table {
      grid-template-columns: minmax(210px, 1.2fr) repeat(4, minmax(144px, 1fr));
      min-width: 860px;
    }

    .sb-iem-compare-table__cell {
      min-height: 88px;
      padding: var(--sb-space-16);
    }

    .sb-iem-compare-table__cell--corner,
    .sb-iem-compare-table__cell--product {
      min-height: 176px;
    }

    .sb-iem-compare-table__cell--corner {
      padding: 24px;
    }

    .sb-iem-compare-table__cell--product {
      gap: 12px;
      padding: 24px 20px;
    }
  }

  @media screen and (max-width: 749px) {
    .sb-iem-compare-table__header {
      text-align: left;
    }

    .sb-iem-compare-table__subtitle {
      margin-inline: 0;
    }

    .sb-iem-compare-table__table {
      min-width: 780px;
    }
  }
{% endstylesheet %}

