    .sb-iem-compare-table__mobile-feature.is-active {
      display: flex;
    }

    .sb-iem-compare-table__mobile-feature + .sb-iem-compare-table__mobile-feature {
      border-top: 1px solid var(--sb-color-neutral-700);
