{% endstylesheet %}

<script>
  (() => {
    const initMobileCompare = (scope) => {
      scope.querySelectorAll('.sb-iem-compare-table__mobile').forEach((mobileRoot) => {
        if (mobileRoot.dataset.compareMobileInitialized == 'true') return;
        mobileRoot.dataset.compareMobileInitialized = 'true';

        const tabs = Array.from(mobileRoot.querySelectorAll('[data-compare-mobile-tab]'));
        const panels = Array.from(mobileRoot.querySelectorAll('[data-compare-mobile-panel]'));

        if (!tabs.length || !panels.length) return;

        const setFeatureState = (panel, index) => {
          const features = Array.from(panel.querySelectorAll('[data-compare-mobile-feature]'));
          const dots = Array.from(panel.querySelectorAll('[data-compare-mobile-dot]'));
          if (!features.length) return;

          const normalizedIndex = ((index % features.length) + features.length) % features.length;
          panel.dataset.compareMobileFeatureIndex = normalizedIndex;

          features.forEach((feature, featureIndex) => {
            const isActive = featureIndex == normalizedIndex;
            feature.classList.toggle('is-active', isActive);
            feature.hidden = !isActive;
          });

          dots.forEach((dot, dotIndex) => {
            dot.classList.toggle('is-active', dotIndex == normalizedIndex);
          });
        };

        const activate = (key) => {
          tabs.forEach((tab) => {
            const isActive = tab.getAttribute('data-compare-mobile-tab') == key;
            tab.classList.toggle('is-active', isActive);
            tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
          });

          panels.forEach((panel) => {
            const isActive = panel.getAttribute('data-compare-mobile-panel') == key;
            panel.classList.toggle('is-active', isActive);
            panel.hidden = !isActive;

            if (isActive) {
              const currentIndex = parseInt(panel.dataset.compareMobileFeatureIndex || '0', 10);
              setFeatureState(panel, Number.isNaN(currentIndex) ? 0 : currentIndex);
            }
          });
        };

        panels.forEach((panel) => {
          const features = Array.from(panel.querySelectorAll('[data-compare-mobile-feature]'));
          if (features.length) {
            const initialIndex = features.findIndex((feature) => feature.classList.contains('is-active'));
            setFeatureState(panel, initialIndex < 0 ? 0 : initialIndex);
          }
        });

        mobileRoot.addEventListener('click', (event) => {
          const tab = event.target.closest('[data-compare-mobile-tab]');
          if (tab && mobileRoot.contains(tab)) {
            activate(tab.getAttribute('data-compare-mobile-tab'));
            return;
          }

          const prevButton = event.target.closest('[data-compare-mobile-prev]');
          if (prevButton && mobileRoot.contains(prevButton)) {
            const panel = prevButton.closest('[data-compare-mobile-panel]');
            if (!panel) return;
            const currentIndex = parseInt(panel.dataset.compareMobileFeatureIndex || '0', 10);
            setFeatureState(panel, (Number.isNaN(currentIndex) ? 0 : currentIndex) - 1);
            return;
          }

          const nextButton = event.target.closest('[data-compare-mobile-next]');
          if (nextButton && mobileRoot.contains(nextButton)) {
            const panel = nextButton.closest('[data-compare-mobile-panel]');
            if (!panel) return;
            const currentIndex = parseInt(panel.dataset.compareMobileFeatureIndex || '0', 10);
            setFeatureState(panel, (Number.isNaN(currentIndex) ? 0 : currentIndex) + 1);
            return;
          }

          const dot = event.target.closest('[data-compare-mobile-dot]');
          if (dot && mobileRoot.contains(dot)) {
            const panel = dot.closest('[data-compare-mobile-panel]');
            if (!panel) return;
            const dotIndex = parseInt(dot.getAttribute('data-compare-mobile-dot') || '0', 10);
            setFeatureState(panel, Number.isNaN(dotIndex) ? 0 : dotIndex);
          }
        });

        const initialTab = tabs.find((tab) => tab.classList.contains('is-active')) || tabs[0];
        if (initialTab) {
          activate(initialTab.getAttribute('data-compare-mobile-tab'));
        }
      });
    };

    initMobileCompare(document);
    document.addEventListener('shopify:section:load', (event) => {
      if (!event.target) return;
      initMobileCompare(event.target);
    });
  })();
</script>

