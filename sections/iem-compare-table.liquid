    { "type": "text", "id": "row_2_name", "label": "Row 2 title", "default": "Strong passive isolation" },
    { "type": "text", "id": "row_2_note", "label": "Row 2 note", "default": "Helps you focus without needing active noise cancellation." },
    { "type": "checkbox", "id": "row_2_wave", "label": "Row 2 Wave", "default": true },
    { "type": "checkbox", "id": "row_2_alt_one", "label": "Row 2 alternative 1", "default": false },
    { "type": "checkbox", "id": "row_2_alt_two", "label": "Row 2 alternative 2", "default": false },
    { "type": "checkbox", "id": "row_2_alt_three", "label": "Row 2 alternative 3", "default": true },
    { "type": "checkbox", "id": "row_2_mobile_other", "label": "Row 2 mobile comparison", "default": false },

    { "type": "text", "id": "row_3_name", "label": "Row 3 title", "default": "Secure fit for long sessions" },
    { "type": "text", "id": "row_3_note", "label": "Row 3 note", "default": "Comfort that stays stable during practice and stage movement." },
    { "type": "checkbox", "id": "row_3_wave", "label": "Row 3 Wave", "default": true },
