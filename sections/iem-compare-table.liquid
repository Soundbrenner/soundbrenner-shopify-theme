    { "type": "checkbox", "id": "row_3_alt_two", "label": "Row 3 alternative 2", "default": false },
    { "type": "checkbox", "id": "row_3_alt_three", "label": "Row 3 alternative 3", "default": true },
    { "type": "checkbox", "id": "row_3_mobile_other", "label": "Row 3 mobile comparison", "default": false },

    { "type": "text", "id": "row_4_name", "label": "Row 4 title", "default": "No charging. No pairing." },
    { "type": "text", "id": "row_4_note", "label": "Row 4 note", "default": "Just plug in and start playing." },
    { "type": "checkbox", "id": "row_4_wave", "label": "Row 4 Wave", "default": true },
    { "type": "checkbox", "id": "row_4_alt_one", "label": "Row 4 alternative 1", "default": false },
    { "type": "checkbox", "id": "row_4_alt_two", "label": "Row 4 alternative 2", "default": false },
    { "type": "checkbox", "id": "row_4_alt_three", "label": "Row 4 alternative 3", "default": true },
    { "type": "checkbox", "id": "row_4_mobile_other", "label": "Row 4 mobile comparison", "default": false },

    { "type": "text", "id": "row_5_name", "label": "Row 5 title", "default": "Musician-first value" },
    { "type": "text", "id": "row_5_note", "label": "Row 5 note", "default": "Serious monitoring benefits without jumping to ultra-premium pricing." },
    { "type": "checkbox", "id": "row_5_wave", "label": "Row 5 Wave", "default": true },
    { "type": "checkbox", "id": "row_5_alt_one", "label": "Row 5 alternative 1", "default": false },
    { "type": "checkbox", "id": "row_5_alt_two", "label": "Row 5 alternative 2", "default": false },
