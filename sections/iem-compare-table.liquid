        <div class="sb-iem-compare-table__mobile-status-cell sb-iem-compare-table__mobile-status-cell--wave" role="cell">
          <span class="sb-iem-compare-table__status {% if section.settings.row_5_wave %}sb-iem-compare-table__status--yes{% else %}sb-iem-compare-table__status--no{% endif %}" aria-label="{{ section.settings.mobile_wave_label }}: {% if section.settings.row_5_wave %}Yes{% else %}No{% endif %}">{% if section.settings.row_5_wave %}{{ sb_iem_compare_table_yes_icon }}{% else %}{{ sb_iem_compare_table_no_icon }}{% endif %}</span>
        </div>
        <div class="sb-iem-compare-table__mobile-status-cell" role="cell">
          <span class="sb-iem-compare-table__status {% if section.settings.row_5_mobile_other %}sb-iem-compare-table__status--yes{% else %}sb-iem-compare-table__status--no{% endif %}" aria-label="{{ mobile_other_label }}: {% if section.settings.row_5_mobile_other %}Yes{% else %}No{% endif %}">{% if section.settings.row_5_mobile_other %}{{ sb_iem_compare_table_yes_icon }}{% else %}{{ sb_iem_compare_table_no_icon }}{% endif %}</span>
        </div>
      </div>
    </div>
  </div>

  <div class="sb-iem-compare-table__cta">
    {% render 'radiant-button',
      label: cta_label,
      link: cta_link,
      size: 'large',
      icon_position: 'trailing',
      extra_class: 'sb-iem-compare-table__cta-button'
    %}
  </div>
</section>

{% stylesheet %}
  .sb-iem-compare-table {
    --sb-iem-compare-table-muted-text: var(--sb-light-neutral-600);

    display: flex;
    flex-direction: column;
    gap: 56px;
    width: 100%;
  }

  .sb-iem-compare-table__header {
    display: flex;
    flex-direction: column;
    gap: var(--sb-space-12);
    margin: 0;
    max-width: 760px;
    text-align: left;
  }

  .sb-iem-compare-table__eyebrow,
  .sb-iem-compare-table__title,
  .sb-iem-compare-table__subtitle,
  .sb-iem-compare-table__product-name,
  .sb-iem-compare-table__product-note,
  .sb-iem-compare-table__feature-name,
  .sb-iem-compare-table__feature-note {
    margin: 0;
  }

  .sb-iem-compare-table__eyebrow {
    color: var(--sb-color-primary-500);
    text-transform: uppercase;
  }

  .sb-iem-compare-table__title,
  .sb-iem-compare-table__subtitle {
    color: var(--sb-color-neutral-900);
  }

  .sb-iem-compare-table__subtitle {
    margin-inline: 0;
    max-width: 620px;
  }

  .sb-iem-compare-table__cta {
    margin-inline: auto;
    width: min(100%, 420px);
  }

  .sb-iem-compare-table__cta-button {
    justify-content: center;
    width: 100%;
  }

  .sb-iem-compare-table__frame {
    background: var(--sb-color-always-black);
    border: 1px solid var(--sb-color-neutral-700);
    border-radius: var(--sb-space-24);
    box-shadow: 0 0 10px 0 var(--sb-color-always-black-12);
    overflow: hidden;
  }

  .sb-iem-compare-table__mobile {
    display: none;
  }

  .sb-iem-compare-table__scroll {
    overflow-x: auto;
    width: 100%;
  }

  .sb-iem-compare-table__scroll:focus-visible {
    outline: 2px solid var(--sb-color-primary-500);
    outline-offset: 4px;
  }

  .sb-iem-compare-table__table {
    background: var(--sb-color-always-black);
    display: grid;
    grid-template-columns: minmax(220px, 1.35fr) repeat(4, minmax(156px, 1fr));
    min-width: 920px;
  }

  .sb-iem-compare-table__cell {
    align-items: center;
    background: var(--sb-color-always-black) !important;
    border-right: 1px solid var(--sb-color-neutral-700);
    border-top: 1px solid var(--sb-color-neutral-700);
    color: var(--sb-color-neutral-100);
    display: flex;
    justify-content: center;
    min-height: 94px;
    padding: var(--sb-space-20);
    position: relative;
  }

  .sb-iem-compare-table__cell:nth-child(5n) {
    border-right: 0;
  }

  .sb-iem-compare-table__cell--corner,
  .sb-iem-compare-table__cell--product {
    background: var(--sb-color-always-black) !important;
    border-top: 0;
    min-height: 208px;
  }

  .sb-iem-compare-table__cell--corner {
    background: var(--sb-color-always-black) !important;
    border-right-color: var(--sb-color-neutral-700);
    justify-content: center;
    padding: 32px;
  }

  .sb-iem-compare-table__cell--product {
    align-items: center;
    color: var(--sb-color-neutral-100);
    flex-direction: column;
    gap: 14px;
    justify-content: flex-start;
    padding: 72px 28px 32px;
    text-align: center;
  }

  .sb-iem-compare-table__cell--product.sb-iem-compare-table__cell--wave {
    background: transparent !important;
    border-left: 1px solid var(--sb-color-primary-500);
    border-right-color: var(--sb-color-primary-500);
    color: var(--sb-color-always-white);
  }

  .sb-iem-compare-table__cell--product.sb-iem-compare-table__cell--wave .sb-iem-compare-table__badge {
    left: 50%;
    position: absolute;
    top: 22px;
    transform: translateX(-50%);
  }

  .sb-iem-compare-table__cell--label {
    align-items: center;
    background: var(--sb-color-always-black) !important;
    justify-content: center;
    position: sticky;
    left: 0;
    text-align: center;
    z-index: 1;
  }

  .sb-iem-compare-table__cell--wave {
    background: transparent !important;
    border-left: 1px solid var(--sb-color-primary-500);
    border-right-color: var(--sb-color-primary-500);
    border-top-color: var(--sb-color-primary-500);
    overflow: hidden;
  }

  .sb-iem-compare-table__cell--wave::before {
    background: rgba(0, 201, 183, 0.14);
    content: '';
    inset: 0;
    pointer-events: none;
    position: absolute;
  }

  .sb-iem-compare-table__cell--product.sb-iem-compare-table__cell--wave::before {
    background: linear-gradient(180deg, var(--sb-color-primary-500) 0%, var(--sb-color-primary-700) 100%);
    border-top: 0;
  }

  .sb-iem-compare-table__cell--wave:nth-last-child(4) {
    border-bottom: 1px solid var(--sb-color-primary-500);
  }

  .sb-iem-compare-table__cell > * {
    position: relative;
    z-index: 1;
  }

  .sb-iem-compare-table__cell--icon {
    padding: var(--sb-space-16);
  }

  .sb-iem-compare-table__label-copy {
    display: flex;
    flex-direction: column;
    gap: var(--sb-space-6);
    text-align: center;
  }

  .sb-iem-compare-table__feature-note,
  .sb-iem-compare-table__product-note {
    color: var(--sb-iem-compare-table-muted-text);
  }

  .sb-iem-compare-table__feature-name,
  .sb-iem-compare-table__product-name {
    color: var(--sb-color-always-white);
  }

  .sb-iem-compare-table__corner-logo {
    color: var(--sb-color-always-white);
    display: inline-flex;
    max-width: 220px;
    width: 100%;
  }

  .sb-iem-compare-table__corner-logo svg {
    display: block;
    height: auto;
    width: 100%;
  }

  .sb-iem-compare-table__corner-logo svg path:not([fill='none']) {
    fill: currentColor !important;
  }

  .sb-iem-compare-table__badge {
    background: rgba(255, 255, 255, 0.18);
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 999px;
    color: var(--sb-color-always-white);
    display: inline-flex;
    padding: 6px 12px;
  }

  .sb-iem-compare-table__status {
    align-items: center;
    border-radius: 999px;
    display: inline-flex;
    height: 44px;
    justify-content: center;
    width: 44px;
  }

  .sb-iem-compare-table__status img {
    display: block;
    height: 18px;
    width: 18px;
  }

  .sb-iem-compare-table__status--yes {
    background: var(--sb-color-primary-500);
    color: var(--sb-color-always-white);
  }

  .sb-iem-compare-table__status--no {
    background: var(--sb-color-neutral-400);
    color: var(--sb-color-neutral-800);
  }

  @media screen and (max-width: 989px) {
    .sb-iem-compare-table {
      gap: 40px;
    }

    .sb-iem-compare-table__frame {
      border-radius: var(--sb-space-20);
    }

    .sb-iem-compare-table__table {
      grid-template-columns: minmax(210px, 1.2fr) repeat(4, minmax(144px, 1fr));
      min-width: 860px;
    }

    .sb-iem-compare-table__cell {
      min-height: 88px;
      padding: var(--sb-space-16);
    }

    .sb-iem-compare-table__cell--corner,
    .sb-iem-compare-table__cell--product {
      min-height: 176px;
    }

    .sb-iem-compare-table__cell--corner {
      padding: 24px;
    }

    .sb-iem-compare-table__cell--product {
      gap: 12px;
      padding: 60px 20px 24px;
    }

    .sb-iem-compare-table__cell--product.sb-iem-compare-table__cell--wave .sb-iem-compare-table__badge {
      left: 50%;
      top: 18px;
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 749px) {
    .sb-iem-compare-table {
      gap: 28px;
    }

    .sb-iem-compare-table__cta {
      width: 100%;
    }

    .sb-iem-compare-table__frame {
      display: none;
    }

    .sb-iem-compare-table__mobile {
      background: var(--sb-color-always-black);
      border: 1px solid var(--sb-color-neutral-700);
      border-radius: 24px;
      color: var(--sb-color-always-white);
      display: block;
      overflow: hidden;
    }

    .sb-iem-compare-table__mobile-table {
      display: grid;
      grid-template-columns: minmax(0, 1.7fr) minmax(72px, 0.7fr) minmax(72px, 0.7fr);
      min-width: 0;
      width: 100%;
    }

    .sb-iem-compare-table__mobile-row {
      display: contents;
    }

    .sb-iem-compare-table__mobile-head,
    .sb-iem-compare-table__mobile-benefit,
    .sb-iem-compare-table__mobile-status-cell {
      background: var(--sb-color-always-black);
      border-left: 0;
      border-right: 1px solid var(--sb-color-neutral-700);
      border-top: 1px solid var(--sb-color-neutral-700);
      min-width: 0;
    }

    .sb-iem-compare-table__mobile-head {
      align-items: center;
      color: var(--sb-iem-compare-table-muted-text);
      display: flex;
      min-height: 56px;
      padding: 12px 14px;
    }

    .sb-iem-compare-table__mobile-head--benefit {
      justify-content: flex-start;
    }

    .sb-iem-compare-table__mobile-logo {
      color: var(--sb-color-always-white);
      display: inline-flex;
      max-width: 100%;
      width: 100%;
    }

    .sb-iem-compare-table__mobile-logo svg {
      display: block;
      height: auto;
      max-width: 132px;
      width: 100%;
    }

    .sb-iem-compare-table__mobile-logo svg path:not([fill='none']) {
      fill: currentColor !important;
    }

    .sb-iem-compare-table__mobile-head--wave {
      background: var(--sb-color-primary-500-25);
      border-right-color: var(--sb-color-primary-500);
      color: var(--sb-color-always-white);
      justify-content: center;
    }

    .sb-iem-compare-table__mobile-head:last-child {
      border-right: 0;
      justify-content: center;
    }

    .sb-iem-compare-table__mobile-benefit {
      align-items: center;
      color: var(--sb-color-always-white);
      display: flex;
      line-height: 1.35;
      padding: 16px 14px;
    }

    .sb-iem-compare-table__mobile-status-cell {
      align-items: center;
      display: flex;
      justify-content: center;
      padding: 12px 8px;
    }

    .sb-iem-compare-table__mobile-status-cell--wave {
      background: var(--sb-color-primary-500-25);
      border-right-color: var(--sb-color-primary-500);
    }

    .sb-iem-compare-table__mobile-status-cell:last-child {
      border-right: 0;
    }

    .sb-iem-compare-table__mobile-row--head .sb-iem-compare-table__mobile-head {
      border-top: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "IEM compare table",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Compare your options" },
    { "type": "text", "id": "title", "label": "Title", "default": "Why Wave is the right first step" },
    { "type": "text", "id": "table_aria_label", "label": "Desktop aria label", "default": "Comparison table for Wave and alternative listening options" },
    { "type": "text", "id": "mobile_aria_label", "label": "Mobile aria label", "default": "Comparison table for Wave and the rest" },
    { "type": "text", "id": "wave_badge", "label": "Wave badge", "default": "Best fit for musicians" },
    { "type": "text", "id": "wave_name", "label": "Wave heading", "default": "Soundbrenner Wave IEMs" },
