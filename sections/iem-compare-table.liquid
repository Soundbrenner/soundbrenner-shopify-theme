{% capture sb_iem_compare_table_yes_icon %}
  <img
    src="https://cdn.shopify.com/s/files/1/1306/4847/files/check.svg?v=1774512519"
    alt=""
    loading="lazy"
    width="18"
    height="18"
  >
{% endcapture %}
{% capture sb_iem_compare_table_no_icon %}
