      border: 0;
      border-radius: 999px;
      cursor: pointer;
      height: 8px;
      padding: 0;
      transition: none;
      width: 8px;
    }

    .sb-iem-compare-table__mobile-feature-dot.is-active {
      background: var(--sb-color-primary-500);
