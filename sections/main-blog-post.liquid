{% javascript %}
  (() => {
    const root = document.querySelector('.sb-blog-post');
    if (!root) return;
    const affiliateAnnouncementCookieName = 'sb_affiliate_announcement_state';

    const sidebarStacks = Array.from(root.querySelectorAll('[data-sb-blog-post-sidebar-stack]'));
    const affiliatePromoBoxes = Array.from(root.querySelectorAll('[data-sidebar-promo-affiliate="true"]'));

    const readCookie = (name) => {
      const cookieSource = `${document.cookie || ''}`;
      if (!cookieSource) return '';
      const cookieParts = cookieSource.split(';');
      for (const cookiePart of cookieParts) {
        const trimmedPart = cookiePart.trim();
        if (!trimmedPart.startsWith(`${name}=`)) continue;
        return trimmedPart.slice(name.length + 1);
      }
      return '';
    };

    const parseJson = (value) => {
      try {
        return JSON.parse(value);
      } catch (_) {
        return null;
      }
    };

    const normalizeAffiliateState = (rawState) => {
      if (!rawState || typeof rawState !== 'object') return null;
      const discountCode = `${rawState.discountCode || ''}`.trim();
      const affiliateName = `${rawState.affiliateName || discountCode}`.trim();
      const expiresAt = Number.parseInt(`${rawState.expiresAt || ''}`, 10);
      if (!discountCode || !affiliateName || !Number.isFinite(expiresAt) || expiresAt <= Date.now()) return null;
      return {
        discountCode,
        affiliateName,
      };
    };

    const getAffiliateState = () => {
      const prefetched = normalizeAffiliateState(window.SBAffiliateAnnouncementState);
      if (prefetched) return prefetched;

      const rawCookieValue = readCookie(affiliateAnnouncementCookieName);
      if (!rawCookieValue) return null;
      const decodedCookieValue = (() => {
        try {
          return decodeURIComponent(rawCookieValue);
        } catch (_) {
          return rawCookieValue;
        }
      })();
      return normalizeAffiliateState(parseJson(decodedCookieValue));
    };

    const replaceToken = (input, token, replacement) => {
      const source = `${input || ''}`;
      const target = `${token || ''}`;
      if (!target) return source;
      return source.split(target).join(`${replacement || ''}`);
    };

    const resolvePromoFreeShippingThresholdDisplay = (promoBox) => {
      if (!(promoBox instanceof HTMLElement)) return '';
      const fallbackDisplay = `${promoBox.dataset.freeShippingThresholdDisplay || ''}`;
      const thresholdCents = Number.parseInt(`${promoBox.dataset.freeShippingThresholdCents || ''}`, 10);
      const currencyCode = `${promoBox.dataset.currency || ''}`.trim().toUpperCase();
      if (!Number.isFinite(thresholdCents) || thresholdCents <= 0) return fallbackDisplay;

      const storefrontPricing = window.SBStorefrontPricing || null;
      if (storefrontPricing && typeof storefrontPricing.formatMoney === 'function') {
        const formatted = storefrontPricing.formatMoney(thresholdCents, currencyCode, { context: 'storefront' });
        if (`${formatted || ''}`.trim() !== '') {
          promoBox.dataset.freeShippingThresholdDisplay = formatted;
          return formatted;
        }
      }

      return fallbackDisplay;
    };

    const resolvePromoTemplate = (promoBox, templateValue, state) => {
      let resolved = `${templateValue || ''}`;
      resolved = replaceToken(resolved, promoBox.dataset.affiliateNameToken || '', state.affiliateName);
      resolved = replaceToken(resolved, promoBox.dataset.saleNameToken || '', state.affiliateName);
      resolved = replaceToken(resolved, promoBox.dataset.sitewideDiscountToken || '', promoBox.dataset.affiliateDiscountDepth || '');
      resolved = replaceToken(resolved, promoBox.dataset.shippingCountryToken || '', promoBox.dataset.shippingCountryName || '');
      resolved = replaceToken(
        resolved,
        promoBox.dataset.freeShippingThresholdToken || '',
        resolvePromoFreeShippingThresholdDisplay(promoBox)
      );
      return resolved.trim();
    };

    const syncDefaultPromoThresholdDisplay = () => {
      affiliatePromoBoxes.forEach((promoBox) => {
        if (!(promoBox instanceof HTMLElement)) return;
        const textElement = promoBox.querySelector('[data-sidebar-promo-text]');
        if (!(textElement instanceof HTMLElement)) return;

        const currentThresholdDisplay = `${promoBox.dataset.freeShippingThresholdDisplay || ''}`;
        const formattedThresholdDisplay = resolvePromoFreeShippingThresholdDisplay(promoBox);
        if (!currentThresholdDisplay || !formattedThresholdDisplay || currentThresholdDisplay === formattedThresholdDisplay) return;

        const currentText = `${textElement.textContent || ''}`;
        if (!currentText.includes(currentThresholdDisplay)) return;
        textElement.textContent = currentText.split(currentThresholdDisplay).join(formattedThresholdDisplay);
      });
    };

    const applyAffiliatePromoState = (state) => {
      if (!state || !affiliatePromoBoxes.length) return;

      affiliatePromoBoxes.forEach((promoBox) => {
        if (!(promoBox instanceof HTMLElement)) return;
        const nextSignature = `${state.discountCode}:${state.affiliateName}`;
        if (promoBox.dataset.sidebarPromoAffiliateSignature === nextSignature) return;
        promoBox.dataset.sidebarPromoAffiliateSignature = nextSignature;

        const titleElement = promoBox.querySelector('[data-sidebar-promo-title]');
        const textElement = promoBox.querySelector('[data-sidebar-promo-text]');
        const buttonLabelElement = promoBox.querySelector('[data-sidebar-promo-button-label]');

        const resolvedTitle = resolvePromoTemplate(promoBox, promoBox.dataset.sidebarPromoAffiliateTitleTemplate || '', state);
        if (resolvedTitle && titleElement) {
          titleElement.textContent = resolvedTitle;
          promoBox.setAttribute('aria-label', resolvedTitle);
        }

        const resolvedText = resolvePromoTemplate(promoBox, promoBox.dataset.sidebarPromoTextTemplate || '', state);
        if (resolvedText && textElement) {
          textElement.textContent = resolvedText;
        }

        const resolvedButtonLabel = resolvePromoTemplate(promoBox, promoBox.dataset.sidebarPromoButtonLabelTemplate || '', state);
        if (resolvedButtonLabel && buttonLabelElement) {
          buttonLabelElement.textContent = resolvedButtonLabel;
        }
      });
    };

    syncDefaultPromoThresholdDisplay();
    applyAffiliatePromoState(getAffiliateState());

    const applySidebarLayout = () => {
      const parseSpaceVar = (name, fallback) => {
        const rawValue = getComputedStyle(document.documentElement).getPropertyValue(name).trim();
        const parsed = Number.parseFloat(rawValue);
        return Number.isFinite(parsed) ? parsed : fallback;
      };

      const gap = parseSpaceVar('--sb-space-36', 36);
      const isMobileViewport = window.matchMedia('(max-width: 989px)').matches;
      const topAccessoryBarWrap = document.querySelector('.sb-blog-top-sticky-accessory-bar .sb-blog-overview__sticky-nav-wrap--desktop');
      const stickyTop =
        !isMobileViewport && topAccessoryBarWrap && window.getComputedStyle(topAccessoryBarWrap).display !== 'none'
          ? Math.max(Math.ceil(topAccessoryBarWrap.getBoundingClientRect().bottom + gap), 0)
          : 112;

      sidebarStacks.forEach((stack) => {
        const cards = Array.from(stack.querySelectorAll('[data-sb-blog-post-sidebar-sticky-card]'));
        const phaseOne = stack.querySelector('[data-sb-blog-post-sidebar-phase-1]');
        if (!phaseOne) return;
        phaseOne.style.height = '';

        cards.forEach((card) => {
          card.style.top = `${stickyTop}px`;
        });

        if (!cards.length || isMobileViewport) return;
        phaseOne.style.height = '100%';
      });
    };

    let frameRequested = false;
    const requestLayoutUpdate = () => {
      if (frameRequested) return;
      frameRequested = true;
      window.requestAnimationFrame(() => {
        frameRequested = false;
        applySidebarLayout();
      });
    };

    window.addEventListener('resize', requestLayoutUpdate);
    window.addEventListener('scroll', requestLayoutUpdate, { passive: true });
    window.addEventListener('load', requestLayoutUpdate);
    document.addEventListener('sb:cart-drawer:state-change', requestLayoutUpdate);

    if ('ResizeObserver' in window) {
      const observer = new ResizeObserver(requestLayoutUpdate);
      observer.observe(document.body);
      sidebarStacks.forEach((stack) => observer.observe(stack));
      const topAccessoryBarWrap = document.querySelector('.sb-blog-top-sticky-accessory-bar .sb-blog-overview__sticky-nav-wrap--desktop');
      if (topAccessoryBarWrap) observer.observe(topAccessoryBarWrap);
    }

    requestLayoutUpdate();
  })();
{% endjavascript %}

