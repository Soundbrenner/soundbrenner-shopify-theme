{% liquid
  assign article_category_tag = blank
  assign article_fallback_tag = blank
  for tag in article.tags
    assign normalized_tag = tag | downcase
    if normalized_tag contains 'by_product' or normalized_tag contains 'by_instrument'
      assign article_category_tag = tag
      break
    elsif article_fallback_tag == blank
      assign article_fallback_tag = tag
    endif
  endfor
  if article_category_tag == blank and article_fallback_tag != blank
    assign article_category_tag = article_fallback_tag
  endif
  capture article_category_text
    render 'sb-blog-tag-label', tag: article_category_tag, blog_title: blog.title
  endcapture
  assign article_category_text = article_category_text | strip

  assign article_plain_text = article.content | strip_html | replace: '&nbsp;', ' ' | replace: '&#160;', ' ' | strip
  assign article_word_count = article_plain_text | split: ' ' | size
  assign article_read_duration_minutes = article_word_count | plus: 219 | divided_by: 220
  if article_read_duration_minutes < 1
    assign article_read_duration_minutes = 1
  endif
  assign article_read_duration_text = article_read_duration_minutes | append: ''
  assign article_excerpt_text = article.excerpt | strip_html | strip
  assign article_published_day = article.published_at | date: '%Y-%m-%d'
  assign article_updated_day = article.updated_at | date: '%Y-%m-%d'
  assign article_publish_date_text = article.published_at | date: format: 'abbreviated_date'
  assign article_updated_date_text = article.updated_at | date: format: 'abbreviated_date'
  assign show_article_updated_date = false
  if article.updated_at != blank and article_updated_day != article_published_day
    assign show_article_updated_date = true
  endif

  assign is_comparison_article = false
  assign comparison_product_handle = blank
  assign comparison_product = blank
  assign comparison_product_name = blank
  assign comparison_product_url = blank
  assign comparison_product_rating = 0
  assign comparison_product_reviews_count = 0
  assign comparison_product_has_reviews = false
  if article.handle contains '-vs-' and article.handle != 'soundbrenner-wave-vs-soundbrenner-wave-pro'
    assign is_comparison_article = true
    if article.handle contains 'soundbrenner-wave-pro'
      assign comparison_product_handle = 'wave-pro-in-ear-monitors'
    elsif article.handle contains 'soundbrenner-wave'
      assign comparison_product_handle = 'wave-in-ear-monitors'
    endif

    if comparison_product_handle != blank
      assign comparison_product = all_products[comparison_product_handle]
    endif

    if comparison_product != blank
      assign comparison_product_name = comparison_product.title
      assign comparison_product_url = comparison_product.url
      if comparison_product.metafields.reviews.rating.value != blank
        assign comparison_rating_source = comparison_product.metafields.reviews.rating.value
        assign comparison_product_rating = comparison_rating_source.rating | default: comparison_rating_source | plus: 0
      endif
      assign comparison_product_reviews_count = comparison_product.metafields.reviews.rating_count.value | default: 0 | plus: 0 | round: 0
      if comparison_product_rating > 0 and comparison_product_reviews_count > 0
        assign comparison_product_has_reviews = true
      endif
    endif
  endif

  assign seasonal_sale_name = settings.seasonal_sale_name | strip
  assign sale_name_token = '{{ Sale name }}'
  assign sitewide_discount_depth_token = '{{ Sitewide discount depth }}'
  assign shipping_country_token = '{{ Shipping country }}'
  assign free_shipping_threshold_token = '{{ Free shipping threshold }}'
  assign affiliate_name_token = '{{ Affiliate name }}'
  assign sitewide_seasonal_discount_depth = settings.sitewide_seasonal_discount_depth | default: 48 | strip
  assign sitewide_affiliate_discount_depth = settings.sitewide_affiliate_discount_depth | default: 20 | strip
  assign sidebar_shipping_country_fallback = 'sb.cart.your_country' | t
  assign sidebar_shipping_country_name = localization.country.name | default: localization.country.iso_code | default: sidebar_shipping_country_fallback
  assign sidebar_shipping_country_iso = localization.country.iso_code | upcase | strip
  assign sidebar_shipping_country_handle = sidebar_shipping_country_iso | downcase
  assign sidebar_shipping_is_blocked = false
  assign sidebar_shipping_has_free_shipping = false
  assign sidebar_free_shipping_threshold_display = ''
  assign sidebar_shipping_entry = shop.metaobjects['database_localized_shipping_info'][sidebar_shipping_country_handle]
  if sidebar_shipping_entry != blank and sidebar_shipping_country_iso != blank
    assign sidebar_entry_ship_to = sidebar_shipping_entry.ship_to_it.value | default: sidebar_shipping_entry.ship_to_it | append: '' | downcase
    assign sidebar_entry_has_free_shipping = sidebar_shipping_entry.free_shipping_available.value | default: sidebar_shipping_entry.free_shipping_available | append: '' | downcase
    assign sidebar_entry_threshold = sidebar_shipping_entry.free_shipping_threshold_in_local_currency.value | default: sidebar_shipping_entry.free_shipping_threshold_in_local_currency

    if sidebar_entry_ship_to == 'false' or sidebar_entry_ship_to == '0' or sidebar_entry_ship_to == 'no'
      assign sidebar_shipping_is_blocked = true
    endif
    if sidebar_entry_has_free_shipping == 'true' or sidebar_entry_has_free_shipping == '1' or sidebar_entry_has_free_shipping == 'yes'
      assign sidebar_shipping_has_free_shipping = true
    endif
    if sidebar_entry_threshold != blank
      assign sidebar_entry_threshold_cents = sidebar_entry_threshold | times: 100
      capture sidebar_free_shipping_threshold_display
        render 'sb-money-no-decimals', amount: sidebar_entry_threshold_cents, currency: cart.currency.iso_code | default: localization.country.currency.iso_code | default: shop.currency, context: 'storefront'
      endcapture
      assign sidebar_free_shipping_threshold_display = sidebar_free_shipping_threshold_display | strip
    endif
  endif

  assign sidebar_promo_title_template = settings.seasonal_hero_headline | strip
  assign sidebar_promo_affiliate_title_template = 'sb.hero_card.affiliate_headline' | t
  assign sidebar_promo_text_free_shipping = settings.seasonal_hero_subheadline_free_shipping | strip
  assign sidebar_promo_text_no_free_shipping = settings.seasonal_hero_subheadline_no_free_shipping | strip
  assign sidebar_promo_text_blocked = settings.seasonal_hero_subheadline_blocked | strip
  if sidebar_shipping_is_blocked
    assign sidebar_promo_text_template = sidebar_promo_text_blocked
  elsif sidebar_shipping_has_free_shipping
    assign sidebar_promo_text_template = sidebar_promo_text_free_shipping
  else
    assign sidebar_promo_text_template = sidebar_promo_text_no_free_shipping
  endif
  assign sidebar_promo_button_label_template = settings.seasonal_hero_button_label | strip
  assign sidebar_promo_button_link = settings.seasonal_hero_button_link

  assign sidebar_promo_title = sidebar_promo_title_template
  assign sidebar_promo_text = sidebar_promo_text_template
  assign sidebar_promo_button_label = sidebar_promo_button_label_template

  assign sidebar_promo_title = sidebar_promo_title | replace: sale_name_token, seasonal_sale_name
  assign sidebar_promo_text = sidebar_promo_text | replace: sale_name_token, seasonal_sale_name
  assign sidebar_promo_text = sidebar_promo_text | replace: sitewide_discount_depth_token, sitewide_seasonal_discount_depth
  assign sidebar_promo_text = sidebar_promo_text | replace: shipping_country_token, sidebar_shipping_country_name
  assign sidebar_promo_text = sidebar_promo_text | replace: free_shipping_threshold_token, sidebar_free_shipping_threshold_display
  assign sidebar_promo_button_label = sidebar_promo_button_label | replace: sale_name_token, seasonal_sale_name
%}

{% liquid
  assign read_next_count = 0
%}
{% capture read_next_cards_markup %}
  {% for related_article in blog.articles %}
    {% if related_article.id == article.id %}
      {% continue %}
    {% endif %}
    {% if read_next_count >= 3 %}
      {% break %}
    {% endif %}
    {%
      render 'sb-blog-overview-article-card',
      article: related_article,
      blog_title: blog.title,
      card_class: 'sb-blog-overview-card--archive'
    %}
    {% assign read_next_count = read_next_count | plus: 1 %}
  {% endfor %}
{% endcapture %}

<section class="sb-blog-post">
  <div class="sb-blog-post__inner">
    {% liquid
      assign sidebar_promo_aria_label = sidebar_promo_title | strip
      if sidebar_promo_aria_label == blank
        assign sidebar_promo_aria_label = 'sb.blog.sidebar_promo' | t
      endif
    %}

    {% capture sidebar_promo_markup %}
      {% if sidebar_promo_title != blank or sidebar_promo_text != blank or sidebar_promo_button_label != blank %}
        <section
          class="sb-blog-sidebar-box sb-blog-sidebar-box--promo"
          aria-label="{{ sidebar_promo_aria_label }}"
          data-sidebar-promo-affiliate="true"
          data-sidebar-promo-affiliate-title-template="{{ sidebar_promo_affiliate_title_template | escape }}"
          data-sidebar-promo-text-template="{{ sidebar_promo_text_template | escape }}"
          data-sidebar-promo-button-label-template="{{ sidebar_promo_button_label_template | escape }}"
          data-sale-name-token="{{ sale_name_token | escape }}"
          data-sitewide-discount-token="{{ sitewide_discount_depth_token | escape }}"
          data-shipping-country-token="{{ shipping_country_token | escape }}"
          data-free-shipping-threshold-token="{{ free_shipping_threshold_token | escape }}"
          data-free-shipping-threshold-cents="{{ sidebar_entry_threshold_cents | default: 0 }}"
          data-affiliate-name-token="{{ affiliate_name_token | escape }}"
          data-affiliate-discount-depth="{{ sitewide_affiliate_discount_depth | escape }}"
          data-shipping-country-name="{{ sidebar_shipping_country_name | escape }}"
          data-free-shipping-threshold-display="{{ sidebar_free_shipping_threshold_display | escape }}"
          data-currency="{{ cart.currency.iso_code | default: localization.country.currency.iso_code | default: shop.currency }}"
        >
          {% if sidebar_promo_title != blank %}
            <h3 class="sb-blog-sidebar-box__promo-title font-callout weight-bold" data-sidebar-promo-title>{{ sidebar_promo_title }}</h3>
          {% endif %}

          {% if sidebar_promo_text != blank %}
            <p
              class="sb-blog-sidebar-box__promo-text font-body weight-regular"
              data-sidebar-promo-text
            >
              {{ sidebar_promo_text }}
            </p>
            <script>
              (() => {
                const promoBox = document.currentScript && document.currentScript.closest('[data-sidebar-promo-affiliate="true"]');
                const textElement = promoBox && promoBox.querySelector('[data-sidebar-promo-text]');
                if (!(promoBox instanceof HTMLElement) || !(textElement instanceof HTMLElement)) return;

                const thresholdToken = `${promoBox.dataset.freeShippingThresholdToken || ''}`;
                const fallbackThresholdDisplay = `${promoBox.dataset.freeShippingThresholdDisplay || ''}`;
                const thresholdCents = Number.parseInt(`${promoBox.dataset.freeShippingThresholdCents || ''}`, 10);
                const currencyCode = `${promoBox.dataset.currency || ''}`.trim().toUpperCase();

                let thresholdDisplay = fallbackThresholdDisplay;
                const storefrontPricing = window.SBStorefrontPricing || null;
                if (
                  Number.isFinite(thresholdCents)
                  && thresholdCents > 0
                  && storefrontPricing
                  && typeof storefrontPricing.formatMoney === 'function'
                ) {
                  const formattedThreshold = storefrontPricing.formatMoney(thresholdCents, currencyCode, { context: 'storefront' });
                  if (`${formattedThreshold || ''}`.trim() !== '') {
                    thresholdDisplay = formattedThreshold;
                  }
                }

                if (!thresholdDisplay) return;
                promoBox.dataset.freeShippingThresholdDisplay = thresholdDisplay;

                const currentText = `${textElement.textContent || ''}`;
                if (
                  thresholdToken
                  && currentText.includes(thresholdToken)
                ) {
                  textElement.textContent = currentText.split(thresholdToken).join(thresholdDisplay);
                  return;
                }

                if (
                  fallbackThresholdDisplay
                  && fallbackThresholdDisplay !== thresholdDisplay
                  && currentText.includes(fallbackThresholdDisplay)
                ) {
                  textElement.textContent = currentText.split(fallbackThresholdDisplay).join(thresholdDisplay);
                }
              })();
            </script>
          {% endif %}

          {% if sidebar_promo_button_label != blank and sidebar_promo_button_link != blank %}
            <a class="sb-blog-sidebar-box__promo-button font-caption weight-bold" href="{{ sidebar_promo_button_link }}">
              <span data-sidebar-promo-button-label>{{ sidebar_promo_button_label }}</span>
            </a>
          {% elsif sidebar_promo_button_label != blank %}
            <span class="sb-blog-sidebar-box__promo-button font-caption weight-bold">
              <span data-sidebar-promo-button-label>{{ sidebar_promo_button_label }}</span>
            </span>
          {% endif %}
        </section>
      {% endif %}
    {% endcapture %}

    <header class="sb-blog-post__header{% if article.image != blank %} sb-blog-post__header--with-media{% else %} sb-blog-post__header--without-media{% endif %}">
      <p class="sb-blog-post__meta-item font-caption weight-regular">{{ article_category_text }}</p>
      <p class="sb-blog-post__meta-item font-caption weight-regular">
        {{ article_publish_date_text }}{% if show_article_updated_date %} {{ 'sb.blog.article_updated_date' | t: date: article_updated_date_text }}{% endif %}
      </p>
      {% if article_read_duration_text != blank %}
        <p class="sb-blog-post__meta-item sb-blog-post__meta-item--read-time font-caption weight-regular">
          {% if article_read_duration_text contains 'min' %}
            {{ article_read_duration_text }}
          {% else %}
            {{ 'sb.blog.min_read' | t: minutes: article_read_duration_text }}
          {% endif %}
        </p>
      {% endif %}
      <h1 class="sb-blog-post__title font-title weight-bold">{{ article.title }}</h1>
      {% if article_excerpt_text != blank %}
        <p class="sb-blog-post__excerpt font-body weight-semibold">{{ article_excerpt_text }}</p>
      {% endif %}
    </header>

    <div class="sb-blog-post__layout">
      <article class="sb-blog-post__main">
        {% if article.image != blank %}
          <figure class="sb-blog-post__media">
            {{
              article.image
              | image_url: width: 1600
              | image_tag:
                widths: '400,800,1200,1600',
                sizes: '(max-width: 989px) calc(100vw - 32px), 800px',
                class: 'sb-blog-post__image',
                loading: 'eager',
                alt: article.title
            }}
          </figure>
          {% if sidebar_promo_markup != blank %}
            <div class="sb-blog-post__mobile-promo" aria-label="{{ sidebar_promo_aria_label }}">
              {{ sidebar_promo_markup }}
            </div>
          {% endif %}
        {% endif %}

        <div class="sb-blog-post__content rte">
          {{ article.content }}
        </div>

        <div class="sb-blog-post__postscript">
          {% if is_comparison_article and comparison_product != blank and comparison_product_url != blank %}
            <section class="sb-blog-post__comparison-cta" aria-label="{{ 'sb.blog.comparison_cta_label' | t: product: comparison_product_name }}">
              <p class="sb-blog-post__comparison-cta-eyebrow font-caption weight-semibold">{{ 'sb.blog.comparison_cta_eyebrow' | t }}</p>
              <h2 class="sb-blog-post__comparison-cta-title font-callout weight-bold">{{ 'sb.blog.comparison_cta_title' | t: product: comparison_product_name }}</h2>
              <p class="sb-blog-post__comparison-cta-body font-body weight-regular">{{ 'sb.blog.comparison_cta_body' | t: product: comparison_product_name }}</p>

              {% if comparison_product_has_reviews %}
                {% liquid
                  assign comparison_product_rating_rounded = comparison_product_rating | round: 1
                  assign comparison_product_rating_text = comparison_product_rating_rounded | append: ''
                  assign comparison_product_reviews_count_text = comparison_product_reviews_count | append: ''
                %}
                <p class="sb-blog-post__comparison-cta-meta font-caption weight-semibold">
                  {{ 'sb.rating.out_of_five_stars' | t: rating: comparison_product_rating_text }}
                  ·
                  {{ 'sb.product.reviews_count' | t: count: comparison_product_reviews_count_text }}
                </p>
              {% endif %}

              <ul class="sb-blog-post__comparison-cta-points">
                <li class="sb-blog-post__comparison-cta-point font-caption weight-semibold">{{ 'sb.value_breakdown.money_back_30_day' | t }}</li>
                <li class="sb-blog-post__comparison-cta-point font-caption weight-semibold">{{ 'sb.product.warranty_1_year' | t }}</li>
                <li class="sb-blog-post__comparison-cta-point font-caption weight-semibold">{{ 'sb.blog.comparison_cta_support' | t }}</li>
              </ul>

              <blockquote class="sb-blog-post__comparison-cta-quote">
                <p class="font-body weight-regular">{{ 'sb.header.mobile_review_text' | t }}</p>
                <footer class="sb-blog-post__comparison-cta-quote-cite font-caption weight-semibold">
                  {{ 'sb.header.mobile_review_name' | t }}
                </footer>
              </blockquote>

              <a class="sb-button-radiant sb-button-radiant--large sb-button-radiant--trailing-icon font-caption weight-bold sb-blog-post__comparison-cta-button" href="{{ comparison_product_url }}">
                <span class="sb-button-radiant__label">{{ 'sb.shogun.view_product_page' | t }}</span>
                <span class="sb-button-radiant__icon" aria-hidden="true">
                  {{ 'arrow-reduced-padding.svg' | inline_asset_content }}
                </span>
              </a>
            </section>
          {% endif %}

          <div class="sb-blog-post__postscript-divider" aria-hidden="true"></div>
          <p class="sb-blog-post__postscript-author font-body weight-bold">{{ 'sb.blog.by_team_soundbrenner' | t }}</p>

          {% assign about_box_content = section.settings.about_box_content %}
          {% assign about_box_default_html = 'sb.blog.about_box_default_html' | t %}
          {% if about_box_content == blank or about_box_content == '<p><strong>About Soundbrenner</strong></p><p>We are on a mission to make music practice addictive.</p><p>Add your links and copy in Theme editor.</p>' %}
            {% assign about_box_content = about_box_default_html %}
          {% endif %}

          {% if about_box_content != blank %}
            <section class="sb-blog-post__about-box rte font-body weight-regular" aria-label="{{ 'sb.blog.about_soundbrenner' | t }}">
              {% render 'localized-richtext-links', content: about_box_content %}
            </section>
          {% endif %}

          {% if read_next_count > 0 %}
            <section class="sb-blog-post__read-next" aria-label="{{ 'sb.blog.read_this_next' | t }}">
              <h2 class="sb-blog-post__read-next-title font-title weight-bold">{{ 'sb.blog.read_this_next' | t }}</h2>
              <div class="sb-blog-post__read-next-list">
                {{ read_next_cards_markup }}
              </div>
            </section>
          {% endif %}
        </div>

        {% if blog.comments_enabled? %}
          <section class="sb-blog-post__comments" id="comments">
            <h2 class="sb-blog-post__comments-title font-callout weight-semibold">
              {{ 'blog.article_comments' | t }}
            </h2>

            {% paginate article.comments by 10 %}
              <div class="sb-blog-post__comment-list">
                {% for comment in article.comments %}
                  <article class="sb-blog-post__comment">
                    <p class="sb-blog-post__comment-content font-caption weight-regular">{{ comment.content }}</p>
                    <p class="sb-blog-post__comment-meta font-caption2 weight-regular">
                      {{ comment.author }} · {{ comment.created_at | date: format: 'abbreviated_date' }}
                    </p>
                  </article>
                {% endfor %}
              </div>
              {% if paginate.pages > 1 %}
                <nav class="sb-blog-post__pagination font-caption weight-regular" aria-label="{{ 'sb.blog.comment_pagination' | t }}">
                  {{ paginate | default_pagination }}
                </nav>
              {% endif %}
            {% endpaginate %}
          </section>
        {% endif %}
      </article>

      {% if sidebar_promo_markup != blank %}
        <aside class="sb-blog-post__sidebar sb-blog-post__sidebar--desktop" aria-label="{{ sidebar_promo_aria_label }}">
          <div class="sb-blog-post__sidebar-stack" data-sb-blog-post-sidebar-stack>
            <div class="sb-blog-post__sidebar-phase sb-blog-post__sidebar-phase--1" data-sb-blog-post-sidebar-phase-1>
              <div class="sb-blog-post__sidebar-card-wrap" data-sb-blog-post-sidebar-sticky-card>
                {{ sidebar_promo_markup }}
              </div>
            </div>
          </div>
        </aside>
      {% endif %}
    </div>
  </div>
</section>

<script type="application/ld+json">
  {{ article | structured_data }}
</script>

{% stylesheet %}
  .sb-blog-post {
    padding: 0;
  }

  .sb-blog-post__inner {
    margin: 0 auto;
    max-width: calc((var(--sb-space-128) * 9) + var(--sb-space-64) + var(--sb-space-24));
    width: 100%;
  }

  .sb-blog-post__layout {
    align-items: start;
    column-gap: var(--sb-space-64);
    display: grid;
    grid-template-columns:
      minmax(0, calc((var(--sb-space-128) * 6) + var(--sb-space-32)))
      calc((var(--sb-space-128) * 2) + var(--sb-space-96) + var(--sb-space-24));
  }

  .sb-blog-post__main {
    min-width: 0;
  }

  .sb-blog-post__sidebar {
    align-self: stretch;
    display: block;
    grid-column: 2;
    grid-row: 1;
    max-width: calc((var(--sb-space-128) * 2) + var(--sb-space-96) + var(--sb-space-24));
    min-width: 0;
    width: 100%;
  }

  .sb-blog-post__sidebar-stack {
    display: block;
    height: 100%;
    overflow: visible;
    position: relative;
  }

  .sb-blog-post__sidebar-phase {
    position: relative;
    width: 100%;
  }

  .sb-blog-post__sidebar-card-wrap {
    overflow: visible;
    position: sticky;
    top: 112px;
  }

  .sb-blog-post__sidebar-phase--1 .sb-blog-post__sidebar-card-wrap {
    z-index: 1;
  }

  .sb-blog-post__header {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 0;
    max-width: calc((var(--sb-space-128) * 6) + var(--sb-space-32));
    width: 100%;
  }

  .sb-blog-post__header--with-media {
    margin-bottom: 24px;
  }

  .sb-blog-post__header--without-media {
    margin-bottom: 30px;
  }

  .sb-blog-post__meta-item {
    color: var(--sb-color-neutral-800);
    margin: 0;
  }

  .sb-blog-post__meta-item + .sb-blog-post__meta-item {
    margin-top: 12px;
  }

  .sb-blog-post__meta-item--read-time + .sb-blog-post__title {
    margin-top: var(--sb-space-20);
  }

  .sb-blog-post__title {
    color: var(--sb-color-neutral-900);
    margin: 0;
    max-width: 800px;
    width: 100%;
  }

  .sb-blog-post__excerpt {
    color: var(--sb-color-neutral-900);
    margin: 0;
    max-width: 800px;
    width: 100%;
  }

  .sb-blog-post__title + .sb-blog-post__excerpt {
    margin-top: var(--sb-space-20);
  }

  .sb-blog-post__media {
    aspect-ratio: 800 / 450;
    border-radius: 24px;
    margin: 0;
    overflow: hidden;
    width: 100%;
  }

  .sb-blog-post__media + .sb-blog-post__content {
    margin-top: 30px;
  }

  .sb-blog-post__image {
    display: block;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .sb-blog-post__mobile-promo {
    display: none;
  }

  .sb-blog-post__content {
    color: var(--sb-color-neutral-900);
    font-family: var(--font-primary--family);
    font-size: var(--font-size-body);
    font-weight: 400;
    line-height: 1.4;
    margin-top: 0;
  }

  .sb-blog-post__content > * {
    margin: 0;
  }

  .sb-blog-post__content > * + * {
    margin-top: 24px;
  }

  .sb-blog-post__content > * + :is(
    img,
    picture,
    figure,
    p:has(> img:only-child),
    p:has(> a:only-child > img:only-child)
  ) {
    margin-top: 30px;
  }

  .sb-blog-post__content > :is(
    img,
    picture,
    figure,
    p:has(> img:only-child),
    p:has(> a:only-child > img:only-child)
  ) + * {
    margin-top: 30px;
  }

  .sb-blog-post__content > h2 {
    color: var(--sb-color-neutral-900);
    font-family: var(--font-primary--family);
    font-size: var(--font-size-callout);
    font-weight: 700;
    line-height: 1.25;
  }

