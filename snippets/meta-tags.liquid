<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width,initial-scale=1">

{%- liquid
  assign resolved_page_title = page_title | default: shop.name
  assign seasonal_sale_name = settings.seasonal_sale_name | strip
  if request.page_type == 'product' and seasonal_sale_name != blank
    assign resolved_page_title_downcase = resolved_page_title | downcase
    assign seasonal_sale_name_downcase = seasonal_sale_name | downcase
    unless resolved_page_title_downcase contains seasonal_sale_name_downcase
      assign resolved_page_title = resolved_page_title | append: ' – ' | append: seasonal_sale_name
    endunless
  endif

  assign og_title = resolved_page_title
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign og_description = page_description | default: shop.description | default: shop.name
  assign og_image = page_image

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif

  if request.page_type == 'page' and page != blank
    assign page_social_media_image = page.metafields.custom.social_media_image.value | default: page.metafields.custom.social_media_image
    if page_social_media_image != blank
      assign og_image = page_social_media_image
    endif
  endif
%}

<meta
  property="og:site_name"
  content="{{ shop.name }}"
>
<meta
  property="og:url"
  content="{{ og_url }}"
>
<meta
  property="og:title"
  content="{{ og_title | escape }}"
>
<meta
  property="og:type"
  content="{{ og_type }}"
>
<meta
  property="og:description"
  content="{{ og_description | escape }}"
>

{%- if og_image -%}
  <meta
    property="og:image"
    content="http:{{ og_image | image_url }}"
  >
  <meta
    property="og:image:secure_url"
    content="https:{{ og_image | image_url }}"
  >
  <meta
    property="og:image:width"
    content="{{ og_image.width }}"
  >
  <meta
    property="og:image:height"
    content="{{ og_image.height }}"
  >
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <script type="application/ld+json">
    {{ product | structured_data }}
  </script>

  <meta
    property="og:price:amount"
    content="{{ product.price | money_without_currency | strip_html }}"
  >
  <meta
    property="og:price:currency"
    content="{{ cart.currency.iso_code }}"
  >
{%- endif -%}

<meta
  name="twitter:card"
  content="summary_large_image"
>
<meta
  name="twitter:title"
  content="{{ og_title | escape }}"
>
<meta
  name="twitter:description"
  content="{{ og_description | escape }}"
>
{%- if og_image -%}
  <meta
    name="twitter:image"
    content="https:{{ og_image | image_url }}"
  >
{%- endif -%}

<title>
  {%- if request.page_type == 'cart' -%}
    {%- assign cart_page_title = 'cart.title' | t -%}
    {{ cart_page_title }}
    {%- unless cart_page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  {%- elsif request.page_type == '404' -%}
    404 &ndash; {{ shop.name }}
  {%- else -%}
    {%- assign page_title_tag_labels = '' -%}
    {%- if current_tags -%}
      {%- for tag in current_tags -%}
        {%- assign normalized_tag = tag | downcase -%}
        {%- assign cleaned_tag = tag | strip -%}
        {%- if normalized_tag contains 'by_product' -%}
          {%- assign cleaned_tag = cleaned_tag | remove_first: 'By_product: ' | remove_first: 'by_product: ' | remove_first: 'By_product - ' | remove_first: 'by_product - ' | remove_first: 'By_product-' | remove_first: 'by_product-' | remove_first: 'By_product ' | remove_first: 'by_product ' | remove_first: 'By_product' | remove_first: 'by_product' | strip -%}
        {%- elsif normalized_tag contains 'by_instrument' -%}
          {%- assign cleaned_tag = cleaned_tag | remove_first: 'By_instrument: ' | remove_first: 'by_instrument: ' | remove_first: 'By_instrument - ' | remove_first: 'by_instrument - ' | remove_first: 'By_instrument-' | remove_first: 'by_instrument-' | remove_first: 'By_instrument ' | remove_first: 'by_instrument ' | remove_first: 'By_instrument' | remove_first: 'by_instrument' | strip -%}
        {%- endif -%}
        {%- if cleaned_tag != blank -%}
          {%- if page_title_tag_labels != blank -%}
            {%- assign page_title_tag_labels = page_title_tag_labels | append: ', ' -%}
          {%- endif -%}
          {%- assign page_title_tag_labels = page_title_tag_labels | append: cleaned_tag -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
    {{ resolved_page_title }}
    {%- if page_title_tag_labels != blank %} ({{ page_title_tag_labels }}){% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless resolved_page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  {%- endif -%}
</title>

<link
  rel="canonical"
  href="{{ canonical_url }}"
>

{% if page_description %}
  <meta
    name="description"
    content="{{ page_description | escape }}"
  >
{% endif %}
