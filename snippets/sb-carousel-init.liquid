<script>
  (() => {
    const initCarousels = (scope = document) => {
      const roots = scope.querySelectorAll('[data-sb-carousel]');
      if (!roots.length) return;

      roots.forEach((root) => {
        if (root.dataset.sbCarouselInit === 'true') return;
        root.dataset.sbCarouselInit = 'true';

        const viewport = root.querySelector('[data-sb-carousel-viewport]');
        const track = root.querySelector('[data-sb-carousel-track]');
        const nativeEndOffsetSpacer = track ? track.querySelector('[data-sb-carousel-end-offset]') : null;
        const prev = root.querySelector('[data-sb-carousel-prev]');
        const next = root.querySelector('[data-sb-carousel-next]');

        if (!viewport || !track || !prev || !next) return;

        const px = (value) => {
          const n = Number.parseFloat(value || '0');
          return Number.isFinite(n) ? n : 0;
        };

        const pageMargin = () => {
          const styles = getComputedStyle(document.documentElement);
          const desktop = window.matchMedia('(min-width: 750px)').matches;
          const token = desktop ? '--page-margin-desktop' : '--page-margin-mobile';
          return px(styles.getPropertyValue(token)) || px(styles.getPropertyValue('--page-margin')) || 16;
        };
        const layoutViewportWidth = () => Math.max(
          1,
          document.documentElement.clientWidth || window.innerWidth || 0
        );
        const contentWidth = () => Math.max(1, root.getBoundingClientRect().width || root.clientWidth || 0);
        const viewportPaddingStart = () => px(getComputedStyle(viewport).paddingLeft);
        const viewportPaddingEnd = () => px(getComputedStyle(viewport).paddingRight);
        const items = () => track.querySelectorAll('[data-sb-carousel-item]');
        const itemStartOffset = (item) =>
          Math.max(0, item.getBoundingClientRect().left - track.getBoundingClientRect().left);
        const itemEndOffset = (item) =>
          Math.max(
            0,
            itemStartOffset(item)
              + viewportPaddingStart()
              + item.getBoundingClientRect().width
              - (viewport.clientWidth - viewportPaddingEnd())
          );

        const scrollEpsilon = 2;
        const snapTolerance = 24;
        const prefersReducedMotion = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const shouldClampToBounds = () => window.matchMedia('(hover: hover) and (pointer: fine)').matches;
        const arrowFeedbackDuration = 220;
        let maxScroll = 0;
        let syncFrame = 0;
        let pendingTarget = null;
        const arrowFeedbackTimers = new WeakMap();

        const currentMaxScroll = () => maxScroll;
        const currentScrollOffset = () => Math.max(0, Math.min(viewport.scrollLeft, currentMaxScroll()));
        const effectiveScrollOffset = () =>
          pendingTarget === null
            ? currentScrollOffset()
            : Math.max(0, Math.min(pendingTarget, currentMaxScroll()));
        const clearNativeEndOffset = () => {
          track.style.removeProperty('--sb-carousel-native-end-offset');
          track.style.paddingRight = '';
          track.style.marginRight = '';
          if (nativeEndOffsetSpacer instanceof HTMLElement) {
            nativeEndOffsetSpacer.style.flexBasis = '';
            nativeEndOffsetSpacer.style.marginLeft = '';
            nativeEndOffsetSpacer.style.width = '';
          }
        };
        const requestSyncState = () => {
          if (syncFrame) return;
          syncFrame = window.requestAnimationFrame(() => {
            syncFrame = 0;
            syncState();
          });
        };
        const playArrowFeedback = (button) => {
          if (!button || button.disabled) return;

          const existingTimer = arrowFeedbackTimers.get(button);
          if (existingTimer) window.clearTimeout(existingTimer);

          button.classList.remove('is-clicked');
          void button.offsetWidth;
          button.classList.add('is-clicked');

          const timer = window.setTimeout(() => {
            button.classList.remove('is-clicked');
            arrowFeedbackTimers.delete(button);
          }, arrowFeedbackDuration);

          arrowFeedbackTimers.set(button, timer);
        };

        const getSnapPoints = (max) => {
          const list = items();
          if (!list.length) return [0, max];

          const points = Array.from(list).map((item) => itemStartOffset(item));
          points.push(max);

          const normalized = points
            .map((point) => Math.max(0, Math.min(max, point)))
            .map((point) => Number(point.toFixed(2)));

          return Array.from(new Set(normalized)).sort((a, b) => a - b);
        };
        const getClosestSnap = (offset, max) => {
          const points = getSnapPoints(max);
          if (!points.length) return { index: 0, point: 0, distance: Math.abs(offset) };

          let closestIndex = 0;
          let closestPoint = points[0];
          let closestDistance = Math.abs(points[0] - offset);

          points.forEach((point, index) => {
            const distance = Math.abs(point - offset);
            if (distance < closestDistance) {
              closestIndex = index;
              closestPoint = point;
              closestDistance = distance;
            }
          });

          return { index: closestIndex, point: closestPoint, distance: closestDistance };
        };
        const captureLayoutState = () => {
          const max = currentMaxScroll();
          const offset = effectiveScrollOffset();

          if (max <= scrollEpsilon || offset <= scrollEpsilon) {
            return { type: 'start' };
          }

          const { index, point, distance } = getClosestSnap(offset, max);
          const list = items();
          const isEndSnap = point >= max - scrollEpsilon || index >= list.length;

          if (pendingTarget !== null || distance <= snapTolerance) {
            if (isEndSnap) return { type: 'end' };
            return { type: 'item', index };
          }

          return { type: 'offset', value: offset };
        };
        const resolveLayoutState = (state, max) => {
          if (!state || max <= scrollEpsilon) return 0;
          if (state.type === 'start') return 0;
          if (state.type === 'end') return max;
          if (state.type === 'offset') return Math.max(0, Math.min(state.value, max));

          const list = Array.from(items());
          if (!list.length) return 0;

          const index = Math.max(0, Math.min(state.index, list.length - 1));
          return Math.max(0, Math.min(itemStartOffset(list[index]), max));
        };

        const getNextSnap = (current, max) => {
          const points = getSnapPoints(max);
          for (const point of points) {
            if (point > current + scrollEpsilon) return point;
          }
          return max;
        };

        const getPrevSnap = (current, max) => {
          const points = getSnapPoints(max);
          for (let i = points.length - 1; i >= 0; i -= 1) {
            if (points[i] < current - scrollEpsilon) return points[i];
          }
          return 0;
        };

        const setBleed = () => {
          const bleed = Math.max(pageMargin(), Math.floor((layoutViewportWidth() - contentWidth()) / 2));
          root.style.setProperty('--sb-carousel-bleed-inline', `${Math.max(0, bleed)}px`);
        };

        const syncState = () => {
          const max = currentMaxScroll();
          const overflowing = max > 1;
          if (overflowing && shouldClampToBounds()) {
            if (viewport.scrollLeft > max + scrollEpsilon) viewport.scrollLeft = max;
            if (viewport.scrollLeft < -scrollEpsilon) viewport.scrollLeft = 0;
          }
          const current = currentScrollOffset();
          const effectiveCurrent = effectiveScrollOffset();
          root.classList.toggle('is-overflowing', overflowing);
          root.classList.toggle('is-not-overflowing', !overflowing);

          if (!overflowing) {
            if (Math.abs(viewport.scrollLeft) > scrollEpsilon) viewport.scrollLeft = 0;
            pendingTarget = null;
            prev.disabled = true;
            next.disabled = true;
            return;
          }

          prev.disabled = effectiveCurrent <= scrollEpsilon;
          next.disabled = effectiveCurrent >= max - scrollEpsilon;

          if (pendingTarget !== null && Math.abs(current - pendingTarget) <= scrollEpsilon) {
            pendingTarget = null;
          }
        };

        const refreshLayout = ({ preserveState = null } = {}) => {
          setBleed();
          clearNativeEndOffset();
          track.style.transform = '';

          const list = items();
          const lastItem = list[list.length - 1];
          const desiredMax = lastItem ? itemEndOffset(lastItem) : 0;
          const baseNativeMax = Math.max(0, viewport.scrollWidth - viewport.clientWidth);
          const nativeEndOffset = Math.max(0, desiredMax - baseNativeMax);

          if (nativeEndOffset > scrollEpsilon) {
            if (nativeEndOffsetSpacer instanceof HTMLElement) {
              const gap = px(getComputedStyle(track).gap);
              nativeEndOffsetSpacer.style.flexBasis = `${nativeEndOffset}px`;
              nativeEndOffsetSpacer.style.marginLeft = `${gap > 0 ? -gap : 0}px`;
              nativeEndOffsetSpacer.style.width = `${nativeEndOffset}px`;

              const adjustedNativeMax = Math.max(0, viewport.scrollWidth - viewport.clientWidth);
              const remainingShortfall = Math.max(0, desiredMax - adjustedNativeMax);
              if (remainingShortfall > scrollEpsilon) {
                nativeEndOffsetSpacer.style.flexBasis = `${nativeEndOffset + remainingShortfall}px`;
                nativeEndOffsetSpacer.style.width = `${nativeEndOffset + remainingShortfall}px`;
              }
            } else {
              track.style.paddingRight = `${nativeEndOffset}px`;

              const adjustedNativeMax = Math.max(0, viewport.scrollWidth - viewport.clientWidth);
              const remainingShortfall = Math.max(0, desiredMax - adjustedNativeMax);
              if (remainingShortfall > scrollEpsilon) {
                track.style.paddingRight = `${nativeEndOffset + remainingShortfall}px`;
              }
            }
          }

          maxScroll = desiredMax;

          if (maxScroll <= scrollEpsilon) {
            if (Math.abs(viewport.scrollLeft) > scrollEpsilon) viewport.scrollLeft = 0;
          } else if (preserveState) {
            viewport.scrollLeft = resolveLayoutState(preserveState, maxScroll);
          } else if (shouldClampToBounds() && viewport.scrollLeft > maxScroll) {
            viewport.scrollLeft = maxScroll;
          }

          syncState();
        };
        const refreshLayoutPreservingState = () => {
          refreshLayout({ preserveState: captureLayoutState() });
        };

        const scrollToOffset = (value, { animate = false } = {}) => {
          const max = currentMaxScroll();
          let clamped = Math.max(0, Math.min(value, max));
          if (clamped < scrollEpsilon) clamped = 0;
          if (clamped > max - scrollEpsilon) clamped = max;
          const startOffset = viewport.scrollLeft;
          const intendedDelta = Math.abs(clamped - startOffset);
          if (intendedDelta <= scrollEpsilon) return;

          if (animate && !prefersReducedMotion()) {
            pendingTarget = clamped;
            viewport.scrollTo({ left: clamped, behavior: 'smooth' });
            requestSyncState();
            return;
          }

          pendingTarget = null;
          viewport.scrollLeft = clamped;
          syncState();
        };

        const syncControlsForTarget = (target) => {
          const max = currentMaxScroll();
          const clamped = Math.max(0, Math.min(target, max));
          prev.disabled = clamped <= scrollEpsilon;
          next.disabled = clamped >= max - scrollEpsilon;
        };

        prev.addEventListener('click', () => {
          const max = currentMaxScroll();
          const target = getPrevSnap(viewport.scrollLeft, max);
          playArrowFeedback(prev);
          syncControlsForTarget(target);
          scrollToOffset(target, { animate: true });
        });

        next.addEventListener('click', () => {
          const max = currentMaxScroll();
          const target = getNextSnap(viewport.scrollLeft, max);
          playArrowFeedback(next);
          syncControlsForTarget(target);
          scrollToOffset(target, { animate: true });
        });

        viewport.addEventListener(
          'scroll',
          () => {
            requestSyncState();
          },
          { passive: true }
        );

        viewport.addEventListener(
          'wheel',
          (event) => {
            if (!root.classList.contains('is-overflowing')) return;

            const horizontalDelta = event.deltaX;
            if (Math.abs(horizontalDelta) < 1) return;

            pendingTarget = null;
            event.preventDefault();
            const max = currentMaxScroll();
            let nextOffset = Math.max(0, Math.min(viewport.scrollLeft + horizontalDelta, max));
            if (nextOffset < scrollEpsilon) nextOffset = 0;
            if (nextOffset > max - scrollEpsilon) nextOffset = max;
            viewport.scrollLeft = nextOffset;
          },
          { passive: false }
        );

        if ('ResizeObserver' in window) {
          const observer = new ResizeObserver(() => refreshLayoutPreservingState());
          observer.observe(viewport);
          observer.observe(track);
        }

        track.querySelectorAll('img').forEach((img) => {
          if (!img.complete) {
            img.addEventListener('load', refreshLayoutPreservingState, { once: true });
            img.addEventListener('error', refreshLayoutPreservingState, { once: true });
          }
        });

        window.addEventListener('load', refreshLayout);
        window.addEventListener('resize', refreshLayoutPreservingState);
        refreshLayout();
        window.requestAnimationFrame(refreshLayoutPreservingState);
        window.setTimeout(refreshLayoutPreservingState, 120);
        window.setTimeout(refreshLayoutPreservingState, 360);
      });
    };

    window.SBInitCarousel = initCarousels;

    if (window.__sbCarouselScriptLoaded) {
      initCarousels(document);
      return;
    }

    window.__sbCarouselScriptLoaded = true;
    initCarousels(document);
    document.addEventListener('shopify:section:load', (event) => {
      initCarousels(event.target);
    });
  })();
</script>
