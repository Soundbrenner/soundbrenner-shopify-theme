{%- liquid
  assign sb_money_context = context | default: 'storefront' | downcase | strip
  assign sb_money_cents = amount | plus: 0
  assign sb_money_display_cents = sb_money_cents

  if sb_money_context != 'cart'
    assign sb_money_display_major = sb_money_cents | divided_by: 100.0 | round: 0
    assign sb_money_display_cents = sb_money_display_major | times: 100
  endif

  echo sb_money_display_cents | money_without_trailing_zeros
-%}
