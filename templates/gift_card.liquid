{% layout none %}

<!doctype html>
<html lang="{{ request.locale.iso_code }}" data-theme="light">
  <head>
    {% assign page_title = 'gift_card.card' | t %}
    {% assign page_description = 'gift_card.use_at_checkout' | t %}

    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'template-gift-card.css' | asset_url | stylesheet_tag }}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}
    {{ 'vendor/qrcode.js' | shopify_asset_url | script_tag }}
    <script src="{{ 'template-gift-card.js' | asset_url }}" defer></script>

    {{ content_for_header }}
  </head>

  <body class="sb-gift-card-page">
    <main class="sb-gift-card">
      {% assign gift_card_product = all_products['gift-card'] %}
      {% assign gift_card_product_image = blank %}
      {% assign gift_card_product_image_width = 800 %}
      {% assign gift_card_product_hover_image_url = blank %}
      {% if gift_card_product != blank %}
        {% assign gift_card_product_image = gift_card_product.featured_image %}
        {% if gift_card_product_image != blank and gift_card_product_image.width != blank %}
          {% assign gift_card_product_image_width = gift_card_product_image.width | at_most: 800 %}
        {% endif %}
        {% assign gift_card_selected_variant = gift_card_product.selected_or_first_available_variant %}
        {% if gift_card_selected_variant != blank %}
          {% capture gift_card_variant_hover_image_url %}
            {% render 'sb-hover-image-url', resource: gift_card_selected_variant, width: gift_card_product_image_width %}
          {% endcapture %}
          {% assign gift_card_variant_hover_image_url = gift_card_variant_hover_image_url | strip %}
          {% if gift_card_variant_hover_image_url != blank %}
            {% assign gift_card_product_hover_image_url = gift_card_variant_hover_image_url %}
          {% endif %}
        {% endif %}
        {% if gift_card_product_hover_image_url == blank %}
          {% capture gift_card_primary_hover_image_url %}
            {% render 'sb-hover-image-url', resource: gift_card_product, width: gift_card_product_image_width %}
          {% endcapture %}
          {% assign gift_card_primary_hover_image_url = gift_card_primary_hover_image_url | strip %}
          {% if gift_card_primary_hover_image_url != blank %}
            {% assign gift_card_product_hover_image_url = gift_card_primary_hover_image_url %}
          {% endif %}
        {% endif %}
      {% endif %}
      {% capture gift_card_info_text %}
        {% if gift_card.expires_on %}
          {% assign expires_on = gift_card.expires_on | date: '%B %e, %Y' %}
          {{ 'gift_card.expires_on' | t: expires_on: expires_on }}.
          <br>
        {% endif %}
        {{ 'gift_card.use_at_checkout' | t }}.
      {% endcapture %}
      {% assign gift_card_store_url = request.locale.root_url | default: routes.root_url | default: '/' %}
      {% assign gift_card_copy_label = 'gift_card.copy_code' | t %}
      {% assign gift_card_copy_success_label = 'gift_card.copy_code_success' | t %}
      {% assign gift_card_shop_label = 'gift_card.shop_link' | t %}
      <div class="shopify-section sb-gift-card__panel">
        <span class="sb-gift-card__logo" aria-hidden="true">
          {{ 'logo-soundbrenner-wordmark.svg' | inline_asset_content }}
        </span>

        <div class="sb-gift-card__media-frame{% if gift_card_product_hover_image_url != blank %} sb-gift-card__media-frame--has-hover{% endif %}">
          {% if gift_card_product_image != blank %}
            {{
              gift_card_product_image
              | image_url: width: gift_card_product_image_width
              | image_tag:
                class: 'sb-gift-card__media-image sb-gift-card__media-image--primary',
                alt: gift_card_product_image.alt | default: gift_card_product.title,
                loading: 'eager',
                sizes: '(min-width: 750px) 400px, calc(100vw - 40px)',
                widths: '400,600,800'
            }}
            {% if gift_card_product_hover_image_url != blank %}
              <img
                class="sb-gift-card__media-image sb-gift-card__media-image--hover"
                src="{{ gift_card_product_hover_image_url }}"
                alt=""
                loading="eager"
                width="800"
                height="800"
              >
            {% endif %}
          {% else %}
            <img
              class="sb-gift-card__media-image sb-gift-card__media-image--fallback"
              src="{{ 'gift-card/card.svg' | shopify_asset_url }}"
              alt="{{ 'gift_card.card' | t }}"
              width="334"
              height="200"
              loading="eager"
            >
          {% endif %}
        </div>

        <h1 class="sb-gift-card__balance font-title weight-bold">{{ gift_card.balance | money_with_currency }}</h1>
        <p class="sb-gift-card__code">{{ gift_card.code | format_code }}</p>

        <div class="sb-gift-card__qr-frame">
          <div
            class="sb-gift-card__qr-code"
            data-gift-card-qr-code
            data-identifier="{{ gift_card.qr_identifier | escape }}"
            aria-label="{{ 'gift_card.qr_code_label' | t }}"
          ></div>
        </div>

        <p class="sb-gift-card__info">{{ gift_card_info_text }}</p>

        <div class="sb-gift-card__actions" data-gift-card-code="{{ gift_card.code | escape }}">
          {% render 'radiant-button',
            label: gift_card_copy_label,
            size: 'large',
            attributes: 'data-gift-card-copy-button',
            extra_class: 'sb-gift-card__button sb-gift-card__copy-button font-caption weight-bold'
          %}

          <p class="sb-gift-card__feedback visually-hidden" role="status" data-gift-card-copy-feedback>
            <span class="sb-gift-card__feedback-icon" aria-hidden="true">
              {{ 'icon-check.svg' | inline_asset_content }}
            </span>
            <span class="sb-gift-card__feedback-text">{{ gift_card_copy_success_label }}</span>
          </p>

          <a href="{{ gift_card_store_url }}" class="sb-gift-card__link sb-button-outline-pill-medium font-caption weight-semibold">
            {{ gift_card_shop_label }}
          </a>
        </div>
      </div>
    </main>
  </body>
</html>
