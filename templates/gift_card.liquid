{% layout none %}

<!doctype html>
<html lang="{{ request.locale.iso_code }}" data-theme="dark">
  <head>
    {% assign page_title = 'gift_card.card' | t %}
    {% assign page_description = 'gift_card.use_at_checkout' | t %}

    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'template-gift-card.css' | asset_url | stylesheet_tag }}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}
    {{ 'vendor/qrcode.js' | shopify_asset_url | script_tag }}
    <script src="{{ 'template-gift-card.js' | asset_url }}" defer></script>

    {{ content_for_header }}
  </head>

  <body class="sb-gift-card-page">
    <main class="sb-gift-card">
      <div class="shopify-section sb-gift-card__panel">
        <h1 class="sb-gift-card__shop-name">{{ shop.name }}</h1>

        <div class="sb-gift-card__image-frame{% unless settings.logo %} sb-gift-card__image-frame--generic{% endunless %}">
          {% if settings.logo %}
            {{
              settings.logo
              | image_url: width: 336
              | image_tag:
                class: 'sb-gift-card__image',
                alt: shop.name,
                loading: 'eager'
            }}
          {% else %}
            <img
              class="sb-gift-card__image sb-gift-card__image--generic"
              src="{{ 'gift-card/card.svg' | shopify_asset_url }}"
              alt="{{ 'gift_card.card' | t }}"
              width="334"
              height="200"
              loading="eager"
            >
          {% endif %}
        </div>

        <div class="sb-gift-card__balance-row">
          <h2 class="sb-gift-card__balance">{{ gift_card.balance | money_with_currency }}</h2>

          {% if gift_card.enabled == false or gift_card.expired %}
            <p class="sb-gift-card__badge">{{ 'gift_card.expired' | t }}</p>
          {% endif %}
        </div>

        {% if gift_card.expires_on %}
          {% assign expires_on = gift_card.expires_on | date: '%B %e, %Y' %}
          <p class="sb-gift-card__expiration">{{ 'gift_card.expires_on' | t: expires_on: expires_on }}</p>
        {% endif %}

        <p class="sb-gift-card__copy">{{ 'gift_card.use_at_checkout' | t }}</p>
        <p class="sb-gift-card__code">{{ gift_card.code | format_code }}</p>

        <div class="sb-gift-card__qr-frame">
          <div
            class="sb-gift-card__qr-code"
            data-gift-card-qr-code
            data-identifier="{{ gift_card.qr_identifier | escape }}"
            aria-label="{{ 'sb.gift_card.qr_code_label' | t }}"
          ></div>
        </div>

        <div class="sb-gift-card__actions">
          {% if gift_card.pass_url %}
            <a href="{{ gift_card.pass_url }}" class="sb-gift-card__link">
              <img
                src="{{ 'gift-card/add-to-apple-wallet.svg' | shopify_asset_url }}"
                alt="{{ 'gift_card.add_to_apple_wallet' | t }}"
                width="120"
                height="40"
                loading="lazy"
              >
            </a>
          {% endif %}

          <button
            type="button"
            class="sb-gift-card__button"
            data-gift-card-copy-button
            data-gift-card-code="{{ gift_card.code | escape }}"
          >
            {{ 'sb.gift_card.copy_code' | t }}
          </button>

          <p class="sb-gift-card__feedback visually-hidden" role="status" data-gift-card-copy-feedback>
            {{ 'sb.gift_card.copy_code_success' | t }}
          </p>

          <a href="{{ routes.root_url }}" class="sb-gift-card__link">
            {{ 'sb.gift_card.shop_link' | t }}
          </a>
        </div>
      </div>
    </main>
  </body>
</html>
