        },
        "subheading_UTgFBp": {
          "type": "subheading",
          "settings": {
            "heading": "Touch interactions"
          }
        },
        "text_VAA3iK": {
          "type": "text",
          "settings": {
            "text": "<p>The Core / Spark features a capacitive touch surface. To ensure reliable input detection, place two fingers flat across the surface. Do not use only your fingertips.</p><p><strong>Start or pause a feature</strong></p><p>Tap the soundwave icon twice quickly to start or pause certain features. This gesture works in the <strong>Metronome</strong>, <strong>Timer</strong>, <strong>Stopwatch</strong>, and <strong>Smartphone music remote</strong> apps.</p>"
          }
        },
        "image_mgU7ky": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/Product_Core_2_Order_9.jpg"
          }
        },
        "text_4aafcq": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Tap tempo</strong></p><p>Tap the soundwave three times or more at a steady pace. The Core/Spark will set a new tempo that matches the average pace of your taps. Works in <strong>Metronome</strong> app only.</p>"
          }
        },
        "image_UGq7br": {
