{% comment %}
  Set the featured product handle before assigning this template to a page.
  Leave blank to keep the page copy-only until the product is chosen.
{% endcomment %}
{% liquid
  assign landing_product_handle = 'wave-in-ear-monitors'
  assign landing_usb_c_adapter_handle = 'usb-c-to-3-5mm-audio-adapter'
  assign landing_mic_cable_handle = 'wave-over-ear-cable-2-5m-8-2-ft-with-microphone'
  assign landing_product = blank
  assign landing_usb_c_adapter = blank
  assign landing_mic_cable = blank
  if landing_product_handle != blank
    assign landing_product = all_products[landing_product_handle]
  endif
  if landing_usb_c_adapter_handle != blank
    assign landing_usb_c_adapter = all_products[landing_usb_c_adapter_handle]
  endif
  if landing_mic_cable_handle != blank
    assign landing_mic_cable = all_products[landing_mic_cable_handle]
  endif

  assign landing_variant = blank
  assign landing_primary_media = blank
  assign landing_secondary_media = blank
  assign landing_product_hide_discounts = false
  assign landing_reviews_count = 0

  if landing_product != blank
    assign landing_variant = landing_product.selected_or_first_available_variant
    assign landing_primary_media = landing_product.featured_media.preview_image | default: landing_product.featured_image
    assign landing_reviews_count = landing_product.metafields.reviews.rating_count.value | default: 0 | plus: 0 | round: 0
    assign landing_product_settings_ref = landing_product.metafields.custom.sbv2_product_settings.value | default: landing_product.metafields.custom.sbv2_product_settings
    if landing_product_settings_ref != blank
      assign landing_product_hide_discounts_value = landing_product_settings_ref.hide_discounts.value | default: landing_product_settings_ref.hide_discounts
      if landing_product_hide_discounts_value == true or landing_product_hide_discounts_value == 'true' or landing_product_hide_discounts_value == 1 or landing_product_hide_discounts_value == '1'
        assign landing_product_hide_discounts = true
      endif
    endif
    for media in landing_product.media
      assign media_preview = media.preview_image | default: media
      if landing_secondary_media == blank and media_preview != blank and media_preview.id != landing_primary_media.id
        assign landing_secondary_media = media_preview
        break
      endif
    endfor
  endif

  if landing_secondary_media == blank
    assign landing_secondary_media = landing_primary_media
  endif

  assign landing_currency_code = cart.currency.iso_code | default: localization.country.currency.iso_code | default: shop.currency | upcase
  assign landing_storefront_cart_discount_percent = 0
  for discount_application in cart.cart_level_discount_applications
    if discount_application.value_type == 'percentage'
      assign storefront_next_discount_percent = discount_application.value | plus: 0
      if storefront_next_discount_percent > landing_storefront_cart_discount_percent
        assign landing_storefront_cart_discount_percent = storefront_next_discount_percent
      endif
    endif
  endfor
  for cart_item in cart.items
    for line_discount_allocation in cart_item.line_level_discount_allocations
      assign line_discount_application = line_discount_allocation.discount_application
      if line_discount_application and line_discount_application.value_type == 'percentage'
        assign storefront_next_discount_percent = line_discount_application.value | plus: 0
        if storefront_next_discount_percent > landing_storefront_cart_discount_percent
          assign landing_storefront_cart_discount_percent = storefront_next_discount_percent
        endif
      endif
    endfor
  endfor

  assign landing_storefront_global_discount_percent = settings.sitewide_seasonal_discount_depth | default: 0 | plus: 0
  if landing_storefront_cart_discount_percent > landing_storefront_global_discount_percent
    assign landing_storefront_global_discount_percent = landing_storefront_cart_discount_percent
  endif
  if landing_storefront_global_discount_percent < 0
    assign landing_storefront_global_discount_percent = 0
  elsif landing_storefront_global_discount_percent > 100
    assign landing_storefront_global_discount_percent = 100
  endif

  assign landing_storefront_product_discount_percent = 0
  assign storefront_override_product_1 = all_products[settings.storefront_price_override_product_id_1]
  if storefront_override_product_1 != blank and landing_product != blank and storefront_override_product_1.id == landing_product.id
    assign landing_storefront_product_discount_percent = settings.storefront_price_override_discount_depth_1 | default: 0 | plus: 0
  endif
  assign storefront_override_product_2 = all_products[settings.storefront_price_override_product_id_2]
  if storefront_override_product_2 != blank and landing_product != blank and storefront_override_product_2.id == landing_product.id
    assign landing_storefront_product_discount_percent = settings.storefront_price_override_discount_depth_2 | default: 0 | plus: 0
  endif
  assign storefront_override_product_3 = all_products[settings.storefront_price_override_product_id_3]
  if storefront_override_product_3 != blank and landing_product != blank and storefront_override_product_3.id == landing_product.id
    assign landing_storefront_product_discount_percent = settings.storefront_price_override_discount_depth_3 | default: 0 | plus: 0
  endif
  assign storefront_override_product_4 = all_products[settings.storefront_price_override_product_id_4]
  if storefront_override_product_4 != blank and landing_product != blank and storefront_override_product_4.id == landing_product.id
    assign landing_storefront_product_discount_percent = settings.storefront_price_override_discount_depth_4 | default: 0 | plus: 0
  endif
  if landing_storefront_product_discount_percent < 0
    assign landing_storefront_product_discount_percent = 0
  elsif landing_storefront_product_discount_percent > 100
    assign landing_storefront_product_discount_percent = 100
  endif

  assign landing_storefront_effective_discount_percent = landing_storefront_global_discount_percent
  if landing_storefront_product_discount_percent > landing_storefront_effective_discount_percent
    assign landing_storefront_effective_discount_percent = landing_storefront_product_discount_percent
  endif
  if landing_storefront_global_discount_percent > 0 and landing_storefront_product_discount_percent > 0
    assign landing_storefront_keep_after_global = 100 | minus: landing_storefront_global_discount_percent
    assign landing_storefront_keep_after_product = 100 | minus: landing_storefront_product_discount_percent
    assign landing_storefront_keep_combined_percent = landing_storefront_keep_after_global | times: landing_storefront_keep_after_product | divided_by: 100.0
    assign landing_storefront_effective_discount_percent = 100 | minus: landing_storefront_keep_combined_percent
  endif

  assign landing_display_price_cents = landing_variant.price | default: 0 | plus: 0
  assign landing_display_compare_cents = 0
  assign landing_variant_compare_cents = landing_variant.compare_at_price | default: 0 | plus: 0
  assign landing_base_compare_cents = landing_variant.price | default: 0 | plus: 0
  if landing_variant_compare_cents > landing_base_compare_cents
    assign landing_base_compare_cents = landing_variant_compare_cents
  endif
  assign landing_has_compare_price = false
  assign landing_savings_cents = 0
  assign landing_savings_percentage = 0

  if landing_variant != blank and landing_product_hide_discounts == false
    if landing_storefront_effective_discount_percent > 0
      assign landing_storefront_keep_percent = 100 | minus: landing_storefront_effective_discount_percent
      assign landing_display_price_cents = landing_display_price_cents | times: landing_storefront_keep_percent | divided_by: 100.0 | round
      assign landing_display_compare_cents = landing_base_compare_cents
    elsif landing_variant_compare_cents > landing_display_price_cents
      assign landing_display_compare_cents = landing_variant_compare_cents
    endif
  endif

  if landing_display_compare_cents > landing_display_price_cents
    assign landing_has_compare_price = true
    assign landing_savings_cents = landing_display_compare_cents | minus: landing_display_price_cents
    if landing_display_compare_cents > 0
      assign landing_savings_percentage = landing_savings_cents | times: 100.0 | divided_by: landing_display_compare_cents | round
    endif
  endif
%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:FILL@0..1&display=swap"
>

<section class="sb-meta-landing{% if landing_product == blank %} sb-meta-landing--copy-only{% endif %}">
  <div class="sb-meta-landing__shell">
    <div
      class="sb-meta-landing__hero{% if landing_primary_media != blank %} sb-meta-landing__hero--with-background{% endif %}"
      {% if landing_primary_media != blank %}
        style="--sb-meta-hero-image: url('{{ landing_primary_media | image_url: width: 1600 }}');"
      {% endif %}
    >
      <div class="sb-meta-landing__content-column">
        <p class="sb-meta-landing__eyebrow font-caption weight-semibold">Ready to upgrade from regular earbuds?</p>
        <h1 class="sb-meta-landing__title font-title weight-bold">Your first serious IEM</h1>
        <p class="sb-meta-landing__body font-body weight-regular">
          If you are practicing, rehearsing, or performing with normal earbuds or headphones, you are probably dealing with unclear sound, weak isolation, and distractions that make it harder to hear yourself properly.
        </p>

        <ul class="sb-meta-landing__benefits" role="list">
          <li class="sb-meta-landing__benefit font-body weight-semibold">Zero-latency wired monitoring</li>
          <li class="sb-meta-landing__benefit font-body weight-semibold">Natural passive noise isolation</li>
          <li class="sb-meta-landing__benefit font-body weight-semibold">Built for musicians, not commuters</li>
        </ul>

        {% if landing_variant != blank %}
          <div class="sb-meta-landing__hero-offer" aria-label="Current Wave offer">
            <div class="sb-meta-landing__hero-offer-price">
              <p class="sb-meta-landing__hero-offer-current font-title weight-bold">
                <span
                  class="sb-meta-landing__hero-offer-current-value"
                  style="color: #ffffff !important; -webkit-text-fill-color: #ffffff !important; background: none !important; -webkit-background-clip: border-box !important; background-clip: border-box !important;"
                >
                  {% render 'sb-money-no-decimals', amount: landing_display_price_cents, currency: landing_currency_code, context: 'storefront' %}
                </span>
              </p>

              {% if landing_has_compare_price %}
                <p class="sb-meta-landing__hero-offer-compare font-body weight-regular">
                  <span class="sb-meta-landing__hero-offer-from">Down from</span>
                  <span class="sb-meta-landing__hero-offer-compare-value">
                    {% render 'sb-money-no-decimals', amount: landing_display_compare_cents, currency: landing_currency_code, context: 'storefront' %}
                  </span>
                </p>
              {% endif %}
            </div>

            {% if landing_has_compare_price %}
              <div class="sb-meta-landing__hero-offer-savings">
                <p class="sb-meta-landing__hero-offer-savings-badge font-caption weight-bold">
                  {{ 'sb.product.save_percent' | t: percent: landing_savings_percentage }}
                </p>
                <p class="sb-meta-landing__hero-offer-savings-copy font-caption weight-regular">
                  Save
                  <span class="sb-meta-landing__hero-offer-savings-value">
                    {% render 'sb-money-no-decimals', amount: landing_savings_cents, currency: landing_currency_code, context: 'storefront' %}
                  </span>
                </p>
              </div>
            {% endif %}
          </div>
        {% endif %}

        <div class="sb-meta-landing__actions">
          {% if landing_product != blank and landing_product.url != blank %}
            {% render 'radiant-button',
              label: 'Get Wave',
              link: landing_product.url,
              size: 'large',
              icon_position: 'trailing',
              extra_class: 'sb-meta-landing__primary-cta'
            %}
          {% endif %}
        </div>
      </div>
    </div>

    <section class="sb-meta-landing__pain-section" id="why-switch-from-regular-earbuds" data-sb-reveal>
      <div class="sb-meta-landing__section-heading">
        <h2 class="sb-meta-landing__section-title font-title weight-bold">
          Most musicians don’t realize how much their audio is holding them back
        </h2>
        <p class="sb-meta-landing__section-subhead font-body weight-regular">
          If you are using regular earbuds or headphones, these problems probably feel familiar
        </p>
      </div>

      <div class="sb-meta-landing__pain-grid">
        <article class="sb-meta-landing__pain-card">
          <span class="sb-meta-landing__pain-icon material-symbols-rounded" aria-hidden="true">hearing</span>
          <h3 class="sb-meta-landing__pain-title font-callout weight-bold">You can’t hear yourself clearly</h3>
          <p class="sb-meta-landing__pain-copy font-body weight-regular">
            Vocals, click, backing tracks, and your own instrument blur together.
          </p>
        </article>

        <article class="sb-meta-landing__pain-card">
          <span class="sb-meta-landing__pain-icon material-symbols-rounded" aria-hidden="true">volume_up</span>
          <h3 class="sb-meta-landing__pain-title font-callout weight-bold">You practice too loud</h3>
          <p class="sb-meta-landing__pain-copy font-body weight-regular">
            When audio lacks clarity, people compensate with more volume.
          </p>
        </article>

        <article class="sb-meta-landing__pain-card">
          <span class="sb-meta-landing__pain-icon material-symbols-rounded" aria-hidden="true">graphic_eq</span>
          <h3 class="sb-meta-landing__pain-title font-callout weight-bold">Everything feels muddy in rehearsal</h3>
          <p class="sb-meta-landing__pain-copy font-body weight-regular">
            Details disappear when the room gets loud.
          </p>
        </article>

        <article class="sb-meta-landing__pain-card">
          <span class="sb-meta-landing__pain-icon material-symbols-rounded" aria-hidden="true">swap_calls</span>
          <h3 class="sb-meta-landing__pain-title font-callout weight-bold">Your sound changes everywhere</h3>
          <p class="sb-meta-landing__pain-copy font-body weight-regular">
            What works in one room falls apart in the next.
          </p>
        </article>

        <article class="sb-meta-landing__pain-card">
          <span class="sb-meta-landing__pain-icon material-symbols-rounded" aria-hidden="true">notifications_off</span>
          <h3 class="sb-meta-landing__pain-title font-callout weight-bold">You get distracted fast</h3>
          <p class="sb-meta-landing__pain-copy font-body weight-regular">
            Outside noise competes with the music.
          </p>
        </article>

        <article class="sb-meta-landing__pain-card">
          <span class="sb-meta-landing__pain-icon material-symbols-rounded" aria-hidden="true">tune</span>
          <h3 class="sb-meta-landing__pain-title font-callout weight-bold">You are not actually monitoring</h3>
          <p class="sb-meta-landing__pain-copy font-body weight-regular">
            You are listening, but not hearing the details that help you improve.
          </p>
        </article>
      </div>
    </section>

    <section class="sb-meta-landing__education-section" data-sb-reveal>
      <div class="sb-meta-landing__education-grid">
        <div class="sb-meta-landing__education-visual">
          <div class="sb-meta-landing__comparison-card">
            <div class="sb-meta-landing__comparison-head">
              <p class="sb-meta-landing__comparison-heading font-callout weight-bold">Regular earbuds</p>
              <p class="sb-meta-landing__comparison-heading font-callout weight-bold">IEMs</p>
            </div>

            <div class="sb-meta-landing__comparison-row">
              <p class="sb-meta-landing__comparison-copy font-body weight-regular">Built for commuting</p>
              <p class="sb-meta-landing__comparison-copy font-body weight-semibold">Built for monitoring</p>
            </div>

            <div class="sb-meta-landing__comparison-row">
              <p class="sb-meta-landing__comparison-copy font-body weight-regular">Loose fit</p>
              <p class="sb-meta-landing__comparison-copy font-body weight-semibold">Secure over-ear fit</p>
            </div>

            <div class="sb-meta-landing__comparison-row">
              <p class="sb-meta-landing__comparison-copy font-body weight-regular">Minimal isolation</p>
              <p class="sb-meta-landing__comparison-copy font-body weight-semibold">Passive isolation</p>
            </div>

            <div class="sb-meta-landing__comparison-row">
              <p class="sb-meta-landing__comparison-copy font-body weight-regular">Casual listening</p>
              <p class="sb-meta-landing__comparison-copy font-body weight-semibold">Performance/practice focus</p>
            </div>

            <div class="sb-meta-landing__comparison-row">
              <p class="sb-meta-landing__comparison-copy font-body weight-regular">Often wireless delay</p>
              <p class="sb-meta-landing__comparison-copy font-body weight-semibold">Wired zero latency</p>
            </div>
          </div>
        </div>

        <div class="sb-meta-landing__education-copy">
          <p class="sb-meta-landing__eyebrow font-caption weight-semibold">What is an IEM?</p>
          <h2 class="sb-meta-landing__section-title font-title weight-bold">What is an IEM, and why do musicians use one?</h2>

          <div class="sb-meta-landing__education-body">
            <p class="sb-meta-landing__education-paragraph font-body weight-regular">
              An IEM is an in-ear monitor: an earphone designed for monitoring music more clearly and more reliably than everyday earbuds.
            </p>
            <p class="sb-meta-landing__education-paragraph font-body weight-regular">
              Musicians use IEMs to hear their own performance, click, backing tracks, and mix with more focus and less distraction.
            </p>
            <p class="sb-meta-landing__education-paragraph font-body weight-regular">
              Because Wave is wired, it gives you zero-latency monitoring, which matters when timing and accuracy matter. It works with standard headphone-jack devices and can also be used with a USB-C adapter on newer phones and tablets.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="sb-meta-landing__transformation-section" data-sb-reveal>
      <div class="sb-meta-landing__section-heading sb-meta-landing__section-heading--wide">
        <h2 class="sb-meta-landing__section-title font-title weight-bold">
          The first time you hear properly, everything changes
        </h2>
        <p class="sb-meta-landing__section-subhead font-body weight-regular">
          The moment proper monitoring clicks, you start hearing the details that used to stay buried: your own timing, articulation, pitch, tone, and the relationship between the click, backing track, and your performance.
        </p>
      </div>

      <div class="sb-meta-landing__transformation-grid">
        <button
          class="sb-meta-landing__transformation-tile"
          type="button"
          data-sb-modal-open
          data-sb-modal-title="Hear your own part clearly"
          data-sb-modal-body="Instead of trying to infer what you played from a noisy room, Wave helps separate your own instrument or voice from click and backing tracks. That makes practice feel less guessy and more immediate."
        >
          <h3 class="sb-meta-landing__transformation-title font-callout weight-bold">Hear your own part clearly</h3>
        </button>

        <button
          class="sb-meta-landing__transformation-tile"
          type="button"
          data-sb-modal-open
          data-sb-modal-title="Catch mistakes faster"
          data-sb-modal-body="When timing, articulation, and pitch are easier to hear, mistakes stop hiding inside a blurry mix. You notice issues earlier, correct them sooner, and repeat fewer bad habits."
        >
          <h3 class="sb-meta-landing__transformation-title font-callout weight-bold">Catch mistakes faster</h3>
        </button>

        <button
          class="sb-meta-landing__transformation-tile"
          type="button"
          data-sb-modal-open
          data-sb-modal-title="Play with more confidence"
          data-sb-modal-body="Clearer monitoring reduces second-guessing. When you can hear where you sit against the track or the room, you commit more naturally and perform with less hesitation."
        >
          <h3 class="sb-meta-landing__transformation-title font-callout weight-bold">Play with more confidence</h3>
        </button>

        <button
          class="sb-meta-landing__transformation-tile"
          type="button"
          data-sb-modal-open
          data-sb-modal-title="Practice with less strain"
          data-sb-modal-body="Better clarity and passive isolation mean you do not need to push volume as hard to understand what is happening. That can make longer sessions feel more controlled and less fatiguing."
        >
          <h3 class="sb-meta-landing__transformation-title font-callout weight-bold">Practice with less strain</h3>
        </button>
      </div>
    </section>

    <section class="sb-meta-landing__product-fit-section" data-sb-reveal>
      <div class="sb-meta-landing__product-fit-grid">
        <div class="sb-meta-landing__product-fit-media">
          {% if landing_secondary_media != blank %}
            <div class="sb-meta-landing__product-fit-media-card" data-sb-parallax="0.025">
              {{
                landing_secondary_media
                | image_url: width: 1200
                | image_tag:
                  class: 'sb-meta-landing__product-fit-image',
                  widths: '480, 720, 960, 1200',
                  sizes: '(min-width: 990px) 42vw, 100vw',
                  alt: landing_product.title,
                  loading: 'lazy'
              }}
            </div>
          {% elsif landing_primary_media != blank %}
            <div class="sb-meta-landing__product-fit-media-card" data-sb-parallax="0.025">
              {{
                landing_primary_media
                | image_url: width: 1200
                | image_tag:
                  class: 'sb-meta-landing__product-fit-image',
                  widths: '480, 720, 960, 1200',
                  sizes: '(min-width: 990px) 42vw, 100vw',
                  alt: landing_product.title,
                  loading: 'lazy'
              }}
            </div>
          {% endif %}
        </div>

        <div class="sb-meta-landing__product-fit-copy">
          <p class="sb-meta-landing__eyebrow font-caption weight-semibold">Why Wave</p>
          <h2 class="sb-meta-landing__section-title font-title weight-bold">Built to be your first real monitoring upgrade</h2>
          <p class="sb-meta-landing__section-subhead font-body weight-regular">
            Wave is not meant to overwhelm beginners with complexity. It is meant to give you the essential benefits of real in-ear monitoring in a clear, practical format.
          </p>

          <div class="sb-meta-landing__feature-list">
            <button
              class="sb-meta-landing__feature-item"
              type="button"
              data-sb-modal-open
              data-sb-modal-title="Zero-latency wired sound"
              data-sb-modal-body="Because Wave stays wired, what you hear arrives when you play it. That matters for practicing to a click, locking into backing tracks, and keeping your timing honest."
            >
              <h3 class="sb-meta-landing__feature-title font-callout weight-bold">Zero-latency wired sound</h3>
              <p class="sb-meta-landing__feature-copy font-body weight-regular">
                Stay locked in without the delay common in wireless listening setups.
              </p>
            </button>

            <button
              class="sb-meta-landing__feature-item"
              type="button"
              data-sb-modal-open
              data-sb-modal-title="Passive noise isolation"
              data-sb-modal-body="A better seal means less of the room competes with your mix. You hear more of the signal you care about without needing to crank the volume just to make details out."
            >
              <h3 class="sb-meta-landing__feature-title font-callout weight-bold">Passive noise isolation</h3>
              <p class="sb-meta-landing__feature-copy font-body weight-regular">
                Foam tips help block outside noise so your music comes through more clearly.
              </p>
            </button>

            <button
              class="sb-meta-landing__feature-item"
              type="button"
              data-sb-modal-open
              data-sb-modal-title="Lightweight comfort"
              data-sb-modal-body="A first IEM should feel easy to wear, not like a technical obstacle. The lighter, more comfortable the fit, the more likely you are to keep using it through longer sessions."
            >
              <h3 class="sb-meta-landing__feature-title font-callout weight-bold">Lightweight comfort</h3>
              <p class="sb-meta-landing__feature-copy font-body weight-regular">
                Designed to stay comfortable through longer practice sessions, rehearsals, and performances.
              </p>
            </button>

            <button
              class="sb-meta-landing__feature-item"
              type="button"
              data-sb-modal-open
              data-sb-modal-title="Musician-ready build"
              data-sb-modal-body="Wave is built around actual rehearsal and performance conditions, with a more stable fit and sweat-ready construction that makes more sense for musicians than everyday consumer earbuds."
            >
              <h3 class="sb-meta-landing__feature-title font-callout weight-bold">Musician-ready build</h3>
              <p class="sb-meta-landing__feature-copy font-body weight-regular">
                Sweat-resistant, stable fit, and designed for real use beyond casual listening.
              </p>
            </button>

            <button
              class="sb-meta-landing__feature-item"
              type="button"
              data-sb-modal-open
              data-sb-modal-title="Replaceable cable"
              data-sb-modal-body="Replaceable parts make a first serious monitoring setup feel less disposable. If a cable wears out, you are not forced to replace the whole pair just to keep using it."
            >
              <h3 class="sb-meta-landing__feature-title font-callout weight-bold">Replaceable cable</h3>
              <p class="sb-meta-landing__feature-copy font-body weight-regular">
                A smarter long-term setup than disposable everyday earbuds.
              </p>
            </button>
          </div>
        </div>
      </div>
    </section>

