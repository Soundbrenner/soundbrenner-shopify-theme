<style>
  .sb-meta-landing {
    --sb-meta-section-spacing: 64px;
    --sb-meta-anchor-offset: 96px;
    background:
      radial-gradient(circle at top left, rgba(0, 181, 156, 0.08), transparent 24%),
      linear-gradient(180deg, var(--sb-color-neutral-100) 0%, #f9fafc 48%, var(--sb-color-neutral-100) 100%);
    color: var(--sb-color-neutral-900);
    padding: var(--sb-space-64) var(--sb-space-20) calc(var(--sb-space-64) + 96px);
    position: relative;
    width: 100%;
  }

  .sb-meta-landing__shell {
    margin: 0 auto;
    max-width: 1240px;
    position: relative;
    width: 100%;
  }

  .sb-meta-landing__shell > * {
    position: relative;
    z-index: 1;
  }

  .sb-meta-landing__hero {
    align-items: start;
    border-radius: calc(var(--sb-radius-card) + 0.5rem);
    display: grid;
    gap: var(--sb-space-32);
    grid-template-columns: minmax(0, 1fr);
    overflow: hidden;
    padding: clamp(1.5rem, 4vw, 3rem);
    position: relative;
    width: 100%;
  }

  .sb-meta-landing__hero > * {
    position: relative;
    z-index: 1;
  }

  .sb-meta-landing__hero--with-background {
    background-color: #050607;
    background-image: var(--sb-meta-hero-image);
    background-position: 72% center;
    background-repeat: no-repeat;
    background-size: cover;
    min-height: clamp(32rem, 72vw, 46rem);
  }

  .sb-meta-landing__hero--with-background::before {
    background:
      linear-gradient(90deg, rgba(4, 6, 8, 0.96) 0%, rgba(4, 6, 8, 0.9) 28%, rgba(4, 6, 8, 0.62) 48%, rgba(4, 6, 8, 0.24) 68%, rgba(4, 6, 8, 0.08) 100%),
      linear-gradient(180deg, rgba(4, 6, 8, 0.18) 0%, rgba(4, 6, 8, 0.54) 100%);
    box-shadow: inset 0 -120px 140px rgba(0, 0, 0, 0.5);
    content: '';
    inset: 0;
    position: absolute;
    z-index: 0;
