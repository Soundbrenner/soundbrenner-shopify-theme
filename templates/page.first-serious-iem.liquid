<script>
  (() => {
    const revealNodes = Array.from(document.querySelectorAll('[data-sb-reveal]'));
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const modalRoot = document.querySelector('[data-sb-modal]');
    const modalTitle = modalRoot?.querySelector('#sb-meta-landing-modal-title');
    const modalBody = modalRoot?.querySelector('#sb-meta-landing-modal-body');
    const modalOpeners = Array.from(document.querySelectorAll('[data-sb-modal-open]'));
    const modalClosers = Array.from(document.querySelectorAll('[data-sb-modal-close]'));
    const testimonialMarquee = document.querySelector('.sb-meta-landing__testimonial-marquee');
    const testimonialTrack = testimonialMarquee?.querySelector('.sb-meta-landing__testimonial-track');
    let lastFocusedNode = null;

    const closeModal = () => {
      if (!modalRoot) return;
      modalRoot.hidden = true;
      document.documentElement.style.overflow = '';
      if (lastFocusedNode instanceof HTMLElement) lastFocusedNode.focus();
    };

    const openModal = (trigger) => {
      if (!modalRoot || !modalTitle || !modalBody) return;
      modalTitle.textContent = trigger.getAttribute('data-sb-modal-title') || '';
      modalBody.textContent = trigger.getAttribute('data-sb-modal-body') || '';
      lastFocusedNode = trigger;
      modalRoot.hidden = false;
      document.documentElement.style.overflow = 'hidden';
      modalRoot.querySelector('.sb-meta-landing__modal-close')?.focus();
    };

    modalOpeners.forEach((trigger) => {
      trigger.addEventListener('click', () => openModal(trigger));
    });

    modalClosers.forEach((trigger) => {
      trigger.addEventListener('click', closeModal);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && modalRoot && !modalRoot.hidden) {
        closeModal();
      }
    });

    if (!reduceMotion && testimonialMarquee instanceof HTMLElement && testimonialTrack instanceof HTMLElement) {
      let testimonialFrame = 0;
      let lastTimestamp = 0;
      let isTestimonialPaused = false;

      const stepTestimonials = (timestamp) => {
        if (!testimonialMarquee.isConnected) return;

        if (isTestimonialPaused) {
          lastTimestamp = timestamp;
          testimonialFrame = window.requestAnimationFrame(stepTestimonials);
          return;
        }

        if (!lastTimestamp) lastTimestamp = timestamp;

        const maxScroll = Math.max(0, testimonialTrack.scrollWidth - testimonialMarquee.clientWidth);
        if (maxScroll <= 0) {
          testimonialMarquee.scrollLeft = 0;
          lastTimestamp = timestamp;
          testimonialFrame = window.requestAnimationFrame(stepTestimonials);
          return;
        }

        const delta = timestamp - lastTimestamp;
        const nextScroll = testimonialMarquee.scrollLeft + (delta * 42) / 1000;
        testimonialMarquee.scrollLeft = nextScroll >= maxScroll ? 0 : nextScroll;
        lastTimestamp = timestamp;
        testimonialFrame = window.requestAnimationFrame(stepTestimonials);
      };

      const pauseTestimonials = () => {
        isTestimonialPaused = true;
      };

      const resumeTestimonials = () => {
        isTestimonialPaused = false;
      };

      testimonialMarquee.addEventListener('mouseenter', pauseTestimonials);
      testimonialMarquee.addEventListener('mouseleave', resumeTestimonials);
      testimonialMarquee.addEventListener('focusin', pauseTestimonials);
      testimonialMarquee.addEventListener('focusout', resumeTestimonials);
      testimonialFrame = window.requestAnimationFrame(stepTestimonials);
    }

    if (reduceMotion || typeof window.IntersectionObserver !== 'function') {
      revealNodes.forEach((node) => node.classList.add('is-visible'));
    } else {
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('is-visible');
            revealObserver.unobserve(entry.target);
          });
        },
        { threshold: 0.14, rootMargin: '0px 0px -8% 0px' }
      );

      revealNodes.forEach((node) => revealObserver.observe(node));
    }

    const parallaxNodes = Array.from(document.querySelectorAll('[data-sb-parallax]'));
    if (reduceMotion || !parallaxNodes.length) return;

    let ticking = false;

    const updateParallax = () => {
      ticking = false;

      parallaxNodes.forEach((node) => {
        const speed = Number.parseFloat(node.getAttribute('data-sb-parallax') || '0');
        if (!Number.isFinite(speed) || speed === 0) return;

        const rect = node.getBoundingClientRect();
        const viewportHeight = window.innerHeight || document.documentElement.clientHeight || 0;
        const progress = (rect.top + rect.height * 0.5 - viewportHeight * 0.5) / viewportHeight;
        const translateY = progress * speed * -120;
        node.style.setProperty('--sb-parallax-y', `${translateY.toFixed(2)}px`);
      });
    };

    const requestParallax = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(updateParallax);
    };

    updateParallax();
    window.addEventListener('scroll', requestParallax, { passive: true });
    window.addEventListener('resize', requestParallax);
  })();
</script>
