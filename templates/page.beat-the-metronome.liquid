  <script>
    (() => {
      const root = document.getElementById('sb-beat-the-metronome-page');
      if (!root) return;

      const config = {
        playBeats: 4,
        attemptsForMercy: 2,
        passThreshold: 2,
        mercyPassThreshold: 1,
        betweenRoundDelayMs: 1150,
        playbackLeadInMs: 260,
      };

      const roundBank = [
        {
          bpm: 84,
          strictOptions: [72, 84, 96],
          mercyOptions: [60, 84, 108],
        },
        {
          bpm: 116,
          strictOptions: [104, 116, 128],
          mercyOptions: [92, 116, 140],
        },
        {
          bpm: 144,
          strictOptions: [132, 144, 156],
          mercyOptions: [120, 144, 168],
        },
      ];

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const startButton = root.querySelector('[data-start-button]');
      const successShopLink = root.querySelector('[data-success-shop-link]');
      const tryAgainButton = root.querySelector('[data-try-again-button]');
      const pulseStage = root.querySelector('[data-pulse-stage]');
      const pulseCore = root.querySelector('[data-pulse-core]');
      const roundLabel = root.querySelector('[data-round-label]');
      const feedbackHeading = root.querySelector('[data-feedback-heading]');
      const feedbackBody = root.querySelector('[data-feedback-body]');
      const optionsWrap = root.querySelector('[data-options]');
      const optionButtons = Array.from(root.querySelectorAll('[data-option-button]'));
      const successPanel = root.querySelector('[data-success-panel]');
      const retryPanel = root.querySelector('[data-retry-panel]');
      const retryCopy = root.querySelector('[data-retry-copy]');
      const mercyCopy = root.querySelector('[data-mercy-copy]');
      const finalScoreSuccess = root.querySelector('[data-final-score-success]');
      const finalScoreRetry = root.querySelector('[data-final-score-retry]');
      const successHeading = root.querySelector('[data-success-heading]');
      const successBody = root.querySelector('[data-success-body]');
      const unlockAnywayButtons = Array.from(root.querySelectorAll('[data-unlock-anyway-button]'));
      const liveRegion = root.querySelector('[data-live-region]');
      const trackDots = Array.from(root.querySelectorAll('[data-track-dot]'));
      const arenaInner = root.querySelector('.sb-beat__arena-inner');

      const state = {
        mode: 'idle',
        attempts: 0,
        failedAttempts: 0,
        mercyMode: false,
        roundIndex: 0,
        score: 0,
        roundResults: [],
        currentBeatDisplay: '',
        hasAnsweredCurrentRound: false,
        audioContext: null,
        activeRounds: [],
        timers: [],
        pulseResetTimer: 0,
        liveRegionTimer: 0,
      };

      let stableHeightFrame = 0;

      const shuffle = (values) => {
        const next = [...values];
        for (let index = next.length - 1; index > 0; index -= 1) {
          const swapIndex = Math.floor(Math.random() * (index + 1));
          [next[index], next[swapIndex]] = [next[swapIndex], next[index]];
        }
        return next;
      };

      const buildOptionSet = (values, answerIndex) => {
        const [lowValue, correctValue, highValue] = values;
        const distractors = shuffle([lowValue, highValue]);
        const optionSet = [];
        let distractorIndex = 0;

        for (let index = 0; index < 3; index += 1) {
          if (index === answerIndex) {
            optionSet.push(correctValue);
            continue;
          }

          optionSet.push(distractors[distractorIndex]);
          distractorIndex += 1;
        }

        return optionSet;
      };

      const clearTimers = () => {
        state.timers.forEach((timerId) => window.clearTimeout(timerId));
        state.timers = [];

        if (state.pulseResetTimer) {
          window.clearTimeout(state.pulseResetTimer);
          state.pulseResetTimer = 0;
        }

        if (state.liveRegionTimer) {
          window.clearTimeout(state.liveRegionTimer);
          state.liveRegionTimer = 0;
        }
      };

      const setLiveMessage = (message) => {
        if (!liveRegion) return;
        liveRegion.textContent = '';
        window.clearTimeout(state.liveRegionTimer);
        state.liveRegionTimer = window.setTimeout(() => {
          liveRegion.textContent = message;
        }, 24);
      };

      const focusSoon = (element) => {
        window.setTimeout(() => {
          if (element) element.focus();
        }, 40);
      };

      const updateStableArenaHeight = () => {
        if (!arenaInner) return;

        const hiddenState = {
          mode: state.mode,
          rootState: root.dataset.state,
          startHidden: startButton.hidden,
          optionsHidden: optionsWrap.hidden,
          successHidden: successPanel.hidden,
          retryHidden: retryPanel.hidden,
          mercyHidden: mercyCopy.hidden,
          feedbackHeading: feedbackHeading.textContent,
          feedbackBody: feedbackBody.textContent,
          roundLabel: roundLabel.textContent,
          successHeading: successHeading.textContent,
          successBody: successBody.textContent,
          finalScoreSuccess: finalScoreSuccess.textContent,
          finalScoreRetry: finalScoreRetry.textContent,
          retryCopy: retryCopy.textContent,
        };

        const measure = (setup) => {
          setup();
          return arenaInner.getBoundingClientRect().height;
        };

        const heights = [
          measure(() => {
            root.dataset.state = 'idle';
            startButton.hidden = false;
            optionsWrap.hidden = true;
            successPanel.hidden = true;
            retryPanel.hidden = true;
            mercyCopy.hidden = true;
            feedbackHeading.textContent = '';
            feedbackBody.textContent = '';
            roundLabel.textContent = '';
          }),
          measure(() => {
            root.dataset.state = 'guessing';
            startButton.hidden = true;
            optionsWrap.hidden = false;
            successPanel.hidden = true;
            retryPanel.hidden = true;
            mercyCopy.hidden = true;
            feedbackHeading.textContent = 'What BPM was that?';
            feedbackBody.textContent = '';
            roundLabel.textContent = '';
          }),
          measure(() => {
            root.dataset.state = 'retry';
            startButton.hidden = true;
            optionsWrap.hidden = true;
            successPanel.hidden = true;
            retryPanel.hidden = false;
            mercyCopy.hidden = false;
            feedbackHeading.textContent = 'Close. Try again.';
            feedbackBody.textContent = 'Almost there. Replay the beats and trust your ear on the next round.';
            retryCopy.textContent = 'Next try gets easier. We’ll widen the BPM spread so the right answer stands out more clearly.';
            finalScoreRetry.textContent = `Score: ${roundBank.length - 1} / ${roundBank.length}`;
            roundLabel.textContent = `You got ${roundBank.length - 1} of ${roundBank.length} right.`;
          }),
          measure(() => {
            root.dataset.state = 'success';
            startButton.hidden = true;
            optionsWrap.hidden = true;
            successPanel.hidden = false;
            retryPanel.hidden = true;
            mercyCopy.hidden = true;
            feedbackHeading.textContent = 'Nice. You earned it.';
            feedbackBody.textContent = '';
            successHeading.textContent = 'Nice. You earned it.';
            successBody.textContent = '';
            finalScoreSuccess.textContent = `Score: ${roundBank.length} / ${roundBank.length}`;
            roundLabel.textContent = '';
          }),
          measure(() => {
            root.dataset.state = 'success';
            startButton.hidden = true;
            optionsWrap.hidden = true;
            successPanel.hidden = false;
            retryPanel.hidden = true;
            mercyCopy.hidden = true;
            feedbackHeading.textContent = '';
            feedbackBody.textContent = '';
            successHeading.textContent = 'Taking the easy route? We respect it.';
            successBody.textContent = '';
            finalScoreSuccess.textContent = `Score: 0 / ${roundBank.length}`;
            roundLabel.textContent = '';
          }),
        ];

        root.dataset.state = hiddenState.rootState;
        startButton.hidden = hiddenState.startHidden;
        optionsWrap.hidden = hiddenState.optionsHidden;
        successPanel.hidden = hiddenState.successHidden;
        retryPanel.hidden = hiddenState.retryHidden;
        mercyCopy.hidden = hiddenState.mercyHidden;
        feedbackHeading.textContent = hiddenState.feedbackHeading;
        feedbackBody.textContent = hiddenState.feedbackBody;
        roundLabel.textContent = hiddenState.roundLabel;
        successHeading.textContent = hiddenState.successHeading;
        successBody.textContent = hiddenState.successBody;
        finalScoreSuccess.textContent = hiddenState.finalScoreSuccess;
        finalScoreRetry.textContent = hiddenState.finalScoreRetry;
        retryCopy.textContent = hiddenState.retryCopy;
        setMode(hiddenState.mode);

        const desktopHeightTrim = window.innerWidth >= 990 ? 56 : 0;
        const stableHeight = Math.ceil(Math.max(...heights) - desktopHeightTrim);
        root.style.setProperty('--sb-beat-arena-inner-min-height', `${stableHeight}px`);
      };

      const scheduleStableArenaHeight = () => {
        window.cancelAnimationFrame(stableHeightFrame);
        stableHeightFrame = window.requestAnimationFrame(() => {
          updateStableArenaHeight();
        });
      };

      const setPulseDisplay = (label = '') => {
        pulseCore.textContent = label;
      };

      const setMode = (mode) => {
        state.mode = mode;
        root.dataset.state = mode;
      };

      const setPulse = (pulseState, label) => {
        pulseStage.dataset.pulse = pulseState;
        if (typeof label === 'string') {
          setPulseDisplay(label);
        }

        if (prefersReducedMotion || pulseState === 'success') return;

        window.clearTimeout(state.pulseResetTimer);
        if (pulseState === 'idle') return;

        state.pulseResetTimer = window.setTimeout(() => {
          if (state.mode === 'success') {
            pulseStage.dataset.pulse = 'success';
            setPulseDisplay('');
            return;
          }

          pulseStage.dataset.pulse = 'idle';
          if (state.mode === 'playing') {
            setPulseDisplay(`${state.currentBeatDisplay}`);
            return;
          }

          if (state.mode === 'guessing') {
            setPulseDisplay('');
          }
        }, 220);
      };

      const updateTrackDots = (activeIndex = -1) => {
        trackDots.forEach((dot, index) => {
          if (state.roundResults[index]) {
            dot.dataset.dotState = state.roundResults[index];
          } else if (index === activeIndex) {
            dot.dataset.dotState = 'active';
          } else {
            dot.dataset.dotState = 'pending';
          }
        });
      };

      const resetOptionButtons = () => {
        optionButtons.forEach((button) => {
          button.disabled = true;
          delete button.dataset.answered;
          delete button.dataset.correct;
          button.textContent = '';
          button.value = '';
        });
      };

      const setOptionsForRound = () => {
        const round = state.activeRounds[state.roundIndex];

        optionButtons.forEach((button, index) => {
          button.textContent = `${round.options[index]} BPM`;
          button.value = `${round.options[index]}`;
          button.disabled = false;
          delete button.dataset.answered;
          delete button.dataset.correct;
        });
      };

      const setIdleUi = () => {
        setMode('idle');
        startButton.hidden = false;
        optionsWrap.hidden = true;
        successPanel.hidden = true;
        retryPanel.hidden = true;
        mercyCopy.hidden = true;
        resetOptionButtons();
        state.roundIndex = 0;
        state.score = 0;
        state.roundResults = [];
        feedbackHeading.textContent = '';
        feedbackBody.textContent = '';
        roundLabel.textContent = '';
        state.currentBeatDisplay = '';
        setPulse('idle', '');
        updateTrackDots();
        setLiveMessage('Challenge ready. Press start when you are ready.');
      };

      const primeAudio = async () => {
        if (!window.AudioContext && !window.webkitAudioContext) return null;

        if (!state.audioContext) {
          const AudioContextConstructor = window.AudioContext || window.webkitAudioContext;
          state.audioContext = new AudioContextConstructor();
        }

        if (state.audioContext.state === 'suspended') {
          try {
            await state.audioContext.resume();
          } catch (_) {
            return null;
          }
        }

        return state.audioContext;
      };

      const playClick = (accentLevel = 1, scheduledTime = null) => {
        const audioContext = state.audioContext;
        if (!audioContext || audioContext.state !== 'running') return;

        const oscillator = audioContext.createOscillator();
        const gainNode = audioContext.createGain();
        const startTime = scheduledTime ?? audioContext.currentTime;
        const gainAmount = accentLevel > 1 ? 0.07 : 0.052;

        oscillator.type = 'triangle';
        oscillator.frequency.setValueAtTime(accentLevel > 1 ? 1580 : 1320, startTime);

        gainNode.gain.setValueAtTime(0.0001, startTime);
        gainNode.gain.exponentialRampToValueAtTime(gainAmount, startTime + 0.004);
        gainNode.gain.exponentialRampToValueAtTime(0.0001, startTime + 0.1);

        oscillator.connect(gainNode);
        gainNode.connect(audioContext.destination);
        oscillator.start(startTime);
        oscillator.stop(startTime + 0.11);
      };

      const queueTimeout = (callback, delay) => {
        const timerId = window.setTimeout(callback, Math.max(0, delay));
        state.timers.push(timerId);
      };

      const currentRound = () => state.activeRounds[state.roundIndex];

      const finishPlayback = () => {
        setMode('guessing');
        setPulse('idle', '');
        feedbackHeading.textContent = 'What BPM was that?';
        feedbackBody.textContent = '';
        roundLabel.textContent = '';
        setOptionsForRound();
        optionsWrap.hidden = false;
        optionButtons[0].focus();
        setLiveMessage(`Round ${state.roundIndex + 1}. Choose the BPM.`);
      };

      const playRound = async () => {
        const round = currentRound();
        if (!round) return;

        clearTimers();
        state.hasAnsweredCurrentRound = false;
        resetOptionButtons();
        optionsWrap.hidden = true;
        updateTrackDots(state.roundIndex);
        setMode('playing');
        feedbackHeading.textContent = '';
        feedbackBody.textContent = state.mercyMode
          ? 'The BPM options are spread further apart on this attempt, so trust the feel of the pulse.'
          : '';
        roundLabel.textContent = '';
        state.currentBeatDisplay = '';
        setLiveMessage(`Playing round ${state.roundIndex + 1}. Listen to the tempo.`);

        await primeAudio();

        const beatInterval = 60000 / round.bpm;
        const audioStartTime =
          state.audioContext && state.audioContext.state === 'running'
            ? state.audioContext.currentTime + config.playbackLeadInMs / 1000
            : null;

        for (let beatIndex = 0; beatIndex < config.playBeats; beatIndex += 1) {
          queueTimeout(() => {
            state.currentBeatDisplay = `${beatIndex + 1}`;
            setPulse('playing', `${state.currentBeatDisplay}`);
          }, config.playbackLeadInMs + beatIndex * beatInterval);

          if (audioStartTime !== null) {
            playClick(beatIndex === 0 ? 2 : 1, audioStartTime + (beatIndex * beatInterval) / 1000);
          }
        }

        queueTimeout(finishPlayback, config.playbackLeadInMs + config.playBeats * beatInterval + 120);
      };

      const prepareRounds = () => {
        const answerSlots = shuffle([0, 1, 2]);

        state.activeRounds = roundBank.map((round) => ({
          bpm: round.bpm,
          options: buildOptionSet(
            state.mercyMode ? round.mercyOptions : round.strictOptions,
            answerSlots.shift()
          ),
        }));
      };

      const finishChallenge = () => {
        const threshold = state.mercyMode ? config.mercyPassThreshold : config.passThreshold;
        const won = state.score >= threshold;
        const scoreLine = `Score: ${state.score} / ${roundBank.length}`;

        optionsWrap.hidden = true;
        updateTrackDots(-1);

        if (won) {
          setMode('success');
          startButton.hidden = true;
          successPanel.hidden = false;
          pulseStage.dataset.pulse = 'success';
          state.currentBeatDisplay = '';
          setPulseDisplay('');
          feedbackHeading.textContent = 'Nice. You earned it.';
          feedbackBody.textContent = '';
          successHeading.textContent = 'Nice. You earned it.';
          successBody.textContent = '';
          finalScoreSuccess.textContent = scoreLine;
          roundLabel.textContent = '';
          setLiveMessage('Success. Your discount code is BEAT25.');
          focusSoon(successShopLink);
          return;
        }

        state.failedAttempts += 1;
        setMode('retry');
        retryPanel.hidden = false;
        feedbackHeading.textContent = 'Close. Try again.';
        feedbackBody.textContent = 'Almost there. Replay the beats and trust your ear on the next round.';
        finalScoreRetry.textContent = scoreLine;
        retryCopy.textContent = state.failedAttempts >= config.attemptsForMercy
          ? 'Next try gets easier. We’ll widen the BPM spread so the right answer stands out more clearly.'
          : 'Almost there. Replay the beats and trust your ear on the next round.';
        mercyCopy.hidden = state.failedAttempts < config.attemptsForMercy;
        roundLabel.textContent = `You got ${state.score} of ${roundBank.length} right.`;
        state.currentBeatDisplay = '';
        setPulse('idle', '');
        setLiveMessage('Close. Try again.');
        focusSoon(tryAgainButton);
      };

      const softUnlock = () => {
        optionsWrap.hidden = true;
        retryPanel.hidden = true;
        startButton.hidden = true;
        successPanel.hidden = false;
        setMode('success');
        pulseStage.dataset.pulse = 'success';
        state.currentBeatDisplay = '';
        setPulseDisplay('');
        finalScoreSuccess.textContent = `Score: ${state.score} / ${roundBank.length}`;
        successHeading.textContent = 'Taking the easy route? We respect it.';
        successBody.textContent = '';
        feedbackHeading.textContent = '';
        feedbackBody.textContent = '';
        roundLabel.textContent = '';
        setLiveMessage('Success. Your discount code is BEAT25.');
        focusSoon(successShopLink);
      };

      const handleOptionSelection = (button) => {
        if (state.mode !== 'guessing' || state.hasAnsweredCurrentRound) return;

        state.hasAnsweredCurrentRound = true;
        const round = currentRound();
        const guessedBpm = Number.parseInt(button.value, 10);
        const correct = guessedBpm === round.bpm;

        optionButtons.forEach((optionButton) => {
          const optionValue = Number.parseInt(optionButton.value, 10);
          optionButton.disabled = true;

          if (optionValue === round.bpm) {
            optionButton.dataset.answered = 'true';
            optionButton.dataset.correct = 'true';
            return;
          }

          if (optionButton === button) {
            optionButton.dataset.answered = 'true';
            optionButton.dataset.correct = 'false';
            return;
          }

          delete optionButton.dataset.answered;
          delete optionButton.dataset.correct;
        });

        if (correct) {
          state.score += 1;
          state.roundResults[state.roundIndex] = 'correct';
          feedbackHeading.textContent = 'That’s it.';
          feedbackBody.textContent = '';
        } else {
          state.roundResults[state.roundIndex] = 'incorrect';
          feedbackHeading.textContent = 'Not quite.';
          feedbackBody.textContent = `That beat was ${round.bpm} BPM.`;
        }

        updateTrackDots();
        setLiveMessage(`${correct ? 'Correct' : 'Incorrect'}. ${round.bpm} BPM.`);

        queueTimeout(() => {
          state.roundIndex += 1;

          if (state.roundIndex >= roundBank.length) {
            finishChallenge();
            return;
          }

          playRound();
        }, config.betweenRoundDelayMs);
      };

      const startChallenge = async () => {
        if (state.mode === 'playing' || state.mode === 'guessing') return;

        clearTimers();
        state.attempts += 1;
        state.mercyMode = state.failedAttempts >= config.attemptsForMercy;
        state.roundIndex = 0;
        state.score = 0;
        state.roundResults = [];
        state.hasAnsweredCurrentRound = false;
        prepareRounds();
        startButton.hidden = true;
        successPanel.hidden = true;
        retryPanel.hidden = true;
        mercyCopy.hidden = true;
        playRound();
      };

      startButton.addEventListener('click', () => {
        startChallenge();
      });

      optionButtons.forEach((button) => {
        button.addEventListener('click', () => {
          handleOptionSelection(button);
        });
      });

      tryAgainButton.addEventListener('click', () => {
        clearTimers();
        setIdleUi();
        startChallenge();
      });

      unlockAnywayButtons.forEach((button) => {
        button.addEventListener('click', () => {
          clearTimers();
          softUnlock();
        });
      });

      document.addEventListener('visibilitychange', () => {
        if (document.visibilityState !== 'hidden') return;
        if (state.mode !== 'playing' && state.mode !== 'guessing') return;

        clearTimers();
        setMode('retry');
        optionsWrap.hidden = true;
        retryPanel.hidden = false;
        startButton.hidden = false;
        feedbackHeading.textContent = 'Test paused.';
        feedbackBody.textContent = 'The tab changed mid-round, so we reset it for a clean replay.';
        retryCopy.textContent = 'Jump back in when you’re ready.';
        mercyCopy.hidden = true;
        roundLabel.textContent = 'Run reset.';
        state.currentBeatDisplay = '';
        setPulse('idle', '');
        updateTrackDots();
        setLiveMessage('Challenge reset after leaving the page.');
      });

      setIdleUi();
      scheduleStableArenaHeight();
      window.addEventListener('resize', scheduleStableArenaHeight);
    })();
  </script>
</div>
