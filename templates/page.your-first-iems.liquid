{% liquid
  assign wave_product = all_products['wave-in-ear-monitors']
  assign hero_header_image_url = 'https://cdn.shopify.com/s/files/1/1306/4847/files/Affiliate_Kristan_mobile.jpg?v=1773291225'
  assign wave_url = '/products/wave-in-ear-monitors'
  assign wave_price = '$99'
  assign wave_compare_price = ''
  assign wave_rating = '4.7'
  assign wave_reviews_count = '2,824'
  assign wave_media_1 = blank
  assign wave_media_2 = blank
  assign wave_media_3 = blank

  if wave_product != blank
    assign wave_url = wave_product.url

    assign wave_variant = wave_product.selected_or_first_available_variant
    if wave_variant != blank
      assign wave_price = wave_variant.price | money_without_trailing_zeros
      if wave_variant.compare_at_price > wave_variant.price
        assign wave_compare_price = wave_variant.compare_at_price | money_without_trailing_zeros
      endif
    endif

    assign wave_media_1 = wave_product.featured_media.preview_image
    if wave_media_1 == blank and wave_product.media.size > 0
      assign wave_media_1 = wave_product.media[0].preview_image
    endif
    if wave_product.media.size > 1
      assign wave_media_2 = wave_product.media[1].preview_image
    endif
    if wave_product.media.size > 2
      assign wave_media_3 = wave_product.media[2].preview_image
    endif
  endif

  assign cta_label = 'Order Wave - ' | append: wave_price
  assign nav_cta_label = 'Get Wave - ' | append: wave_price
%}

