            if (!Number.isFinite(ratingNumber) || !Number.isFinite(countNumber)) return;

            button.dataset.sbKlaviyoRatingValue = `${ratingNumber}`;
            button.dataset.sbKlaviyoReviewCount = `${countNumber}`;

            const formattedCount = numberFormatter.format(countNumber);
            const formattedRating = ratingFormatter.format(ratingNumber);
            const reviewsCountCopy = reviewsCountTemplate.replace(/__COUNT__/g, formattedCount);
            const copy = `${formattedRating} (${reviewsCountCopy})`;
            const localizedAria = ratingSummaryTemplate
              .replace(/__RATING__/g, formattedRating)
