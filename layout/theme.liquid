        display: none !important;
      }

      [data-testid='POPUP'] .klaviyo-close-form::before {
        -webkit-mask-image: url('{{ 'icon-cancel-circle.svg' | asset_url }}');
        -webkit-mask-position: center;
        -webkit-mask-repeat: no-repeat;
        -webkit-mask-size: var(--sb-klaviyo-popup-close-size, 30px) var(--sb-klaviyo-popup-close-size, 30px);
        background: currentColor;
        content: '';
        display: block;
        height: var(--sb-klaviyo-popup-close-size, 30px);
        left: 50%;
        mask-image: url('{{ 'icon-cancel-circle.svg' | asset_url }}');
        mask-position: center;
        mask-repeat: no-repeat;
        mask-size: var(--sb-klaviyo-popup-close-size, 30px) var(--sb-klaviyo-popup-close-size, 30px);
        pointer-events: none;
        position: absolute;
        top: 50%;
        transform: translate(-50%, -50%);
        width: var(--sb-klaviyo-popup-close-size, 30px);
        z-index: 1;
      }

      [data-testid='POPUP'] .klaviyo-close-form::after {
        background: var(--sb-color-neutral-900);
        border-radius: 999px;
        content: '';
        display: block;
        height: calc(var(--sb-klaviyo-popup-close-size, 30px) - 2px);
        left: 50%;
        pointer-events: none;
        position: absolute;
        top: 50%;
        transform: translate(-50%, -50%);
        width: calc(var(--sb-klaviyo-popup-close-size, 30px) - 2px);
        z-index: 0;
      }

      [data-testid='POPUP'] .klaviyo-close-form:focus-visible::after,
      [data-testid='POPUP'] .klaviyo-close-form:active::after {
        background: var(--sb-color-primary-500);
      }

      @media (hover: hover) and (pointer: fine) {
        [data-testid='POPUP'] .klaviyo-close-form:hover::after {
          background: var(--sb-color-primary-500);
        }
      }

    </style>
    <script>
      (() => {
        const popupOpenClass = 'sb-klaviyo-popup-open';
        const markerSelector =
          '.klaviyo-form, [class*="klaviyo-form-"], [data-testid^="klaviyo-form-"], iframe[src*="klaviyo"]';
        const numberFormatter = new Intl.NumberFormat(document.documentElement.lang || undefined);
        const popupLocaleCopy = {
          dialogLabel: {{ 'sb.klaviyo_popup.dialog_label' | t | json }},
          closeLabel: {{ 'sb.klaviyo_popup.close_label' | t | json }},
          imageAlt: {{ 'sb.klaviyo_popup.image_alt' | t | json }},
          titleLineOne: {{ 'sb.klaviyo_popup.title_line_1' | t | json }},
          titleLineTwo: {{ 'sb.klaviyo_popup.title_line_2' | t | json }},
          description: {{ 'sb.klaviyo_popup.description' | t | json }},
          emailPlaceholder: {{ 'sb.klaviyo_popup.email_placeholder' | t | json }},
          emailLabel: {{ 'sb.klaviyo_popup.email_label' | t | json }},
          buttonLabel: {{ 'sb.klaviyo_popup.button_label' | t | json }},
          engagementTemplate: {{ 'sb.klaviyo_popup.engagement_counter' | t: count: '__COUNT__' | json }},
          errorRequired: {{ 'sb.klaviyo_popup.error_required' | t | json }},
          errorInvalidEmail: {{ 'sb.klaviyo_popup.error_invalid_email' | t | json }},
          errorGeneric: {{ 'sb.klaviyo_popup.error_generic' | t | json }},
          successTitle: {{ 'sb.klaviyo_popup.success_title' | t | json }},
          successCodeLine: {{ 'sb.klaviyo_popup.success_code_line' | t: code: '__CODE__' | json }},
          successOfferLine: {{ 'sb.klaviyo_popup.success_offer_line' | t | json }},
          successReminderLine: {{ 'sb.klaviyo_popup.success_reminder_line' | t | json }},
          successExpiresIn: {{ 'sb.klaviyo_popup.success_expires_in' | t | json }},
          timerDays: {{ 'sb.klaviyo_popup.timer_days' | t | json }},
          timerHours: {{ 'sb.klaviyo_popup.timer_hours' | t | json }},
          timerMinutes: {{ 'sb.klaviyo_popup.timer_minutes' | t | json }},
          timerSeconds: {{ 'sb.klaviyo_popup.timer_seconds' | t | json }},
        };
        const decodeHtmlEntities = (value) => {
          const source = `${value || ''}`;
          if (!source.includes('&')) return source;
          const decoder = document.createElement('textarea');
          decoder.innerHTML = source;
          return decoder.value;
        };

        const normalizeText = (value) => decodeHtmlEntities(value).replace(/\s+/g, ' ').trim();
        const setNodeText = (node, value) => {
          if (!(node instanceof HTMLElement)) return;
          const nextText = normalizeText(value);
          if (!nextText) return;
          if (normalizeText(node.textContent) === nextText) return;
          node.textContent = nextText;
        };

        const isFooterEmbedContext = (node) =>
          node instanceof HTMLElement && Boolean(node.closest('.sb-footer__newsletter-klaviyo'));

        const getPopupContainer = (node) => {
          if (!(node instanceof HTMLElement)) return null;
          if (isFooterEmbedContext(node)) return null;

          let currentNode = node;
          while (currentNode && currentNode !== document.body) {
            if (!(currentNode instanceof HTMLElement)) break;
            if (isFooterEmbedContext(currentNode)) return null;

            const computedStyle = window.getComputedStyle(currentNode);
            const zIndex = Number.parseInt(computedStyle.zIndex || '0', 10);
            const isDialog = currentNode.getAttribute('role') === 'dialog' || currentNode.getAttribute('aria-modal') === 'true';
            const isPopupLike = computedStyle.position === 'fixed' || (computedStyle.position === 'absolute' && zIndex >= 1000) || isDialog;
            if (isPopupLike) return currentNode;

            currentNode = currentNode.parentElement;
          }

          return null;
        };

        const isVisiblePopup = (node) => {
          if (!(node instanceof HTMLElement)) return false;
          if (node.hasAttribute('hidden') || node.getAttribute('aria-hidden') === 'true') return false;

          const computedStyle = window.getComputedStyle(node);
          if (computedStyle.display === 'none' || computedStyle.visibility === 'hidden') return false;
          if (Number.parseFloat(computedStyle.opacity || '1') <= 0.01) return false;

          const rect = node.getBoundingClientRect();
          if (rect.width < 120 || rect.height < 80) return false;
          if (rect.right <= 0 || rect.bottom <= 0) return false;
          if (rect.left >= window.innerWidth || rect.top >= window.innerHeight) return false;

          return true;
        };

        const extractCounterValue = (text) => {
          const source = `${text || ''}`;
          if (!source) return null;
          const countMatch = source.match(/\d[\d,.]*/);
          if (!countMatch) return null;
          const normalizedCount = Number.parseInt(countMatch[0].replace(/[^\d]/g, ''), 10);
          return Number.isFinite(normalizedCount) ? normalizedCount : null;
        };

        const extractDiscountCode = (text) => {
          const source = normalizeText(text);
          if (!source) return '';
          const labeledMatch = source.match(/discount code[:\s]+([A-Z0-9-]{4,})/i);
          if (labeledMatch && labeledMatch[1]) return labeledMatch[1].toUpperCase();

          const fallbackCandidates = source.match(/\b[A-Z0-9-]{6,}\b/g) || [];
          if (!fallbackCandidates.length) return '';
          const alphaNumericCandidate = fallbackCandidates.find((candidate) => /[A-Z]/.test(candidate) && /\d/.test(candidate));
          if (alphaNumericCandidate) return alphaNumericCandidate.toUpperCase();
          return fallbackCandidates[0].toUpperCase();
        };

        const getLocalizedPopupErrorText = (sourceText) => {
          const normalizedSource = normalizeText(sourceText).toLowerCase();
          if (!normalizedSource) return '';
          if (normalizedSource.includes('required')) return normalizeText(popupLocaleCopy.errorRequired);
          if (
            normalizedSource.includes('email')
            && (normalizedSource.includes('invalid') || normalizedSource.includes('valid'))
          ) {
            return normalizeText(popupLocaleCopy.errorInvalidEmail);
          }
          if (
            normalizedSource.includes('error')
            || normalizedSource.includes('submitting')
            || normalizedSource.includes('try again')
          ) {
            return normalizeText(popupLocaleCopy.errorGeneric);
          }
          return '';
        };

        const getLocalizedTimerLabel = (sourceText) => {
          const normalizedSource = normalizeText(sourceText).toLowerCase();
          if (!normalizedSource || /\d/.test(normalizedSource)) return '';
          if (normalizedSource === 'day' || normalizedSource === 'days') {
            return normalizeText(popupLocaleCopy.timerDays);
          }
          if (normalizedSource === 'hour' || normalizedSource === 'hours') {
            return normalizeText(popupLocaleCopy.timerHours);
          }
          if (
            normalizedSource === 'min'
            || normalizedSource === 'mins'
            || normalizedSource === 'minute'
            || normalizedSource === 'minutes'
          ) {
            return normalizeText(popupLocaleCopy.timerMinutes);
          }
          if (
            normalizedSource === 'sec'
            || normalizedSource === 'secs'
            || normalizedSource === 'second'
            || normalizedSource === 'seconds'
          ) {
            return normalizeText(popupLocaleCopy.timerSeconds);
          }
          return '';
        };

        const popupCloseButtonPlacements = new WeakMap();

        const syncPopupCloseButtonPlacement = (popupForm, popupDialog, hasEmailInput) => {
          if (!(popupForm instanceof HTMLFormElement) || !(popupDialog instanceof HTMLElement)) return;

          const closeButton = popupDialog.querySelector('.klaviyo-close-form');
          if (!(closeButton instanceof HTMLButtonElement)) return;

          let originalPlacement = popupCloseButtonPlacements.get(closeButton);
          if (!originalPlacement) {
            originalPlacement = {
              parent: closeButton.parentElement,
              nextSibling: closeButton.nextSibling,
            };
            popupCloseButtonPlacements.set(closeButton, originalPlacement);
          }

          const activeCloseRow = popupForm.querySelector('.sb-klaviyo-popup-close-row');
          if (
            originalPlacement.parent instanceof HTMLElement
            && closeButton.parentElement !== originalPlacement.parent
          ) {
            if (
              originalPlacement.nextSibling
              && originalPlacement.nextSibling.parentNode === originalPlacement.parent
            ) {
              originalPlacement.parent.insertBefore(closeButton, originalPlacement.nextSibling);
            } else {
              originalPlacement.parent.appendChild(closeButton);
            }
          }

          if (activeCloseRow instanceof HTMLElement && activeCloseRow.childElementCount === 0) {
            activeCloseRow.remove();
          }
        };

        const applyPopupLocalizedCopy = () => {
          const popupForms = document.querySelectorAll("[data-testid='POPUP'] form[data-testid^='klaviyo-form-']");
          popupForms.forEach((popupForm) => {
            if (!(popupForm instanceof HTMLFormElement)) return;

            const popupDialog = popupForm.closest("[data-testid='POPUP'], [role='dialog'][aria-modal='true']");
            if (popupDialog instanceof HTMLElement) {
              const localizedDialogLabel = normalizeText(popupLocaleCopy.dialogLabel);
              if (localizedDialogLabel) popupDialog.setAttribute('aria-label', localizedDialogLabel);

              const closeButton = popupDialog.querySelector('.klaviyo-close-form');
              const localizedCloseLabel = normalizeText(popupLocaleCopy.closeLabel);
              if (closeButton instanceof HTMLButtonElement && localizedCloseLabel) {
                closeButton.setAttribute('aria-label', localizedCloseLabel);
              }
            }

            const popupImage = popupForm.querySelector('img');
            const localizedImageAlt = normalizeText(popupLocaleCopy.imageAlt);
            if (popupImage instanceof HTMLImageElement && localizedImageAlt) {
              popupImage.setAttribute('alt', localizedImageAlt);
            }

            const emailInput = popupForm.querySelector("input[type='email']");
            const hasEmailInput = emailInput instanceof HTMLInputElement;
            popupForm.classList.toggle('sb-klaviyo-popup-form--initial', hasEmailInput);
            popupForm.classList.toggle('sb-klaviyo-popup-form--success', !hasEmailInput);
            if (popupDialog instanceof HTMLElement) {
              popupDialog.classList.toggle('sb-klaviyo-popup--initial', hasEmailInput);
              popupDialog.classList.toggle('sb-klaviyo-popup--success', !hasEmailInput);
              syncPopupCloseButtonPlacement(popupForm, popupDialog, hasEmailInput);
            }

            popupForm
              .querySelectorAll('.sb-klaviyo-popup-copy-code-component')
              .forEach((node) => node.classList.remove('sb-klaviyo-popup-copy-code-component'));
            popupForm
              .querySelectorAll('.sb-klaviyo-popup-success-title-component')
              .forEach((node) => node.classList.remove('sb-klaviyo-popup-success-title-component'));
            popupForm
              .querySelectorAll('.sb-klaviyo-popup-success-body-component')
              .forEach((node) => node.classList.remove('sb-klaviyo-popup-success-body-component'));
            popupForm
              .querySelectorAll('.sb-klaviyo-popup-success-body-richtext')
              .forEach((node) => node.classList.remove('sb-klaviyo-popup-success-body-richtext'));
            popupForm
              .querySelectorAll('.sb-klaviyo-popup-countdown-component')
              .forEach((node) => node.classList.remove('sb-klaviyo-popup-countdown-component'));

            if (hasEmailInput) {
              const titleRoot = popupForm.querySelector("[data-testid='form-row']:nth-of-type(2) [id^='rich-text-']");
              const lineOne = normalizeText(popupLocaleCopy.titleLineOne);
              const lineTwo = normalizeText(popupLocaleCopy.titleLineTwo);
              if (titleRoot instanceof HTMLElement && (lineOne || lineTwo)) {
                titleRoot.classList.add('font-title', 'weight-bold');
                const initialTitleSignature = [lineOne, lineTwo].join('||');
                if (titleRoot.dataset.sbLocalizedTitleSignature !== initialTitleSignature) {
                  titleRoot.replaceChildren();
                  if (lineOne) {
                    const lineOneNode = document.createElement('p');
                    lineOneNode.className = 'font-title weight-bold';
                    lineOneNode.textContent = lineOne;
                    titleRoot.appendChild(lineOneNode);
                  }
                  if (lineTwo) {
                    const lineTwoNode = document.createElement('p');
                    lineTwoNode.className = 'font-title weight-bold';
                    lineTwoNode.textContent = lineTwo;
                    titleRoot.appendChild(lineTwoNode);
                  }
                  titleRoot.dataset.sbLocalizedTitleSignature = initialTitleSignature;
                }
              }

              const descriptionRoot = popupForm.querySelector("[data-testid='form-row']:nth-of-type(3) [id^='rich-text-']");
              const descriptionText = normalizeText(popupLocaleCopy.description);
              if (descriptionRoot instanceof HTMLElement && descriptionText) {
                if (descriptionRoot.dataset.sbLocalizedDescriptionSignature !== descriptionText) {
                  descriptionRoot.replaceChildren();
                  const descriptionNode = document.createElement('div');
                  descriptionNode.textContent = descriptionText;
                  descriptionRoot.appendChild(descriptionNode);
                  descriptionRoot.dataset.sbLocalizedDescriptionSignature = descriptionText;
                }
              }

              const placeholderText = normalizeText(popupLocaleCopy.emailPlaceholder);
              const labelText = normalizeText(popupLocaleCopy.emailLabel) || placeholderText;
              if (placeholderText) emailInput.setAttribute('placeholder', placeholderText);
              if (labelText) emailInput.setAttribute('aria-label', labelText);

              const inputId = `${emailInput.getAttribute('id') || ''}`.trim();
              if (inputId) {
                const inputLabel = popupForm.querySelector(`label[for="${inputId}"]`);
                if (inputLabel instanceof HTMLLabelElement && labelText) {
                  inputLabel.textContent = labelText;
                }
              }

              return;
            }

            const successRichTextRoots = popupForm.querySelectorAll("[id^='rich-text-']");
            const successTitleRoot = successRichTextRoots[0];
            const successBodyRoot = successRichTextRoots[1];
            const successTitleComponent = successTitleRoot instanceof HTMLElement
              ? successTitleRoot.closest("[data-testid='form-component']")
              : null;
            const successBodyComponent = successBodyRoot instanceof HTMLElement
              ? successBodyRoot.closest("[data-testid='form-component']")
              : null;
            const countdownRoot = popupForm.querySelector("[data-testid='klaviyo-countdown']");
            const countdownComponent = countdownRoot instanceof HTMLElement
              ? countdownRoot.closest("[data-testid='form-component']")
              : null;
            const successActionButton = Array.from(popupForm.querySelectorAll('button')).find(
              (button) => button instanceof HTMLButtonElement && !button.classList.contains('klaviyo-close-form')
            );
            const successActionComponent = successActionButton instanceof HTMLButtonElement
              ? successActionButton.closest("[data-testid='form-component']")
              : null;
            if (successActionComponent instanceof HTMLElement) {
              successActionComponent.classList.add('sb-klaviyo-popup-copy-code-component');
            }
            if (successTitleComponent instanceof HTMLElement) {
              successTitleComponent.classList.add('sb-klaviyo-popup-success-title-component');
            }
            if (successBodyComponent instanceof HTMLElement) {
              successBodyComponent.classList.add('sb-klaviyo-popup-success-body-component');
            }
            if (successBodyRoot instanceof HTMLElement) {
              successBodyRoot.classList.add('sb-klaviyo-popup-success-body-richtext');
            }
            if (countdownComponent instanceof HTMLElement) {
              countdownComponent.classList.add('sb-klaviyo-popup-countdown-component');
            }

            const successTitleText = normalizeText(popupLocaleCopy.successTitle);
            if (successTitleRoot instanceof HTMLElement && successTitleText) {
              successTitleRoot.classList.add('font-title', 'weight-bold');
              if (successTitleRoot.dataset.sbLocalizedTitleSignature !== successTitleText) {
                successTitleRoot.replaceChildren();
                const successTitleNode = document.createElement('p');
                successTitleNode.className = 'font-title weight-bold';
                successTitleNode.textContent = successTitleText;
                successTitleRoot.appendChild(successTitleNode);
                successTitleRoot.dataset.sbLocalizedTitleSignature = successTitleText;
              }
            }

            if (successBodyRoot instanceof HTMLElement) {
              const existingSuccessBodyText = normalizeText(successBodyRoot.textContent);
              const discountCode = extractDiscountCode(existingSuccessBodyText);

              const codeTemplate = normalizeText(popupLocaleCopy.successCodeLine);
              const normalizedCodeTemplate = codeTemplate.replace(/\{\{\s*code\s*\}\}/gi, '__CODE__');
              const codeTemplateHasToken = normalizedCodeTemplate.includes('__CODE__');
              const localizedCodeLine =
                normalizedCodeTemplate && (!codeTemplateHasToken || discountCode)
                  ? normalizedCodeTemplate.replace(/__CODE__/g, discountCode)
                  : '';

              const successLines = [
                normalizeText(popupLocaleCopy.successOfferLine),
                normalizeText(popupLocaleCopy.successReminderLine),
                normalizeText(popupLocaleCopy.successExpiresIn),
              ];
              const successBodySignature = [
                localizedCodeLine,
                successLines[0],
                successLines[1],
                successLines[2],
              ].join('||');

              if (
                (localizedCodeLine || successLines.some(Boolean))
                && successBodyRoot.dataset.sbLocalizedSignature !== successBodySignature
              ) {
                successBodyRoot.replaceChildren();

                if (localizedCodeLine) {
                  const codeLineNode = document.createElement('div');
                  if (codeTemplateHasToken && discountCode) {
                    const templateSegments = normalizedCodeTemplate.split('__CODE__');
                    const prefixText = templateSegments[0] || '';
                    const suffixText = templateSegments.slice(1).join('__CODE__');
                    if (prefixText) {
                      codeLineNode.append(document.createTextNode(prefixText));
                    }
                    const codeStrong = document.createElement('strong');
                    codeStrong.textContent = discountCode;
                    codeLineNode.append(codeStrong);
                    if (suffixText) {
                      codeLineNode.append(document.createTextNode(suffixText));
                    }
                  } else {
                    codeLineNode.textContent = localizedCodeLine;
                  }
                  successBodyRoot.appendChild(codeLineNode);
                }

                const offerText = successLines[0];
                const reminderText = successLines[1];
                if (offerText || reminderText) {
                  const offerLineNode = document.createElement('div');
                  if (offerText) {
                    const offerStrong = document.createElement('strong');
                    offerStrong.textContent = offerText;
                    offerLineNode.appendChild(offerStrong);
                  }
                  if (reminderText) {
                    if (offerText) {
                      offerLineNode.append(document.createTextNode(' '));
                    }
                    offerLineNode.append(document.createTextNode(reminderText));
                  }
                  successBodyRoot.appendChild(offerLineNode);
                }

                const expiresText = successLines[2];
                if (expiresText) {
                  const expiresLineNode = document.createElement('div');
                  expiresLineNode.textContent = expiresText;
                  successBodyRoot.appendChild(expiresLineNode);
                }

                successBodyRoot.dataset.sbLocalizedSignature = successBodySignature;
              }
            }
          });
        };

        const localizePopupErrorMessages = () => {
          const popupForms = document.querySelectorAll("[data-testid='POPUP'] form[data-testid^='klaviyo-form-']");
          popupForms.forEach((popupForm) => {
            if (!(popupForm instanceof HTMLFormElement)) return;
            const hasEmailInput = popupForm.querySelector("input[type='email']") instanceof HTMLInputElement;
            if (!hasEmailInput) return;

            const errorNodes = popupForm.querySelectorAll(
              "[data-testid='form-message'], [data-testid='field-message'], [data-testid='error-message'], .error_message, [role='alert'], [aria-live='assertive'], [role='status']"
            );

            errorNodes.forEach((errorNode) => {
              if (!(errorNode instanceof HTMLElement)) return;
              if (errorNode.closest("[id^='engagement-counter-']")) return;
              const replacementText = getLocalizedPopupErrorText(errorNode.textContent);
              if (!replacementText) return;
              setNodeText(errorNode, replacementText);
            });
          });
        };

        const localizePopupCountdownUnits = () => {
          const popupForms = document.querySelectorAll("[data-testid='POPUP'] form[data-testid^='klaviyo-form-']");
          popupForms.forEach((popupForm) => {
            if (!(popupForm instanceof HTMLFormElement)) return;
            const hasEmailInput = popupForm.querySelector("input[type='email']") instanceof HTMLInputElement;
            if (hasEmailInput) return;

            const timerLabelNodes = popupForm.querySelectorAll(
              "[class*='timer'] span, [class*='timer'] div, [data-testid*='timer'] span, [data-testid*='timer'] div"
            );

            timerLabelNodes.forEach((timerLabelNode) => {
              if (!(timerLabelNode instanceof HTMLElement)) return;
              if (timerLabelNode.children.length > 0) return;
              const localizedTimerLabel = getLocalizedTimerLabel(timerLabelNode.textContent);
              if (!localizedTimerLabel) return;
              setNodeText(timerLabelNode, localizedTimerLabel);
            });
          });
        };

        const formatPopupEngagementCounters = () => {
          const counterRoots = document.querySelectorAll("[data-testid='POPUP'] [id^='engagement-counter-']");
          counterRoots.forEach((counterRoot) => {
            if (!(counterRoot instanceof HTMLElement)) return;
            const currentText = `${counterRoot.textContent || ''}`;
            const detectedCount = extractCounterValue(currentText);
            if (!Number.isFinite(detectedCount)) return;

            const formattedCount = numberFormatter.format(detectedCount);
            const counterTemplate = `${popupLocaleCopy.engagementTemplate || ''}`.replace(/\{\{\s*count\s*\}\}/gi, '__COUNT__');
            if (!counterTemplate.includes('__COUNT__')) return;

            const localizedCounterText = counterTemplate.replace('__COUNT__', formattedCount);

            let paragraphNode = counterRoot.querySelector('p');
            if (!(paragraphNode instanceof HTMLElement)) {
              paragraphNode = document.createElement('p');
              counterRoot.replaceChildren(paragraphNode);
            }

            let spanNode = paragraphNode.querySelector('span');
            if (!(spanNode instanceof HTMLElement)) {
              spanNode = document.createElement('span');
              paragraphNode.replaceChildren(spanNode);
            }

            if (spanNode.textContent !== localizedCounterText) {
              spanNode.textContent = localizedCounterText;
            }
          });
        };

        const applyPopupRadiantButtons = () => {
          const isButtonLoading = (button) => {
            if (!(button instanceof HTMLButtonElement)) return false;

            const hasTruthyState = (value) => {
              const normalized = `${value || ''}`.trim().toLowerCase();
              return normalized === 'true'
                || normalized === '1'
                || normalized === 'loading'
                || normalized === 'pending'
                || normalized === 'submitting';
            };

            if (hasTruthyState(button.getAttribute('aria-busy'))) return true;
            if (hasTruthyState(button.getAttribute('data-loading'))) return true;
            if (hasTruthyState(button.getAttribute('data-state'))) return true;
            if (hasTruthyState(button.getAttribute('aria-disabled'))) return true;

            const classNames = Array.from(button.classList).join(' ').toLowerCase();
            if (/(loading|spinner|progress|submitting|pending)/.test(classNames)) return true;

            const loadingNode = button.querySelector(
              "[role='progressbar'], progress, [class*='loading' i], [class*='spinner' i], [class*='progress' i]"
            );
            if (loadingNode) return true;

            if (button.disabled && button.closest(".sb-klaviyo-popup-form--initial")) return true;

            return false;
          };

          const popupForms = document.querySelectorAll("[data-testid='POPUP'] form[data-testid^='klaviyo-form-']");
          popupForms.forEach((popupForm) => {
            if (!(popupForm instanceof HTMLFormElement)) return;

            const submitButtons = popupForm.querySelectorAll("button[type='button']:not(.klaviyo-close-form)");

            submitButtons.forEach((button) => {
              if (!(button instanceof HTMLButtonElement)) return;

              button.classList.remove('sb-button-radiant--blue');
              button.classList.add('sb-button-radiant', 'sb-button-radiant--large', 'font-caption', 'weight-bold');

              const currentLabelText = `${button.textContent || ''}`.trim();
              const localizedLabelText = `${popupLocaleCopy.buttonLabel || ''}`.trim();
              const desiredLabelText = localizedLabelText || currentLabelText;
              let labelNode = button.querySelector('.sb-button-radiant__label');

              if (!labelNode) {
                labelNode = document.createElement('span');
                labelNode.className = 'sb-button-radiant__label';
                labelNode.textContent = desiredLabelText;
                button.textContent = '';
                button.appendChild(labelNode);
              } else if (desiredLabelText && labelNode.textContent !== desiredLabelText) {
                labelNode.textContent = desiredLabelText;
              }

              const isLoading = isButtonLoading(button);
              button.classList.toggle('sb-klaviyo-button-loading', isLoading);
            });
          });
        };

        const updatePopupBackdropState = () => {
          const rootNode = document.documentElement;
          const popupContainers = new Set();
          document.querySelectorAll(markerSelector).forEach((node) => {
            if (!(node instanceof HTMLElement)) return;
            const popupContainer = getPopupContainer(node);
            if (!(popupContainer instanceof HTMLElement)) return;
            popupContainers.add(popupContainer);
          });

          const hasVisiblePopup = Array.from(popupContainers).some((popupContainer) => isVisiblePopup(popupContainer));

          applyPopupLocalizedCopy();
          applyPopupRadiantButtons();
          localizePopupErrorMessages();
          formatPopupEngagementCounters();
          localizePopupCountdownUnits();
          if (rootNode instanceof HTMLElement) {
            rootNode.classList.toggle(popupOpenClass, hasVisiblePopup);
          }
        };

        let frameId = 0;
        const queueUpdate = () => {
          if (frameId) return;
          frameId = window.requestAnimationFrame(() => {
            frameId = 0;
            updatePopupBackdropState();
          });
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', queueUpdate, { once: true });
        } else {
          queueUpdate();
        }

        if (typeof MutationObserver !== 'function') return;
        const observer = new MutationObserver(queueUpdate);
        observer.observe(document.documentElement, {
          childList: true,
          subtree: true,
          attributes: true,
          attributeFilter: [
            'class',
            'style',
            'hidden',
            'aria-hidden',
            'data-testid',
            'aria-busy',
            'aria-disabled',
            'data-loading',
            'data-state',
            'disabled',
          ],
        });

        window.addEventListener('resize', queueUpdate, { passive: true });
        window.addEventListener('orientationchange', queueUpdate);
      })();
    </script>

