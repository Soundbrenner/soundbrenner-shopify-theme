          const affiliateName = `${affiliateState.affiliateName || ''}`.trim();
          const expiresAt = Number.parseInt(`${affiliateState.expiresAt || ''}`, 10);
          if (!affiliateName || !Number.isFinite(expiresAt) || expiresAt <= Date.now()) return;
          if (!Number.isFinite(affiliateDiscountDepth) || affiliateDiscountDepth <= 0) return;

          if (isProductPage && productTitle) {
            document.title = replacePlaceholders(
              {{ sb_affiliate_meta_product_title_template | json }},
              {
                '__SB_TITLE__': productTitle,
                '__SB_DISCOUNT__': affiliateDiscountDepth,
                '__SB_SALE__': affiliateName,
