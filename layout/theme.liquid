      (() => {
        const affiliateDiscountDepth = Number({{ settings.sitewide_affiliate_discount_depth | default: 0 | json }});
        const isProductPage = {{ sb_affiliate_meta_is_product_page | json }};
        const isHomePage = {{ sb_affiliate_meta_is_home_page | json }};
        const productTitle = {{ sb_affiliate_meta_product_title | json }};
        const shopName = {{ shop.name | json }};

        const replacePlaceholders = (template, replacements) => {
          let nextValue = `${template || ''}`;
          Object.entries(replacements).forEach(([key, value]) => {
            nextValue = nextValue.replaceAll(key, `${value ?? ''}`);
          });
          return nextValue;
        };

        const applyAffiliateTitleOverride = () => {
          const affiliateState = window.SBAffiliateAnnouncementState;
          if (!affiliateState || typeof affiliateState !== 'object') return;

          const affiliateName = `${affiliateState.affiliateName || ''}`.trim();
          const expiresAt = Number.parseInt(`${affiliateState.expiresAt || ''}`, 10);
          if (!affiliateName || !Number.isFinite(expiresAt) || expiresAt <= Date.now()) return;
          if (!Number.isFinite(affiliateDiscountDepth) || affiliateDiscountDepth <= 0) return;

          if (isProductPage && productTitle) {
            document.title = replacePlaceholders(
              {{ sb_affiliate_meta_product_title_template | json }},
              {
                '__SB_TITLE__': productTitle,
                '__SB_DISCOUNT__': affiliateDiscountDepth,
                '__SB_SALE__': affiliateName,
              }
            );
            return;
          }

          if (isHomePage) {
            document.title = replacePlaceholders(
              {{ sb_affiliate_meta_shop_title_template | json }},
              {
                '__SB_SHOP__': shopName,
                '__SB_DISCOUNT__': affiliateDiscountDepth,
                '__SB_SALE__': affiliateName,
              }
            );
          }
        };

        applyAffiliateTitleOverride();
        window.addEventListener('load', applyAffiliateTitleOverride, { once: true });
      })();
    </script>
