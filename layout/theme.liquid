              const countFromLabel = (existingLabel?.textContent || '').match(/(\d[\d.,\s\u00A0\u202F]*)/);
              const ratingFromAria = ariaNumericTokens.find((token) => /[.,]/.test(token)) || ariaNumericTokens[0] || '';
              const countFromAria = ariaNumericTokens
