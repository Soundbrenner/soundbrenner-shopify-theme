    <script>
      (() => {
        const existingStorefrontPricing = window.SBStorefrontPricing;
        if (
          existingStorefrontPricing
          && typeof existingStorefrontPricing.formatMoney === 'function'
          && typeof existingStorefrontPricing.getDiscountRate === 'function'
          && typeof existingStorefrontPricing.parseCents === 'function'
          && typeof existingStorefrontPricing.resolvePrice === 'function'
        ) {
          return;
        }

        const parseCents = (value) => {
          const nextValue = Number.parseInt(`${value ?? ''}`.trim(), 10);
          return Number.isFinite(nextValue) ? nextValue : null;
        };

        const clampDiscountRate = (value) => {
          if (!Number.isFinite(value)) return 0;
          return Math.min(1, Math.max(0, value));
        };

        const seasonalDiscountRate = clampDiscountRate(
          Number({{ settings.sitewide_seasonal_discount_depth | json }}) / 100
        );
        const affiliateDiscountRate = clampDiscountRate(
          Number({{ settings.sitewide_affiliate_discount_depth | json }}) / 100
        );
        const cartDiscountRate = clampDiscountRate(
          Number({{ storefront_cart_discount_depth | json }}) / 100
        );
        const hasAffiliateSaleCookie = (() => {
          const affiliateState = window.SBAffiliateAnnouncementState;
          if (!affiliateState || typeof affiliateState !== 'object') return false;
          const expiresAt = Number.parseInt(`${affiliateState.expiresAt || ''}`, 10);
          return Number.isFinite(expiresAt) && expiresAt > Date.now();
        })();
        const effectiveGlobalDiscountRate = (() => {
          if (cartDiscountRate > 0) return cartDiscountRate;
          if (hasAffiliateSaleCookie) return affiliateDiscountRate;
          return seasonalDiscountRate;
        })();

        const productOverrideEntries = [
          {
            productId: {{ all_products[settings.storefront_price_override_product_id_1].id | default: '' | json }},
            discountPercent: Number({{ settings.storefront_price_override_discount_depth_1 | default: 0 | json }}),
          },
          {
            productId: {{ all_products[settings.storefront_price_override_product_id_2].id | default: '' | json }},
            discountPercent: Number({{ settings.storefront_price_override_discount_depth_2 | default: 0 | json }}),
          },
          {
            productId: {{ all_products[settings.storefront_price_override_product_id_3].id | default: '' | json }},
            discountPercent: Number({{ settings.storefront_price_override_discount_depth_3 | default: 0 | json }}),
          },
          {
            productId: {{ all_products[settings.storefront_price_override_product_id_4].id | default: '' | json }},
            discountPercent: Number({{ settings.storefront_price_override_discount_depth_4 | default: 0 | json }}),
          },
        ];

        const productOverrideRateById = new Map();
        productOverrideEntries.forEach((entry) => {
          const productId = `${entry?.productId || ''}`.trim();
          const rate = clampDiscountRate(Number(entry?.discountPercent || 0) / 100);
          if (!productId || productId === '0' || rate <= 0) return;
          productOverrideRateById.set(productId, rate);
        });

        const getDiscountRate = (productId) => {
          const normalizedProductId = `${productId || ''}`.trim();
          const productRate = normalizedProductId
            ? Number(productOverrideRateById.get(normalizedProductId) || 0)
            : 0;

          if (effectiveGlobalDiscountRate > 0 && productRate > 0) {
            return clampDiscountRate(1 - ((1 - effectiveGlobalDiscountRate) * (1 - productRate)));
          }

          return clampDiscountRate(Math.max(effectiveGlobalDiscountRate, productRate));
        };

        const fallbackCurrency = {{ cart.currency.iso_code | default: localization.country.currency.iso_code | default: shop.currency | json }};
        const formatterCache = new Map();

        const resolveCurrency = (preferredCurrency = '') => {
          const normalizedPreferredCurrency = `${preferredCurrency || ''}`.trim().toUpperCase();
          if (normalizedPreferredCurrency) return normalizedPreferredCurrency;
          return `${fallbackCurrency || ''}`.trim().toUpperCase();
        };

        const normalizeContext = (context = 'storefront') => {
          const normalized = `${context || ''}`.trim().toLowerCase();
          return normalized === 'cart' ? 'cart' : 'storefront';
        };

        const getMoneyFormatter = (currencyCode, context = 'storefront') => {
          const normalizedCurrencyCode = resolveCurrency(currencyCode);
          if (!normalizedCurrencyCode) return null;
          const normalizedContext = normalizeContext(context);
          const cacheKey = `${normalizedContext}:${normalizedCurrencyCode}`;
          if (formatterCache.has(cacheKey)) return formatterCache.get(cacheKey);
          const formatterOptions = {
            style: 'currency',
            currency: normalizedCurrencyCode,
            currencyDisplay: 'symbol',
          };
          if (normalizedContext !== 'cart') {
            formatterOptions.minimumFractionDigits = 0;
            formatterOptions.maximumFractionDigits = 0;
          } else {
            formatterOptions.minimumFractionDigits = 0;
          }
          const formatter = new Intl.NumberFormat(document.documentElement.lang || undefined, formatterOptions);
          formatterCache.set(cacheKey, formatter);
          return formatter;
        };

        const formatMoney = (cents, currencyOverride = '', options = {}) => {
          const normalizedCents = Number.isFinite(Number(cents)) ? Math.round(Number(cents)) : 0;
          const context = normalizeContext(options?.context || 'storefront');
          const displayCents = context === 'cart'
            ? normalizedCents
            : Math.round(normalizedCents / 100) * 100;
          const formatter = getMoneyFormatter(currencyOverride, context);
          if (!formatter) return '';
          return formatter.format(displayCents / 100);
        };

        const resolvePrice = ({
          productId = '',
          priceCents = null,
          comparePriceCents = null,
        } = {}) => {
          const normalizedPriceCents = parseCents(priceCents);
          if (!Number.isFinite(normalizedPriceCents) || normalizedPriceCents <= 0) {
            return {
              currentPriceCents: null,
              comparePriceCents: null,
              hasComparePrice: false,
              discountRate: 0,
            };
          }

          const discountRate = getDiscountRate(productId);
          if (discountRate > 0) {
            const discountedPriceCents = Math.max(0, Math.round(normalizedPriceCents * (1 - discountRate)));
            return {
              currentPriceCents: discountedPriceCents,
              comparePriceCents: normalizedPriceCents,
              hasComparePrice: normalizedPriceCents > discountedPriceCents,
              discountRate,
            };
          }

          const normalizedComparePriceCents = parseCents(comparePriceCents);
          if (Number.isFinite(normalizedComparePriceCents) && normalizedComparePriceCents > normalizedPriceCents) {
            return {
              currentPriceCents: normalizedPriceCents,
              comparePriceCents: normalizedComparePriceCents,
              hasComparePrice: true,
              discountRate: 0,
            };
          }

          return {
            currentPriceCents: normalizedPriceCents,
            comparePriceCents: null,
            hasComparePrice: false,
            discountRate: 0,
          };
        };

        window.SBStorefrontPricing = {
          formatMoney,
          getDiscountRate,
          parseCents,
          resolvePrice,
        };
      })();
    </script>

