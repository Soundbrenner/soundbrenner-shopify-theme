            const parsedCount = parseLocalizedInteger(currentText);
            if (!Number.isFinite(parsedCount)) return;

            const nextText = reviewsCountTemplate.replace(/__COUNT__/g, numberFormatter.format(parsedCount));

            if (nextText !== currentText) {
              target.textContent = nextText;
            }
          });

          const tabCountLabels = root.querySelectorAll('.kl_reviews__list__tab small');
          tabCountLabels.forEach((target) => {
            const raw = (target.textContent || '').replace(/[^\d]/g, '');
            if (!raw) return;
            const formatted = numberFormatter.format(Number(raw));
            if (formatted !== target.textContent) {
              target.textContent = formatted;
            }
          });

          const orderTimestamps = root.querySelectorAll('.kl_reviews__review__order_timestamp');
          orderTimestamps.forEach((target) => {
            const currentText = target.textContent;
            if (!currentText) return;

            const withoutBullet = currentText.replace(/^\s*[•·]\s*/, '').trim();
            const deduped = withoutBullet.replace(/^(.+?)\1+$/, '$1').trim();

            if (deduped !== currentText.trim()) {
              target.textContent = deduped;
              return;
            }

            if (withoutBullet !== currentText.trim()) {
              target.textContent = withoutBullet;
              return;
            }

            if (deduped !== withoutBullet) {
              target.textContent = deduped;
              return;
            }

            if (deduped !== currentText) {
              target.textContent = deduped;
            }
          });

          const productReviewInfos = root.querySelectorAll(
            '.kl_reviews__review__product_card__details__review_info'
          );
          productReviewInfos.forEach((target) => {
            const currentText = target.textContent;
            if (!currentText) return;

            const nextText = currentText
              .replace(/\s+/g, ' ')
              .replace(/\s·\s/g, ' • ')
              .trim();

            const numericTokens = Array.from(nextText.matchAll(/\d[\d.,\s\u00A0\u202F]*/g)).map((match) => `${match[0]}`.trim());
            const ratingToken = numericTokens[0] || '';
            const reviewsToken = numericTokens.length > 1 ? numericTokens[numericTokens.length - 1] : '';

            if (ratingToken && reviewsToken) {
              const parsedRatingValue = parseLocalizedDecimal(ratingToken);
              const parsedReviewsCount = parseLocalizedInteger(reviewsToken);
              const ratingValue = Number.isFinite(parsedRatingValue)
                ? ratingFormatter.format(parsedRatingValue)
                : ratingToken;
              const reviewsValue = Number.isFinite(parsedReviewsCount)
                ? numberFormatter.format(parsedReviewsCount)
                : `${reviewsToken}`.trim();
              const reviewsCopy = reviewsCountTemplate.replace(/__COUNT__/g, reviewsValue);
              const nextHtml =
                `<span class="sb-klaviyo-rating-value">${ratingValue}</span>` +
                `<span class="sb-klaviyo-inline-star" aria-hidden="true"></span>` +
                `<span class="sb-klaviyo-inline-dot" aria-hidden="true">•</span>` +
                `<span class="sb-klaviyo-rating-reviews">${reviewsCopy}</span>`;
              if (target.innerHTML !== nextHtml) target.innerHTML = nextHtml;
              return;
            }

            // Fallback dedupe for any repeated fragments during rerenders.
            const dedupedText = nextText.replace(/(.+?)\s+\1+$/, '$1').trim();
            if (dedupedText !== currentText.trim()) target.textContent = dedupedText;
          });

          const productNames = root.querySelectorAll('.kl_reviews__review__product_card__details__name');
          productNames.forEach((target) => {
            const currentText = target.textContent;
            if (!currentText) return;
            const compact = currentText.replace(/\s+/g, ' ').trim();
            const deduped = compact.replace(/^(.+?)\s+\1+$/, '$1').trim();
            if (deduped !== compact) target.textContent = deduped;
          });

          applyCustomStarPaths(root);
          normalizeRangeSvgs(root);
          normalizeFilterSelects(root);
        };

        const localizeThemeRatingTokens = (scope = document) => {
          if (!(scope instanceof Element || scope instanceof Document)) return;

          scope.querySelectorAll('[data-sb-localized-count-template][data-sb-localized-count-value]').forEach((node) => {
            if (!(node instanceof HTMLElement)) return;
            const template = `${node.dataset.sbLocalizedCountTemplate || ''}`.trim();
            if (!template) return;
            const rawCountValue = `${node.dataset.sbLocalizedCountValue || ''}`;
            if (!isPlainNumericCountString(rawCountValue)) return;
            const parsedCount = parseLocalizedInteger(rawCountValue);
            if (!Number.isFinite(parsedCount)) return;
            const nextText = template.replace(/__COUNT__/g, numberFormatter.format(parsedCount));
            if (nextText && node.textContent !== nextText) {
              node.textContent = nextText;
            }
          });

          scope.querySelectorAll('[data-sb-localized-rating-value]').forEach((node) => {
            if (!(node instanceof HTMLElement)) return;
            if (node.hasAttribute('data-sb-localized-rating-template') || node.hasAttribute('data-sb-localized-rating-summary-template')) return;
            const parsedRating = parseLocalizedDecimal(node.dataset.sbLocalizedRatingValue || '');
            if (!Number.isFinite(parsedRating)) return;
            const fixedDigitsRaw = Number.parseInt(node.dataset.sbLocalizedRatingDigits || '1', 10);
            const fixedDigits = Number.isFinite(fixedDigitsRaw) && fixedDigitsRaw >= 0 ? fixedDigitsRaw : 1;
            const formatter = new Intl.NumberFormat(locale, {
              minimumFractionDigits: fixedDigits,
              maximumFractionDigits: fixedDigits,
            });
            const nextText = formatter.format(parsedRating);
            if (nextText && node.textContent !== nextText) {
              node.textContent = nextText;
            }
          });

          scope.querySelectorAll('[data-sb-localized-rating-template][data-sb-localized-rating-value]').forEach((node) => {
            if (!(node instanceof HTMLElement)) return;
            const template = `${node.dataset.sbLocalizedRatingTemplate || ''}`.trim();
            if (!template) return;
            const parsedRating = parseLocalizedDecimal(node.dataset.sbLocalizedRatingValue || '');
            if (!Number.isFinite(parsedRating)) return;
            const fixedDigitsRaw = Number.parseInt(node.dataset.sbLocalizedRatingDigits || '1', 10);
            const fixedDigits = Number.isFinite(fixedDigitsRaw) && fixedDigitsRaw >= 0 ? fixedDigitsRaw : 1;
            const formatter = new Intl.NumberFormat(locale, {
              minimumFractionDigits: fixedDigits,
              maximumFractionDigits: fixedDigits,
            });
            const formattedRating = formatter.format(parsedRating);
            const nextText = template.replace(/__RATING__/g, formattedRating);
            if (nextText && node.textContent !== nextText) {
              node.textContent = nextText;
            }
          });

          scope.querySelectorAll('[data-sb-localized-rating-summary-template][data-sb-localized-rating-value][data-sb-localized-count-value]').forEach((node) => {
            if (!(node instanceof HTMLElement)) return;
            const template = `${node.dataset.sbLocalizedRatingSummaryTemplate || ''}`.trim();
            if (!template) return;
            const parsedRating = parseLocalizedDecimal(node.dataset.sbLocalizedRatingValue || '');
            const rawCountValue = `${node.dataset.sbLocalizedCountValue || ''}`;
            if (!isPlainNumericCountString(rawCountValue)) return;
            const parsedCount = parseLocalizedInteger(rawCountValue);
            if (!Number.isFinite(parsedRating) || !Number.isFinite(parsedCount)) return;
            const digitsRaw = Number.parseInt(node.dataset.sbLocalizedRatingDigits || '1', 10);
            const digits = Number.isFinite(digitsRaw) && digitsRaw >= 0 ? digitsRaw : 1;
            const formatter = new Intl.NumberFormat(locale, {
              minimumFractionDigits: digits,
              maximumFractionDigits: digits,
            });
            const formattedRating = formatter.format(parsedRating);
            const formattedCount = numberFormatter.format(parsedCount);
            const nextText = template
              .replace(/__RATING__/g, formattedRating)
              .replace(/__COUNT__/g, formattedCount);
            if (!nextText) return;
            const paragraph = node.querySelector('p');
            if (paragraph instanceof HTMLElement) {
              if (paragraph.textContent !== nextText) {
                paragraph.textContent = nextText;
              }
            } else if (node.textContent !== nextText) {
              node.textContent = nextText;
            }
          });
        };

        const customerPrivacyCheckboxOffSvg = {{ 'icon-data-sharing-opt-out-checkbox-off.svg' | inline_asset_content | strip_newlines | json }};
        const customerPrivacyCheckboxOnSvg = {{ 'icon-data-sharing-opt-out-checkbox-on.svg' | inline_asset_content | strip_newlines | json }};
        let customerPrivacyCheckboxBackgrounds = null;
        let customerPrivacyCheckboxOffFillColor = '';
        let customerPrivacyCheckboxOnFillColor = '';
        const toInlineSvgDataUrl = (svgContent) => `url("data:image/svg+xml;charset=utf-8,${encodeURIComponent(svgContent)}")`;
        const getCustomerPrivacyCheckboxBackgrounds = () => {
          const computedStyles = window.getComputedStyle(document.documentElement);
          const nextOffFillColor = computedStyles
            .getPropertyValue('--sb-color-neutral-900')
            .trim();
          const nextOnFillColor = computedStyles
            .getPropertyValue('--sb-color-primary-500')
            .trim();
          if (!nextOffFillColor || !nextOnFillColor) return customerPrivacyCheckboxBackgrounds;
          if (
            customerPrivacyCheckboxBackgrounds
            && customerPrivacyCheckboxOffFillColor === nextOffFillColor
            && customerPrivacyCheckboxOnFillColor === nextOnFillColor
          ) {
            return customerPrivacyCheckboxBackgrounds;
          }
          customerPrivacyCheckboxOffFillColor = nextOffFillColor;
          customerPrivacyCheckboxOnFillColor = nextOnFillColor;
          customerPrivacyCheckboxBackgrounds = {
            off: toInlineSvgDataUrl(customerPrivacyCheckboxOffSvg.replaceAll('fill="white"', `fill="${nextOffFillColor}"`)),
            on: toInlineSvgDataUrl(customerPrivacyCheckboxOnSvg.replaceAll('fill="white"', `fill="${nextOnFillColor}"`)),
          };
          return customerPrivacyCheckboxBackgrounds;
        };
        const applyCustomerPrivacyCheckboxVisualState = (checkboxNode) => {
          if (!(checkboxNode instanceof HTMLInputElement)) return;
          const iconNode = checkboxNode.closest('label')?.querySelector('span[aria-hidden="true"]');
          if (!(iconNode instanceof HTMLElement)) return;
          const backgrounds = getCustomerPrivacyCheckboxBackgrounds();
          if (!backgrounds) return;
          const { off, on } = backgrounds;
          if (checkboxNode.checked) {
            iconNode.style.backgroundImage = `${on}, linear-gradient(var(--sb-color-always-white), var(--sb-color-always-white))`;
            iconNode.style.backgroundSize = '20px 20px, 16px 16px';
            iconNode.style.backgroundPosition = 'center center, center center';
            iconNode.style.backgroundRepeat = 'no-repeat, no-repeat';
          } else {
            iconNode.style.backgroundImage = off;
            iconNode.style.backgroundSize = '20px 20px';
            iconNode.style.backgroundPosition = 'center center';
            iconNode.style.backgroundRepeat = 'no-repeat';
          }
          iconNode.style.backgroundColor = 'transparent';
        };
        const syncCustomerPrivacyCheckboxes = (scope = document) => {
          if (!(scope instanceof Element || scope instanceof Document)) return;
          scope.querySelectorAll('#shopify-pc__prefs__dialog .shopify-pc__prefs__option input[type="checkbox"]').forEach((checkboxNode) => {
            if (!(checkboxNode instanceof HTMLInputElement)) return;
            applyCustomerPrivacyCheckboxVisualState(checkboxNode);
            if (checkboxNode.dataset.sbCustomerPrivacyCheckboxBound === 'true') return;
            const syncCheckboxVisualState = () => applyCustomerPrivacyCheckboxVisualState(checkboxNode);
            checkboxNode.addEventListener('change', syncCheckboxVisualState);
            checkboxNode.addEventListener('input', syncCheckboxVisualState);
            checkboxNode.dataset.sbCustomerPrivacyCheckboxBound = 'true';
          });
        };


        const observeAndFormat = (root) => {
          if (formattingObserver) return;

          formatCounts(root);

          let isQueued = false;
          formattingObserver = new MutationObserver(() => {
            if (isQueued) return;
            isQueued = true;
            requestAnimationFrame(() => {
              isQueued = false;
              formatCounts(root);
            });
          });

          formattingObserver.observe(root, { childList: true, subtree: true });
        };

        const observeWidgets = () => {
          if (widgetObserver) return;

          applyCustomStarPaths(document);
          normalizeRangeSvgs(document);
          normalizeFilterSelects(document);
          formatStarRatingWidgets(document);
          localizeThemeRatingTokens(document);
          syncCustomerPrivacyCheckboxes(document);

          let isQueued = false;
          widgetObserver = new MutationObserver(() => {
            if (isQueued) return;
            isQueued = true;
            requestAnimationFrame(() => {
              isQueued = false;
              applyCustomStarPaths(document);
              normalizeRangeSvgs(document);
              normalizeFilterSelects(document);
              formatStarRatingWidgets(document);
              localizeThemeRatingTokens(document);
              syncCustomerPrivacyCheckboxes(document);
            });
          });

          widgetObserver.observe(document.body, { childList: true, subtree: true });
        };

        const init = () => {
          const root = document.querySelector(rootSelector);
          if (!root) return false;
          observeAndFormat(root);
          return true;
        };

        observeWidgets();
        if (init()) return;

        const rootFinder = new MutationObserver(() => {
          if (!init()) return;
          rootFinder.disconnect();
        });

        rootFinder.observe(document.body, {
          childList: true,
          subtree: true,
        });
      })();
    </script>
    {% if request.page_type == 'product' and product != blank %}
      <script>
        (() => {
          const storageKey = 'viewedProducts';
          const maxProducts = 4;
          const currentProductId = `${'{{ product.id }}'}`.trim();

          if (!/^\d+$/.test(currentProductId)) return;

          const normalizeProductIds = (items) =>
            items
              .map((item) => `${item || ''}`.trim())
              .filter((item) => /^\d+$/.test(item));

          try {
            const rawStoredValue = window.localStorage.getItem(storageKey);
            const parsedStoredValue = rawStoredValue ? JSON.parse(rawStoredValue) : [];
            const viewedProducts = Array.isArray(parsedStoredValue) ? normalizeProductIds(parsedStoredValue) : [];
            const deduplicatedProducts = viewedProducts.filter((productId) => productId !== currentProductId);
            deduplicatedProducts.unshift(currentProductId);
            window.localStorage.setItem(storageKey, JSON.stringify(deduplicatedProducts.slice(0, maxProducts)));
          } catch (_) {
          }
        })();
      </script>
    {% endif %}
    <script>
      (() => {
        const root = document.documentElement;
        if (!(root instanceof HTMLElement)) return;
        const visualViewport = window.visualViewport;
        let dockReserveFrame = 0;

        const getActiveMobileDocks = () =>
          Array.from(
            document.querySelectorAll(
              '.sb-product-main__sticky-bottom-bar-wrap:not(.sb-product-main__sticky-bottom-bar-wrap--hidden), .sb-metronome-app-sticky-nav__bar'
            )
          ).filter((dock) => dock instanceof HTMLElement);

        const updateMobileBottomDockReserve = () => {
          dockReserveFrame = 0;

          const viewportHeight = visualViewport ? visualViewport.height : window.innerHeight || 0;
          let maxReserve = 0;

          getActiveMobileDocks().forEach((dock) => {
            const styles = window.getComputedStyle(dock);
            if (styles.position !== 'fixed' || styles.display === 'none' || styles.visibility === 'hidden') return;
            if (styles.pointerEvents === 'none' && Number.parseFloat(styles.opacity || '1') === 0) return;

            const rect = dock.getBoundingClientRect();
            if (rect.height <= 0) return;

            const reserve = Math.max(0, viewportHeight - rect.top);
            if (reserve > maxReserve) maxReserve = reserve;
          });

          root.style.setProperty('--sb-mobile-bottom-dock-reserve', `${Math.ceil(maxReserve)}px`);
        };

        const requestMobileBottomDockReserveUpdate = () => {
          if (dockReserveFrame) return;
          dockReserveFrame = window.requestAnimationFrame(updateMobileBottomDockReserve);
        };

        updateMobileBottomDockReserve();
        window.addEventListener('resize', requestMobileBottomDockReserveUpdate, { passive: true });
        window.addEventListener('orientationchange', requestMobileBottomDockReserveUpdate);
        window.addEventListener('pageshow', requestMobileBottomDockReserveUpdate);
        document.addEventListener('visibilitychange', () => {
          if (!document.hidden) requestMobileBottomDockReserveUpdate();
        });
        document.addEventListener('shopify:section:load', requestMobileBottomDockReserveUpdate);
        document.addEventListener('shopify:section:unload', requestMobileBottomDockReserveUpdate);

        if (visualViewport) {
          visualViewport.addEventListener('resize', requestMobileBottomDockReserveUpdate);
          visualViewport.addEventListener('scroll', requestMobileBottomDockReserveUpdate);
        }

        if ('ResizeObserver' in window) {
          const dockObserver = new ResizeObserver(requestMobileBottomDockReserveUpdate);
          getActiveMobileDocks().forEach((dock) => dockObserver.observe(dock));
        }
      })();
    </script>
  </body>
</html>
