              if (!button) return;

              const nextImage = String(button.dataset.thumbnailImage || '').trim();
              const nextHoverImage = String(button.dataset.thumbnailHoverImage || '').trim();
              const nextGallery = String(button.dataset.thumbnailGallery || '').trim();
