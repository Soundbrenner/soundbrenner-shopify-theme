<!doctype html>
<html lang="{{ request.locale.iso_code }}" data-theme="light">
  <head>
    {% render 'shogun-optimizer' %}

    {% assign page_title = 'password.page_title' | t %}

    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'template-password.css' | asset_url | stylesheet_tag }}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}
    <script src="{{ 'template-password.js' | asset_url }}" defer></script>

    {{ content_for_header }}
  </head>

  <body class="sb-password-page">
    <main class="sb-password-page__main" role="main">
      {{ content_for_layout }}
    </main>

    <noscript>
      <div class="sb-password-noscript">
        {% form 'storefront_password' %}
          <div class="sb-password-dialog__surface sb-password-noscript__surface">
            <button type="button" class="sb-password-dialog__close" aria-label="{{ 'password.close_dialog' | t }}">
              {{ 'icon-cancel-with-padding.svg' | inline_asset_content }}
            </button>

            <div class="sb-password-dialog__logo" aria-hidden="true">
              {{ 'logo-soundbrenner-wordmark.svg' | inline_asset_content }}
            </div>

            {% if form.errors %}
              <div class="sb-password-dialog__errors">
                {{ form.errors | default_errors }}
              </div>
            {% endif %}

            <div class="sb-password-dialog__form">
              <label class="visually-hidden" for="PasswordNoScript">{{ 'password.password' | t }}</label>
              <input
                type="password"
                name="password"
                id="PasswordNoScript"
                class="sb-password-dialog__input"
                autocomplete="current-password"
                placeholder="{{ 'password.password' | t }}"
              >
              {% render 'radiant-button',
                label: 'password.submit' | t,
                button_type: 'submit',
                size: 'large',
                extra_class: 'sb-password-button sb-password-dialog__submit font-caption weight-bold'
              %}
            </div>
          </div>
        {% endform %}
      </div>
    </noscript>

    {% form 'storefront_password' %}
      <dialog
        id="PasswordDialog"
        class="sb-password-dialog"
        data-password-dialog
        {% if form.errors %}
          open
        {% endif %}
      >
        <div class="sb-password-dialog__surface">
          <button
            type="button"
            class="sb-password-dialog__close"
            data-password-dialog-close
            aria-label="{{ 'password.close_dialog' | t }}"
          >
            {{ 'icon-cancel-with-padding.svg' | inline_asset_content }}
          </button>

          <div class="sb-password-dialog__logo" aria-hidden="true">
            {{ 'logo-soundbrenner-wordmark.svg' | inline_asset_content }}
          </div>

          {% if form.errors %}
            <div class="sb-password-dialog__errors">
              {{ form.errors | default_errors }}
            </div>
          {% endif %}

          <div class="sb-password-dialog__form">
            <label class="visually-hidden" for="Password">{{ 'password.password' | t }}</label>
            <input
              type="password"
              name="password"
              id="Password"
              class="sb-password-dialog__input"
              autocomplete="current-password"
              placeholder="{{ 'password.password' | t }}"
              autofocus
            >
            {% render 'radiant-button',
              label: 'password.submit' | t,
              button_type: 'submit',
              size: 'large',
              extra_class: 'sb-password-button sb-password-dialog__submit font-caption weight-bold'
            %}
          </div>
        </div>
      </dialog>
    {% endform %}
  </body>
</html>
